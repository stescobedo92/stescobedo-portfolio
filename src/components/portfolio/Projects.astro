  .deck-card:hover .card-bars {
    opacity: 0.95;
  }

  .card-bar {
    display: inline-block;
    width: 3px;
    height: var(--h, 50%);
    background: var(--lang-hue);
    border-radius: 1px 1px 0 0;
    opacity: 0.7;
  }

  /* stars */
  .card-stars {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    color: rgba(187, 247, 208, 0.7);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
  }

  .star-glyph {
    color: var(--amber-300);
    font-size: 0.78rem;
  }

  /* "now showing" badge — visible only on the active card */
  .card-now {
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
    padding: 0.08rem 0.45rem;
    border-radius: 999px;
    background: rgba(110, 231, 183, 0.12);
