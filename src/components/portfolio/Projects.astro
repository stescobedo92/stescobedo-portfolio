  .tab-radio:nth-of-type(1):checked ~ .deck-row > .deck-card[data-tab-index="0"] .card-accent,
  .tab-radio:nth-of-type(2):checked ~ .deck-row > .deck-card[data-tab-index="1"] .card-accent,
  .tab-radio:nth-of-type(3):checked ~ .deck-row > .deck-card[data-tab-index="2"] .card-accent,
  .tab-radio:nth-of-type(4):checked ~ .deck-row > .deck-card[data-tab-index="3"] .card-accent,
  .tab-radio:nth-of-type(5):checked ~ .deck-row > .deck-card[data-tab-index="4"] .card-accent {
    opacity: 1;
    height: 3px;
    box-shadow: 0 0 16px var(--lang-hue);
  }

  .tab-radio:nth-of-type(1):checked ~ .deck-row > .deck-card[data-tab-index="0"] .card-now,
  .tab-radio:nth-of-type(2):checked ~ .deck-row > .deck-card[data-tab-index="1"] .card-now,
  .tab-radio:nth-of-type(3):checked ~ .deck-row > .deck-card[data-tab-index="2"] .card-now,
  .tab-radio:nth-of-type(4):checked ~ .deck-row > .deck-card[data-tab-index="3"] .card-now,
  .tab-radio:nth-of-type(5):checked ~ .deck-row > .deck-card[data-tab-index="4"] .card-now {
    opacity: 1;
    transform: translateY(0);
  }

  .tab-radio:nth-of-type(1):checked ~ .deck-row > .deck-card[data-tab-index="0"] .card-bars,
  .tab-radio:nth-of-type(2):checked ~ .deck-row > .deck-card[data-tab-index="1"] .card-bars,
  .tab-radio:nth-of-type(3):checked ~ .deck-row > .deck-card[data-tab-index="2"] .card-bars {
    opacity: 1;
  }

  .tab-radio:nth-of-type(1):checked ~ .deck-row > .deck-card[data-tab-index="0"] .card-jump,
  .tab-radio:nth-of-type(2):checked ~ .deck-row > .deck-card[data-tab-index="1"] .card-jump,
  .tab-radio:nth-of-type(3):checked ~ .deck-row > .deck-card[data-tab-index="2"] .card-jump {
    color: var(--lang-hue);
    transform: translateY(3px);
  }

  /* ─── editor body ─── */
  .ide-body {
    position: relative;
    background: rgba(13, 22, 42, 0.55);
  }

  .panel {
    display: none;
    animation: panel-fade 320ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  /* show only the panel matching the checked radio */
  .tab-radio:nth-of-type(1):checked ~ .ide-body > .panel[data-panel-index="0"],
  .tab-radio:nth-of-type(2):checked ~ .ide-body > .panel[data-panel-index="1"],
  .tab-radio:nth-of-type(3):checked ~ .ide-body > .panel[data-panel-index="2"],
  .tab-radio:nth-of-type(4):checked ~ .ide-body > .panel[data-panel-index="3"],
  .tab-radio:nth-of-type(5):checked ~ .ide-body > .panel[data-panel-index="4"] {
    display: block;
  }

  @keyframes panel-fade {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1rem;
    background: rgba(22, 30, 52, 0.6);
    border-bottom: 1px solid rgba(110, 231, 183, 0.08);
    font-family: var(--mono);
    font-size: 0.7rem;
    color: rgba(187, 247, 208, 0.65);
    overflow-x: auto;
    white-space: nowrap;
  }

  .bc-glyph { color: var(--emerald-400); }
  .bc-seg { color: rgba(187, 247, 208, 0.55); }
  .bc-seg.active { color: var(--slate-100); font-weight: 500; }
  .bc-icon { color: var(--lang-hue); margin-right: 0.2rem; }
  .bc-sep { color: rgba(187, 247, 208, 0.3); margin: 0 0.05rem; }
  .bc-spacer { flex: 1; }
  .bc-action {
    color: rgba(110, 231, 183, 0.5);
    letter-spacing: 0.06em;
    font-size: 0.62rem;
  }

  /* split layout */
  .editor-split {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.85fr);
    min-height: 480px;
  }

  /* ─── code pane ─── */
  .code-pane {
    position: relative;
    padding: 1rem 0.5rem 1.5rem 0;
    background:
      radial-gradient(circle at top right, var(--lang-hue-soft), transparent 60%),
      rgba(13, 22, 42, 0.6);
    border-right: 1px solid rgba(110, 231, 183, 0.08);
    overflow-x: auto;
  }

  .code-block {
    margin: 0;
    padding: 0;
    font-family: var(--mono);
    font-size: 0.82rem;
    line-height: 1.65;
    color: var(--slate-300);
    white-space: pre;
  }

  .code-line {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 0;
    padding: 0 0.5rem;
    position: relative;
    transition: background-color 180ms ease;
  }

  .code-line:hover {
    background: rgba(110, 231, 183, 0.04);
  }

  .ln {
    color: rgba(110, 231, 183, 0.32);
    text-align: right;
    padding-right: 0.85rem;
    border-right: 1px solid rgba(110, 231, 183, 0.08);
    font-size: 0.74rem;
    user-select: none;
  }

  .lc {
    padding-left: 1rem;
    color: var(--slate-300);
  }

  .code-line-cursor .lc {
    display: flex;
    align-items: center;
  }

  .caret {
    display: inline-block;
    width: 8px;
    height: 1em;
    background: var(--emerald-400);
    animation: caret-blink 1.05s steps(1) infinite;
  }

  @keyframes caret-blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  /* token coloring (custom syntax theme) */
  .tk-kw    { color: rgb(167 139 250); font-weight: 500; }       /* violet */
  .tk-ty    { color: var(--amber-300); }                          /* yellow */
  .tk-str   { color: var(--emerald-300); }                        /* green */
  .tk-cmt   { color: rgba(148, 163, 184, 0.7); font-style: italic; }
  .tk-fn    { color: var(--sky-300); }                            /* blue */
  .tk-attr  { color: rgb(248 113 113); font-weight: 500; }        /* red */
  .tk-punct { color: rgba(187, 247, 208, 0.55); }
  .tk-ident { color: var(--slate-100); }
  .tk-num   { color: var(--amber-300); }
  .tk-space { color: transparent; }
  .tk-hash  { color: rgb(248 113 113); }

  /* ─── meta pane ─── */
  .meta-pane {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    padding: 1.1rem 1.2rem 1.4rem;
    background: rgba(22, 30, 52, 0.4);
  }

  .meta-section {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .meta-eyebrow {
    color: rgba(110, 231, 183, 0.55);
    font-family: var(--mono);
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .meta-title {
    margin: 0;
    color: var(--slate-100);
    font-family: var(--display);
    font-size: 1.45rem;
    font-style: italic;
    font-weight: 400;
    font-variation-settings: 'opsz' 144, 'WONK' 1;
    letter-spacing: -0.012em;
    line-height: 1.15;
  }

  .meta-title a {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(transparent 88%, var(--lang-hue) 0);
    background-size: 0% 100%;
    background-repeat: no-repeat;
    transition: background-size 360ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .meta-title a:hover { background-size: 100% 100%; }

  .meta-lede {
    margin: 0.25rem 0 0;
    color: rgba(187, 247, 208, 0.78);
    font-family: var(--mono);
    font-size: 0.78rem;
    line-height: 1.55;
  }

  .meta-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.4rem;
  }

  .stat-cell {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 0.55rem 0.65rem;
    border: 1px solid rgba(110, 231, 183, 0.12);
    border-radius: 6px;
    background: rgba(13, 22, 42, 0.5);
  }

  .stat-num {
    color: var(--lang-hue);
    font-family: var(--mono);
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1;
  }

  .stat-key {
    margin-top: 0.25rem;
    color: rgba(110, 231, 183, 0.55);
    font-family: var(--mono);
    font-size: 0.58rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .meta-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.32rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tech-pill {
    padding: 0.16rem 0.55rem;
    border: 1px solid rgba(110, 231, 183, 0.22);
    border-radius: 4px;
    background: rgba(110, 231, 183, 0.06);
    color: var(--emerald-100);
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.04em;
  }

  .meta-highlights {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .meta-highlights li {
    display: grid;
    grid-template-columns: 1.6rem 1fr;
    align-items: baseline;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.74rem;
    line-height: 1.5;
    color: var(--emerald-100);
  }

  .hl-num {
    color: rgba(110, 231, 183, 0.4);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-align: right;
  }

  .meta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .action {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 0.85rem;
    border-radius: 6px;
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: transform 220ms ease, background-color 220ms ease, border-color 220ms ease;
  }

  .action.primary {
    background: linear-gradient(135deg, var(--emerald-400), var(--emerald-500));
    color: var(--navy-900);
    box-shadow: 0 6px 18px rgba(52, 211, 153, 0.32);
  }

  .action.primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(52, 211, 153, 0.48);
  }

  .action.ghost {
    background: transparent;
    border: 1px solid rgba(110, 231, 183, 0.32);
    color: var(--emerald-100);
  }

  .action.ghost:hover {
    border-color: var(--emerald-400);
    background: rgba(110, 231, 183, 0.08);
    transform: translateY(-2px);
  }

  .action-shortcut {
    margin-left: 0.25rem;
    opacity: 0.6;
    font-size: 0.85em;
  }

  /* ─── status bar ─── */
  .statusbar {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.4rem 0.95rem;
    background: var(--lang-hue);
    color: var(--navy-950);
    font-family: var(--mono);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .sb-cell {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    white-space: nowrap;
  }

  .sb-glyph {
    font-size: 0.78rem;
  }

  .sb-spacer { flex: 1; }

  .sb-status .sb-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(13, 22, 42, 0.4);
  }

  .sb-status.is-active .sb-dot {
    background: var(--navy-950);
    box-shadow: 0 0 0 0 rgba(13, 22, 42, 0.6);
    animation: sb-pulse 2.4s ease-out infinite;
  }

  @keyframes sb-pulse {
    0% { box-shadow: 0 0 0 0 rgba(13, 22, 42, 0.6); }
    70% { box-shadow: 0 0 0 6px rgba(13, 22, 42, 0); }
    100% { box-shadow: 0 0 0 0 rgba(13, 22, 42, 0); }
  }

  .sb-link { letter-spacing: 0.06em; }

  /* ═══════════════════════  WORKSPACE (manifests)  ═══════════════════════ */
  .workspace {
    margin: 4rem auto 0;
  }

  .workspace-head {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 2rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px dashed rgba(187, 247, 208, 0.16);
  }

  .ws-glyph {
    color: var(--emerald-400);
    font-family: var(--mono);
    font-size: 1.2rem;
  }

  .ws-title {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .ws-title h3 {
    margin: 0;
    color: var(--slate-100);
    font-family: var(--mono);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .ws-title p {
    margin: 0.15rem 0 0;
    color: rgba(110, 231, 183, 0.6);
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .ws-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(187, 247, 208, 0.18), transparent);
  }

  .ws-link {
    color: var(--emerald-400);
    font-family: var(--mono);
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 200ms ease, transform 200ms ease;
  }

  .ws-link:hover {
    color: var(--emerald-300);
    transform: translateX(3px);
  }

  /* manifest grid */
  .manifest-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.2rem;
  }

  .manifest {
    position: relative;
  }

  .manifest.revealed {
    animation: rise 360ms ease both;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .manifest-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    height: 100%;
    padding: 1rem 1.05rem 1rem 1.25rem;
    border: 1px solid rgba(187, 247, 208, 0.12);
    border-radius: 10px;
    background:
      linear-gradient(180deg, rgba(34, 46, 78, 0.65), rgba(22, 30, 52, 0.55));
    backdrop-filter: blur(8px);
    transition:
      transform 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 240ms ease,
      box-shadow 260ms ease;
    overflow: hidden;
  }

  .manifest-card::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 50%;
    height: 100%;
    background: radial-gradient(circle at top right, var(--lang-hue-soft), transparent 70%);
    opacity: 0;
    transition: opacity 320ms ease;
    pointer-events: none;
  }

  .manifest:hover .manifest-card {
    transform: translateY(-4px);
    border-color: var(--lang-hue);
    box-shadow: 0 18px 44px rgba(4, 12, 32, 0.5);
  }

  .manifest:hover .manifest-card::before {
    opacity: 0.55;
  }

  .manifest-rail {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: linear-gradient(
      180deg,
      var(--lang-hue) 0%,
      var(--lang-hue) 35%,
      transparent 100%
    );
  }

  .manifest-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px dashed rgba(187, 247, 208, 0.12);
  }

  .manifest-num {
    color: rgba(110, 231, 183, 0.45);
    font-family: var(--mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
  }

  .manifest-glyph {
    color: var(--lang-hue);
    font-size: 0.95rem;
  }

  .manifest-lang {
    color: var(--slate-100);
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 600;
  }

  .manifest-spacer { flex: 1; }

  .manifest-version {
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    background: rgba(110, 231, 183, 0.08);
    border: 1px solid rgba(110, 231, 183, 0.22);
    color: var(--emerald-300);
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.04em;
  }

  /* sections inside the manifest body */
  .manifest-section {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .ms-key {
    color: rgb(248 113 113);
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .ms-rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    font-family: var(--mono);
    font-size: 0.72rem;
  }

  .ms-rows li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.45rem;
  }

  .ms-prop {
    color: var(--sky-300);
    min-width: 4.5rem;
  }

  .ms-eq {
    color: rgba(187, 247, 208, 0.45);
  }

  .ms-val {
    color: var(--emerald-300);
  }

  .ms-arr {
    color: var(--amber-300);
  }

  .ms-link {
    text-decoration: none;
    transition: color 220ms ease;
  }

  .ms-link:hover {
    color: var(--emerald-100);
  }

  .manifest-desc .repo-description {
    margin: 0;
    color: rgba(187, 247, 208, 0.78);
    font-family: var(--mono);
    font-size: 0.74rem;
    line-height: 1.55;
    padding-left: 0.85rem;
    border-left: 2px solid rgba(110, 231, 183, 0.22);
  }

  .repo-languages {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.45rem;
    font-family: var(--mono);
    font-size: 0.7rem;
  }

  .repo-languages li {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.12rem 0.5rem;
    border: 1px dashed rgba(110, 231, 183, 0.22);
    border-radius: 4px;
    background: rgba(110, 231, 183, 0.04);
    color: var(--emerald-100);
  }

  .dep-plus {
    color: var(--lang-hue);
    font-weight: 700;
  }

  /* manifest footer */
  .manifest-foot {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.55rem 0.85rem;
    margin-top: auto;
    padding-top: 0.7rem;
    border-top: 1px dashed rgba(187, 247, 208, 0.12);
    font-family: var(--mono);
    font-size: 0.7rem;
  }

  .foot-stats {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .foot-stat {
    color: rgba(187, 247, 208, 0.6);
  }

  .foot-spacer { flex: 1; }

  .foot-links {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }

  .foot-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--emerald-100);
    text-decoration: none;
    transition: color 200ms ease, transform 200ms ease;
  }

  .foot-links a:hover {
    color: var(--emerald-400);
    transform: translateY(-1px);
  }

  .foot-label {
    letter-spacing: 0.06em;
  }

  .active-dot {
    color: var(--emerald-400);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
  }

  /* show-more */
  .workspace-footer {
    display: flex;
    justify-content: center;
    margin-top: 2.2rem;
  }

  .show-more {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    border: 1px solid rgba(110, 231, 183, 0.32);
    border-radius: 999px;
    background: rgba(28, 38, 70, 0.5);
    padding: 0.7rem 1.4rem;
    color: var(--emerald-400);
    cursor: pointer;
    font-family: var(--mono);
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    transition: color 180ms ease, transform 180ms ease, background-color 220ms ease, border-color 220ms ease;
  }

  .show-more .dash {
    display: inline-block;
    width: 28px;
    height: 1px;
    background: currentColor;
    opacity: 0.5;
  }

  .show-more:hover,
  .show-more:focus-visible {
    color: var(--emerald-300);
    background: rgba(110, 231, 183, 0.08);
    border-color: var(--emerald-400);
    transform: translateY(-1px);
    outline: none;
  }

  .show-more[disabled] {
    opacity: 0.5;
    cursor: wait;
  }

  /* ═══════════════════════  LIGHT MODE  ═══════════════════════ */
  :global(html:not(.dark)) .ide {
    background: linear-gradient(180deg, rgb(248 250 252), rgb(241 245 249));
    border-color: rgb(226 232 240);
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
  }

  /* workspace command header — light mode */
  :global(html:not(.dark)) .ws-header {
    background:
      linear-gradient(180deg, rgb(255 255 255), rgb(248 250 252)),
      repeating-linear-gradient(90deg, transparent 0 18px, rgba(15, 23, 42, 0.04) 18px 19px);
    border-bottom-color: rgb(226 232 240);
  }
  :global(html:not(.dark)) .ws-glyph { color: rgb(5 150 105); }
  :global(html:not(.dark)) .ws-cmd-bin { color: rgb(15 23 42); }
  :global(html:not(.dark)) .ws-cmd-sub { color: rgb(124 58 237); }
  :global(html:not(.dark)) .ws-cmd-flag { color: rgb(180 83 9); }
  :global(html:not(.dark)) .ws-caret { background: rgb(5 150 105); }
  :global(html:not(.dark)) .ws-stat-key { color: rgb(5 150 105); }
  :global(html:not(.dark)) .ws-stat-val { color: rgb(15 23 42); }
