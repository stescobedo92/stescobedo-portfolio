---
import Section from './Section.astro';
import Icon from './Icon.astro';
import { projects, profile } from '../../data/portfolio';

const rawBase = import.meta.env.BASE_URL || '/';
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, '')}`;

const featured = projects.filter((project) => project.featured);
const otherProjects = projects.filter((project) => !project.featured);
const pad2 = (n: number) => String(n).padStart(2, '0');
const padN = (n: number, w: number) => String(n).padStart(w, ' ');

// ─────────────────────────  LANGUAGE METADATA  ─────────────────────────
type LangKey = 'rust' | 'cpp' | 'go' | 'csharp' | 'typescript' | 'python' | 'generic';

type LangMeta = {
  key: LangKey;
  label: string;
  ext: string;
  glyph: string;          // emoji-ish file icon
  hue: string;            // accent color (CSS)
  hueSoft: string;        // tinted background
  comment: string;        // // or # etc.
  docComment: string;     // /// or //! or # etc.
};

const LANGS: Record<LangKey, LangMeta> = {
  rust:       { key: 'rust',       label: 'Rust',       ext: 'rs',   glyph: '◆', hue: '247 154 65',   hueSoft: '247 154 65',   comment: '//', docComment: '//!' },
  cpp:        { key: 'cpp',        label: 'C++',        ext: 'cpp',  glyph: '▣', hue: '116 199 236',  hueSoft: '116 199 236',  comment: '//', docComment: '///' },
  go:         { key: 'go',         label: 'Go',         ext: 'go',   glyph: '◎', hue: '125 211 252',  hueSoft: '125 211 252',  comment: '//', docComment: '//' },
  csharp:     { key: 'csharp',     label: 'C#',         ext: 'cs',   glyph: '◈', hue: '167 139 250',  hueSoft: '167 139 250',  comment: '//', docComment: '///' },
  typescript: { key: 'typescript', label: 'TypeScript', ext: 'ts',   glyph: '◇', hue: '96 165 250',   hueSoft: '96 165 250',   comment: '//', docComment: '/**' },
  python:     { key: 'python',     label: 'Python',     ext: 'py',   glyph: '○', hue: '252 211 77',   hueSoft: '252 211 77',   comment: '#',  docComment: '"""' },
  generic:    { key: 'generic',    label: 'Code',       ext: 'src',  glyph: '◌', hue: '110 231 183',  hueSoft: '110 231 183',  comment: '//', docComment: '//' },
};

const detectLang = (tech: string[]): LangMeta => {
  const norm = tech.map((t) => t.toLowerCase());
  if (norm.some((t) => t === 'rust')) return LANGS.rust;
  if (norm.some((t) => t === 'c++' || t === 'cpp')) return LANGS.cpp;
  if (norm.some((t) => t === 'go' || t === 'golang')) return LANGS.go;
  if (norm.some((t) => t === '.net' || t.includes('c#'))) return LANGS.csharp;
  if (norm.some((t) => t === 'typescript' || t === 'ts')) return LANGS.typescript;
  if (norm.some((t) => t === 'python')) return LANGS.python;
  return LANGS.generic;
};

// File icon path-style slug for the breadcrumb: dotnet-version-manager → dotnet_version_manager
const fileSlug = (name: string) =>
  name
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '_')
    .replace(/^_|_$/g, '');

// Deterministic mock metrics derived from the project name so they stay stable across builds
const hashSeed = (s: string) => {
  let h = 0x811c9dc5;
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 0x01000193) >>> 0;
  }
  return h;
};

const mockMetrics = (project: { name: string; active?: boolean }) => {
  const seed = hashSeed(project.name);
  const stars = (seed % 90) + 12;          // 12 - 101
  const lines = ((seed >>> 8) % 4500) + 320; // 320 - 4819
  const commits = ((seed >>> 16) % 240) + 22; // 22 - 261
  return { stars, lines, commits };
};

const mockVersion = (project: { name: string }) => {
  const seed = hashSeed(project.name);
  const major = (seed >>> 24) % 3;          // 0 - 2
  const minor = (seed >>> 12) & 0x0f;       // 0 - 15
  const patch = seed & 0x1f;                // 0 - 31
  return `${major}.${minor}.${patch}`;
};

// Build a "code preview" as an array of lines, each being an array of tokens.
type Token = { t: 'kw' | 'ty' | 'str' | 'cmt' | 'fn' | 'attr' | 'punct' | 'ident' | 'num' | 'space' | 'hash'; v: string };
type Line = Token[];

const renderRust = (project: typeof projects[number]): Line[] => {
  const slug = fileSlug(project.name);
  const struct = project.name.split(/[\s\-_]+/).map((w) => w[0]?.toUpperCase() + w.slice(1).toLowerCase()).join('');
  const isActive = project.active === true;
  const lines: Line[] = [];

  lines.push([{ t: 'cmt', v: `//! ${project.name}` }]);
  lines.push([{ t: 'cmt', v: `//! ${'='.repeat(Math.min(project.name.length + 4, 48))}` }]);
  lines.push([{ t: 'cmt', v: '//!' }]);
  lines.push([{ t: 'cmt', v: `//! ${project.description}` }]);
  lines.push([]);
  lines.push([{ t: 'kw', v: 'use' }, { t: 'space', v: ' ' }, { t: 'ident', v: 'std' }, { t: 'punct', v: '::' }, { t: 'ident', v: 'process' }, { t: 'punct', v: '::Command' }, { t: 'punct', v: ';' }]);
  lines.push([{ t: 'kw', v: 'use' }, { t: 'space', v: ' ' }, { t: 'ident', v: 'clap' }, { t: 'punct', v: '::' }, { t: 'ident', v: 'Parser' }, { t: 'punct', v: ';' }]);
  lines.push([]);
  lines.push([{ t: 'attr', v: '#[derive(Debug, Project)]' }]);
  lines.push([{ t: 'kw', v: 'pub struct' }, { t: 'space', v: ' ' }, { t: 'ty', v: struct }, { t: 'space', v: ' ' }, { t: 'punct', v: '{' }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'cmt', v: `/// status: ${isActive ? 'active' : 'shipped'}` }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'kw', v: 'pub status' }, { t: 'punct', v: ':' }, { t: 'space', v: ' ' }, { t: 'ty', v: 'Status' }, { t: 'punct', v: ',' }]);
  lines.push([]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'cmt', v: '/// distinguishing capabilities' }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'kw', v: 'pub highlights' }, { t: 'punct', v: ':' }, { t: 'space', v: ' ' }, { t: 'ty', v: `[&'static str; ${project.highlights.length}]` }, { t: 'punct', v: ',' }]);
  lines.push([{ t: 'punct', v: '}' }]);
  lines.push([]);
  lines.push([{ t: 'kw', v: 'impl' }, { t: 'space', v: ' ' }, { t: 'ty', v: struct }, { t: 'space', v: ' ' }, { t: 'punct', v: '{' }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'kw', v: 'pub fn' }, { t: 'space', v: ' ' }, { t: 'fn', v: 'launch' }, { t: 'punct', v: '() -> ' }, { t: 'ty', v: '!' }, { t: 'space', v: ' ' }, { t: 'punct', v: '{' }]);
  lines.push([{ t: 'space', v: '        ' }, { t: 'cmt', v: `// → github.com/${(project.githubRepo ?? slug).replace(/^.*?\//, 'stescobedo92/')}` }]);
  lines.push([{ t: 'space', v: '        ' }, { t: 'ident', v: 'cli' }, { t: 'punct', v: '::' }, { t: 'fn', v: 'run' }, { t: 'punct', v: '(' }, { t: 'str', v: `"${project.tech.join(' + ')}"` }, { t: 'punct', v: ');' }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'punct', v: '}' }]);
  lines.push([{ t: 'punct', v: '}' }]);
  return lines;
};

const renderCpp = (project: typeof projects[number]): Line[] => {
  const struct = project.name.split(/[\s\-_]+/).map((w) => w[0]?.toUpperCase() + w.slice(1).toLowerCase()).join('');
  const lines: Line[] = [];
  lines.push([{ t: 'cmt', v: `// ${project.name} — ${project.tech.join(' / ')}` }]);
  lines.push([{ t: 'cmt', v: '//' }]);
  lines.push([{ t: 'cmt', v: `// ${project.description}` }]);
  lines.push([]);
  lines.push([{ t: 'attr', v: '#include' }, { t: 'space', v: ' ' }, { t: 'str', v: '<iostream>' }]);
  lines.push([{ t: 'attr', v: '#include' }, { t: 'space', v: ' ' }, { t: 'str', v: '"platform/desktop.hpp"' }]);
  lines.push([]);
  lines.push([{ t: 'kw', v: 'namespace' }, { t: 'space', v: ' ' }, { t: 'ident', v: 'stescobedo' }, { t: 'space', v: ' ' }, { t: 'punct', v: '{' }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'kw', v: 'class' }, { t: 'space', v: ' ' }, { t: 'ty', v: struct }, { t: 'space', v: ' ' }, { t: 'punct', v: '{' }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'kw', v: 'public:' }]);
  lines.push([{ t: 'space', v: '        ' }, { t: 'kw', v: 'static void' }, { t: 'space', v: ' ' }, { t: 'fn', v: 'apply' }, { t: 'punct', v: '();' }]);
  project.highlights.forEach((h) => {
    lines.push([{ t: 'space', v: '        ' }, { t: 'cmt', v: `// + ${h}` }]);
  });
  lines.push([{ t: 'space', v: '    ' }, { t: 'punct', v: '};' }]);
  lines.push([{ t: 'punct', v: '}' }]);
  return lines;
};

const renderGo = (project: typeof projects[number]): Line[] => {
  const lines: Line[] = [];
  const pkg = fileSlug(project.name);
  lines.push([{ t: 'cmt', v: `// Package ${pkg}` }]);
  lines.push([{ t: 'cmt', v: `// ${project.description}` }]);
  lines.push([]);
  lines.push([{ t: 'kw', v: 'package' }, { t: 'space', v: ' ' }, { t: 'ident', v: pkg }]);
  lines.push([]);
  lines.push([{ t: 'kw', v: 'import' }, { t: 'space', v: ' ' }, { t: 'punct', v: '(' }]);
  project.tech.forEach((t) => {
    lines.push([{ t: 'space', v: '    ' }, { t: 'str', v: `"${t.toLowerCase()}.io/${pkg}"` }]);
  });
  lines.push([{ t: 'punct', v: ')' }]);
  lines.push([]);
  lines.push([{ t: 'kw', v: 'type' }, { t: 'space', v: ' ' }, { t: 'ty', v: 'Project' }, { t: 'space', v: ' ' }, { t: 'kw', v: 'struct' }, { t: 'space', v: ' ' }, { t: 'punct', v: '{' }]);
  project.highlights.forEach((h, i) => {
    const fld = h.split(/\s+/).slice(0, 2).map((w) => w[0]?.toUpperCase() + w.slice(1).toLowerCase()).join('');
    lines.push([{ t: 'space', v: '    ' }, { t: 'ident', v: fld || `Field${i}` }, { t: 'space', v: ' ' }, { t: 'ty', v: 'string' }, { t: 'space', v: '   ' }, { t: 'cmt', v: `// ${h}` }]);
  });
  lines.push([{ t: 'punct', v: '}' }]);
  return lines;
};

const renderForLang = (project: typeof projects[number], lang: LangMeta): Line[] => {
  if (lang.key === 'rust') return renderRust(project);
  if (lang.key === 'cpp') return renderCpp(project);
  if (lang.key === 'go') return renderGo(project);
  return renderRust(project); // sensible default
};

// 8-bar procedural waveform derived from a project's hash. Stable across
// renders, no assets — feels like a tiny activity sparkline.
const activityBars = (seed: number) =>
  Array.from({ length: 8 }, (_, i) => 28 + ((seed >>> (i * 3)) & 0x3f));

// Pre-compute previews for all featured projects so we can render them once
const featuredViews = featured.map((project, index) => {
  const lang = detectLang(project.tech);
  const lines = renderForLang(project, lang);
  const metrics = mockMetrics(project);
  const version = mockVersion(project);
  const seed = hashSeed(project.name);
  return {
    project,
    lang,
    lines,
    metrics,
    version,
    bars: activityBars(seed),
    tabId: `tab-${index}`,
    panelId: `panel-${index}`,
    isActive: index === 0,
    fileName: `${fileSlug(project.name)}.${lang.ext}`,
  };
});

// Workspace summary stats for the command header (live mock totals).
const wsStats = {
  crates: featuredViews.length,
  langs: new Set(featuredViews.map((v) => v.lang.key)).size,
  loc: featuredViews.reduce((acc, v) => acc + v.metrics.lines, 0),
};
const formatLoc = (n: number) =>
  n >= 1000 ? `${(n / 1000).toFixed(1)}k` : String(n);

// For other projects, mock metrics + cargo-style sections
const otherViews = otherProjects.map((project, index) => {
  const lang = detectLang(project.tech);
  const metrics = mockMetrics(project);
  const version = mockVersion(project);
  return { project, lang, metrics, version, num: index + 1 };
});
---

<Section title="Selected Work" id="projects">
  <!-- ────────  WORKSPACE DECK (featured)  ──────── -->
  <div class="ide" role="region" aria-label="Featured projects, displayed as a workspace deck">
    <!-- Command header — replaces the traffic-light chrome -->
    <header class="ws-header" aria-hidden="true">
      <div class="ws-prompt">
        <span class="ws-glyph">⌗</span>
        <span class="ws-cmd">
          <span class="ws-cmd-bin">cargo</span>
          <span class="ws-cmd-sub">workspace</span>
          <span class="ws-cmd-flag">--select</span>
        </span>
        <span class="ws-caret"></span>
      </div>

      <div class="ws-stats">
        <span class="ws-stat">
          <span class="ws-stat-key">crates</span>
          <span class="ws-stat-val">{wsStats.crates}</span>
        </span>
        <span class="ws-stat-sep" aria-hidden="true"></span>
        <span class="ws-stat">
          <span class="ws-stat-key">langs</span>
          <span class="ws-stat-val">{wsStats.langs}</span>
        </span>
        <span class="ws-stat-sep" aria-hidden="true"></span>
        <span class="ws-stat">
          <span class="ws-stat-key">loc</span>
          <span class="ws-stat-val">{formatLoc(wsStats.loc)}</span>
        </span>
      </div>
    </header>

    <!-- Project deck (radios drive :checked + the panels below) -->
    <div class="deck" role="tablist" aria-label="Project files">
      {featuredViews.map((view, index) => (
        <input
          type="radio"
          name="ide-tab"
          id={view.tabId}
          class="tab-radio"
          checked={view.isActive}
          aria-controls={view.panelId}
        />
      ))}

      <div class="deck-row">
        {featuredViews.map((view, index) => (
          <label
            for={view.tabId}
            class="deck-card"
            data-tab-index={index}
            role="tab"
            tabindex="0"
            style={`--lang-hue: rgb(${view.lang.hue}); --lang-hue-soft: rgba(${view.lang.hueSoft} / 0.18);`}
          >
            <span class="card-accent" aria-hidden="true"></span>
            <span class="card-shine" aria-hidden="true"></span>

            <div class="card-row card-row-top">
              <span class="card-lang">
                <span class="card-glyph" aria-hidden="true">{view.lang.glyph}</span>
                <span class="card-lang-name">{view.lang.label}</span>
              </span>
              <span class={`card-status ${view.project.active ? 'is-active' : ''}`}>
                <span class="card-status-dot" aria-hidden="true"></span>
                <span class="card-status-text">{view.project.active ? 'active' : 'shipped'}</span>
              </span>
            </div>

            <h3 class="card-name">{view.project.name}</h3>

            <div class="card-row card-row-mid">
              <span class="card-version" aria-label="Version">
                <span class="version-glyph" aria-hidden="true">v</span>
                {view.version}
              </span>
              <span class="card-bars" aria-hidden="true">
                {view.bars.map((h) => (
                  <span class="card-bar" style={`--h: ${h}%`}></span>
                ))}
              </span>
            </div>

            <div class="card-row card-row-bot">
              <span class="card-stars" aria-label="Stars">
                <span class="star-glyph" aria-hidden="true">★</span>
                {view.metrics.stars}
              </span>
              <span class="card-now" aria-hidden="true">
                <span class="now-dot"></span>
                <span>now showing</span>
              </span>
              <span class="card-jump" aria-hidden="true">↳</span>
            </div>
          </label>
        ))}
      </div>
    </div>

    <!-- Editor body — only the active panel is shown via :checked -->
    <div class="ide-body">
      {featuredViews.map((view, index) => (
        <section
          id={view.panelId}
          class="panel"
          role="tabpanel"
          aria-labelledby={view.tabId}
          data-panel-index={index}
          style={`--lang-hue: rgb(${view.lang.hue}); --lang-hue-soft: rgba(${view.lang.hueSoft} / 0.12);`}
        >
          <!-- Breadcrumb -->
          <nav class="breadcrumb" aria-label="File path">
            <span class="bc-glyph" aria-hidden="true">⌘</span>
            <span class="bc-seg">~</span>
            <span class="bc-sep" aria-hidden="true">›</span>
            <span class="bc-seg">workspace</span>
            <span class="bc-sep" aria-hidden="true">›</span>
            <span class="bc-seg">selected-work</span>
            <span class="bc-sep" aria-hidden="true">›</span>
            <span class="bc-seg active"><span class="bc-icon">{view.lang.glyph}</span> {view.fileName}</span>
            <span class="bc-spacer"></span>
            <span class="bc-action" aria-hidden="true">⌃ ⌘ → next</span>
          </nav>

          <!-- Editor split: code | sidebar -->
          <div class="editor-split">
            <!-- Code preview -->
            <div class="code-pane">
              <pre class="code-block" aria-label={`${view.project.name} source preview`}>
                {view.lines.map((tokens, lineIdx) => (
                  <div class="code-line">
                    <span class="ln" aria-hidden="true">{padN(lineIdx + 1, 2)}</span>
                    <span class="lc">
                      {tokens.map((token) => (
                        <span class={`tk tk-${token.t}`}>{token.v}</span>
                      ))}
                    </span>
                  </div>
                ))}
                <div class="code-line code-line-cursor">
                  <span class="ln" aria-hidden="true">{padN(view.lines.length + 1, 2)}</span>
                  <span class="lc"><span class="caret" aria-hidden="true"></span></span>
                </div>
              </pre>
            </div>

            <!-- Sidebar -->
            <aside class="meta-pane" aria-label={`${view.project.name} metadata`}>
              <div class="meta-section">
                <h3 class="meta-title">
                  <a href={view.project.github} target="_blank" rel="noopener noreferrer">{view.project.name}</a>
                </h3>
                <p class="meta-lede">{view.project.description}</p>
              </div>

              <div class="meta-section">
                <span class="meta-eyebrow">stats</span>
                <div class="meta-stats">
                  <div class="stat-cell">
                    <span class="stat-num">{view.metrics.stars}</span>
                    <span class="stat-key">stars</span>
                  </div>
                  <div class="stat-cell">
                    <span class="stat-num">{view.metrics.commits}</span>
                    <span class="stat-key">commits</span>
                  </div>
                  <div class="stat-cell">
                    <span class="stat-num">{view.metrics.lines.toLocaleString()}</span>
                    <span class="stat-key">loc</span>
                  </div>
                </div>
              </div>

              <div class="meta-section">
                <span class="meta-eyebrow">stack</span>
                <ul class="meta-tech">
                  {view.project.tech.map((tech) => (
                    <li class="tech-pill">{tech}</li>
                  ))}
                </ul>
              </div>

              <div class="meta-section">
                <span class="meta-eyebrow">highlights</span>
                <ul class="meta-highlights">
                  {view.project.highlights.map((h, i) => (
                    <li>
                      <span class="hl-num">{pad2(i + 1)}</span>
                      <span class="hl-text">{h}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="meta-actions">
                <a class="action primary" href={view.project.github} target="_blank" rel="noopener noreferrer">
                  <Icon name="github" class="h-4 w-4" />
                  <span>Source</span>
                  <span class="action-shortcut" aria-hidden="true">↗</span>
                </a>
                {view.project.demo && (
                  <a class="action ghost" href={view.project.demo} target="_blank" rel="noopener noreferrer">
                    <Icon name="external" class="h-4 w-4" />
                    <span>Live</span>
                  </a>
                )}
              </div>
            </aside>
          </div>

          <!-- Status bar -->
          <div class="statusbar" aria-hidden="true">
            <span class="sb-cell sb-branch">
              <span class="sb-glyph">⎇</span>
              <span>main</span>
            </span>
            <span class="sb-cell">{view.lang.label}</span>
            <span class="sb-cell">UTF-8</span>
            <span class="sb-cell">LF</span>
            <span class="sb-cell">spaces: 4</span>
            <span class="sb-spacer"></span>
            <span class="sb-cell">v{view.version}</span>
            <span class={`sb-cell sb-status ${view.project.active ? 'is-active' : ''}`}>
              <span class="sb-dot"></span>
              <span>{view.project.active ? 'active' : 'shipped'}</span>
            </span>
            <span class="sb-cell sb-link">Ln {view.lines.length}, Col 1</span>
          </div>
        </section>
      ))}
    </div>
  </div>

  <!-- ────────  WORKSPACE (other projects as Cargo manifests)  ──────── -->
  <div class="workspace" data-github-user={profile.githubUsername}>
    <header class="workspace-head">
      <span class="ws-glyph" aria-hidden="true">⌗</span>
      <div class="ws-title">
        <h3>workspace.toml</h3>
        <p>more crates from the same author</p>
      </div>
      <span class="ws-rule" aria-hidden="true"></span>
      <a class="ws-link" href={withBase('blog')}>view archive →</a>
    </header>

    <ul class="manifest-grid" id="project-grid">
      {otherViews.map((view) => (
        <li
          class="manifest"
          data-github-repo={view.project.githubRepo}
          data-repo-name={view.project.githubRepo?.split('/')[1] ?? view.project.name}
          style={`--lang-hue: rgb(${view.lang.hue}); --lang-hue-soft: rgba(${view.lang.hueSoft} / 0.18);`}
        >
          <article class="manifest-card">
            <span class="manifest-rail" aria-hidden="true"></span>

            <header class="manifest-head">
              <span class="manifest-num">{pad2(view.num)}</span>
              <span class="manifest-glyph" aria-hidden="true">{view.lang.glyph}</span>
              <span class="manifest-lang">{view.lang.label}</span>
              <span class="manifest-spacer"></span>
              <span class="manifest-version">v{view.version}</span>
            </header>

            <div class="manifest-section">
              <span class="ms-key">[package]</span>
              <ul class="ms-rows">
                <li>
                  <span class="ms-prop">name</span>
                  <span class="ms-eq">=</span>
                  <a class="ms-val ms-link" href={view.project.github} target="_blank" rel="noopener noreferrer">
                    "{view.project.name}"
                  </a>
                </li>
                <li>
                  <span class="ms-prop">authors</span>
                  <span class="ms-eq">=</span>
                  <span class="ms-val ms-arr">["stescobedo92"]</span>
                </li>
                <li>
                  <span class="ms-prop">license</span>
                  <span class="ms-eq">=</span>
                  <span class="ms-val">"MIT"</span>
                </li>
              </ul>
            </div>

            <div class="manifest-section manifest-desc">
              <span class="ms-key">[description]</span>
              <p class="repo-description">{view.project.description}</p>
            </div>

            <div class="manifest-section">
              <span class="ms-key">[dependencies]</span>
              <ul class="repo-languages" aria-label={`${view.project.name} technologies`}>
                {view.project.tech.slice(0, 6).map((tech) => (
                  <li><span class="dep-plus" aria-hidden="true">+</span> {tech}</li>
                ))}
              </ul>
            </div>

            <footer class="manifest-foot">
              <span class="foot-stats">
                <span class="foot-stat">★ {view.metrics.stars}</span>
                <span class="foot-stat">⎇ {view.metrics.commits}</span>
              </span>
              <span class="foot-spacer"></span>
              <div class="foot-links card-links">
                <a class="repo-title" href={view.project.github} target="_blank" rel="noopener noreferrer" aria-label={`${view.project.name} on GitHub`}>
                  <Icon name="github" class="h-4 w-4" />
                  <span class="foot-label">source</span>
                </a>
                {view.project.demo && (
                  <a href={view.project.demo} target="_blank" rel="noopener noreferrer" aria-label={`${view.project.name} demo`}>
                    <Icon name="external" class="h-4 w-4" />
                    <span class="foot-label">live</span>
                  </a>
                )}
                {view.project.active && <span class="active-dot">● active</span>}
              </div>
            </footer>

            <span class="card-num" hidden></span>
          </article>
        </li>
      ))}
    </ul>

    <div class="workspace-footer">
      <button id="toggle-projects" class="show-more" type="button" aria-expanded="false">
        <span class="dash" aria-hidden="true"></span>
        <span>cargo search --remote</span>
        <span class="dash" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</Section>

<script>
  type GitHubRepo = {
    name: string;
    full_name: string;
    description: string | null;
    html_url: string;
    homepage: string | null;
    fork: boolean;
    archived: boolean;
    private: boolean;
    languages_url: string;
    pushed_at: string;
    owner: { login: string };
  };

  const PAGE_SIZE = 3;
  const repoCache = new Map<string, GitHubRepo[]>();

  const fetchOwnedRepos = async (user: string): Promise<GitHubRepo[]> => {
    const cached = repoCache.get(user);
    if (cached) return cached;
    try {
      const response = await fetch(
        `https://api.github.com/users/${encodeURIComponent(user)}/repos?per_page=100&sort=pushed&type=owner`,
        { headers: { Accept: 'application/vnd.github+json' } },
      );
      if (!response.ok) return [];
      const data = (await response.json()) as GitHubRepo[];
      const owned = data.filter(
        (repo) =>
          !repo.fork &&
          !repo.private &&
          repo.owner?.login?.toLowerCase() === user.toLowerCase(),
      );
      repoCache.set(user, owned);
      return owned;
    } catch {
      return [];
    }
  };

  const fetchLanguages = async (url: string): Promise<string[]> => {
    try {
      const response = await fetch(url, {
        headers: { Accept: 'application/vnd.github+json' },
      });
      if (!response.ok) return [];
      const data = (await response.json()) as Record<string, number>;
      return Object.entries(data)
        .sort(([, a], [, b]) => b - a)
        .slice(0, 6)
        .map(([language]) => language);
    } catch {
      return [];
    }
  };

  const safeUrl = (value: string | null | undefined): string | null => {
    if (!value) return null;
    return /^https?:\/\//i.test(value) ? value : null;
  };

  const findScopeAttribute = (element: Element): string | null => {
    for (const attr of Array.from(element.attributes)) {
      if (attr.name.startsWith('data-astro-cid')) return attr.name;
    }
    return null;
  };

  const buildManifestCard = (
    template: HTMLLIElement,
    repo: GitHubRepo,
    index: number,
  ): HTMLLIElement => {
    const li = template.cloneNode(true) as HTMLLIElement;
    li.className = 'manifest revealed';
    li.dataset.githubRepo = repo.full_name;
    li.dataset.repoName = repo.name;

    const repoUrl = safeUrl(repo.html_url) ?? `https://github.com/${repo.full_name}`;

    const numEl = li.querySelector('.manifest-num');
    if (numEl) numEl.textContent = String(index + 1).padStart(2, '0');

    const versionEl = li.querySelector('.manifest-version');
    if (versionEl) versionEl.textContent = 'v0.1.0';

    const nameLink = li.querySelector<HTMLAnchorElement>('.ms-link');
    if (nameLink) {
      nameLink.href = repoUrl;
      nameLink.textContent = `"${repo.name}"`;
    }

    const description = li.querySelector<HTMLElement>('.repo-description');
    if (description) {
      description.textContent = repo.description ?? 'A repository on GitHub.';
    }

    const deps = li.querySelector<HTMLElement>('.repo-languages');
    if (deps) {
      deps.replaceChildren();
      deps.setAttribute('aria-label', `${repo.name} technologies`);
    }

    const sourceLink = li.querySelector<HTMLAnchorElement>('.foot-links .repo-title');
    if (sourceLink) sourceLink.href = repoUrl;

    const demoLink = li.querySelectorAll<HTMLAnchorElement>('.foot-links a')[1];
    if (demoLink) demoLink.remove();

    li.querySelector('.active-dot')?.remove();

    return li;
  };

  const populateLanguages = async (card: HTMLElement, repo: GitHubRepo) => {
    const target = card.querySelector<HTMLElement>('.repo-languages');
    if (!target) return;
    const languages = await fetchLanguages(repo.languages_url);
    if (languages.length === 0) return;
    const scope = findScopeAttribute(target);
    target.replaceChildren(
      ...languages.map((language) => {
        const li = document.createElement('li');
        if (scope) li.setAttribute(scope, '');
        const plus = document.createElement('span');
        plus.className = 'dep-plus';
        plus.setAttribute('aria-hidden', 'true');
        plus.textContent = '+';
        if (scope) plus.setAttribute(scope, '');
        li.append(plus, ' ', language);
        return li;
      }),
    );
  };

  const initializeProjects = () => {
    // ── Deck-card keyboard nav (arrow keys when focused) ──
    const cards = Array.from(document.querySelectorAll<HTMLLabelElement>('.deck .deck-card'));
    cards.forEach((card) => {
      if ((card as any).dataset.bound === 'true') return;
      (card as any).dataset.bound = 'true';
      card.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;
        event.preventDefault();
        const idx = cards.indexOf(card);
        const next = (idx + (event.key === 'ArrowRight' ? 1 : -1) + cards.length) % cards.length;
        const radio = document.getElementById(cards[next].getAttribute('for') ?? '') as HTMLInputElement | null;
        if (radio) {
          radio.checked = true;
          cards[next].focus();
        }
      });
    });

    // Global keyboard shortcut: ⌘/Ctrl + → / ← anywhere inside the IDE region
    if (!(document as any).__projectsTabHotkeysBound) {
      (document as any).__projectsTabHotkeysBound = true;
      document.addEventListener('keydown', (event) => {
        if (!event.metaKey && !event.ctrlKey) return;
        if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;
        const radios = Array.from(document.querySelectorAll<HTMLInputElement>('.deck .tab-radio'));
        if (radios.length === 0) return;
        const activeIdx = radios.findIndex((r) => r.checked);
        if (activeIdx === -1) return;
        const target = (event.target as HTMLElement | null);
        if (target && target.closest('.ide')) {
          event.preventDefault();
          const next = (activeIdx + (event.key === 'ArrowRight' ? 1 : -1) + radios.length) % radios.length;
          radios[next].checked = true;
        }
      });
    }

    // ── Show more (cargo search --remote) ──
    const section = document.querySelector<HTMLElement>('.workspace');
    const button = document.getElementById('toggle-projects') as HTMLButtonElement | null;
    const grid = document.getElementById('project-grid');
    if (!section || !button || !grid || button.dataset.ready === 'true') return;
    button.dataset.ready = 'true';

    const user = section.dataset.githubUser;
    const template = grid.querySelector<HTMLLIElement>('.manifest');
    if (!user || !template) {
      button.hidden = true;
      return;
    }

    const collectShownNames = () => {
      const names = new Set<string>();
      grid.querySelectorAll<HTMLElement>('.manifest').forEach((card) => {
        const explicit = card.dataset.repoName?.trim().toLowerCase();
        if (explicit) names.add(explicit);
      });
      return names;
    };

    button.addEventListener('click', async () => {
      button.disabled = true;
      const label = button.querySelector('span:not(.dash)');
      const previousLabel = label?.textContent ?? 'cargo search --remote';
      if (label) label.textContent = 'fetching…';

      const repos = await fetchOwnedRepos(user);
      const shown = collectShownNames();
      const remaining = repos.filter((repo) => !shown.has(repo.name.toLowerCase()));
      const next = remaining.slice(0, PAGE_SIZE);
      const baseIndex = grid.querySelectorAll('.manifest').length;

      next.forEach((repo, index) => {
        const card = buildManifestCard(template, repo, baseIndex + index);
        grid.appendChild(card);
        window.setTimeout(() => {
          void populateLanguages(card, repo);
        }, index * 60);
      });

      button.setAttribute('aria-expanded', 'true');
      if (label) label.textContent = previousLabel;
      button.disabled = false;

      if (remaining.length <= PAGE_SIZE || next.length === 0) {
        button.hidden = true;
      }
    });
  };

  document.addEventListener('astro:page-load', initializeProjects);
  initializeProjects();
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,300..900,0..100,0..1&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&display=swap');

  :where(.ide, .workspace) {
    --mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    --display: 'Fraunces', Georgia, serif;
    --emerald-100: rgb(187 247 208);
    --emerald-300: rgb(167 243 208);
    --emerald-400: rgb(110 231 183);
    --emerald-500: rgb(52 211 153);
    --emerald-600: rgb(16 185 129);
    --navy-950: rgb(13 22 42);
    --navy-900: rgb(22 30 52);
    --navy-800: rgb(28 38 70);
    --navy-700: rgb(34 46 78);
    --slate-100: rgb(248 250 252);
    --slate-300: rgb(203 213 225);
    --slate-500: rgb(100 116 139);
    --amber-300: rgb(252 211 77);
    --rose-300: rgb(252 165 165);
    --violet-300: rgb(196 181 253);
    --sky-300: rgb(125 211 252);
  }

  /* ═══════════════════════  IDE WINDOW  ═══════════════════════ */
  .ide {
    position: relative;
    margin: -1rem 0 4rem;
    border: 1px solid rgba(187, 247, 208, 0.16);
    border-radius: 14px;
    background:
      linear-gradient(180deg, rgba(34, 46, 78, 0.6), rgba(22, 30, 52, 0.78));
    backdrop-filter: blur(14px);
    box-shadow: 0 30px 80px rgba(4, 12, 32, 0.5);
    overflow: hidden;
  }

  /* glow accent that picks up active tab's language hue */
  .ide::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--emerald-400),
      transparent
    );
    opacity: 0.6;
  }

  /* ─── window chrome ─── */
  /* ─── Workspace command header (replaces window chrome) ─── */
  .ws-header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.85rem 1.5rem;
    padding: 0.9rem 1.1rem;
    background:
      linear-gradient(180deg, rgba(13, 22, 42, 0.85), rgba(22, 30, 52, 0.6)),
      repeating-linear-gradient(90deg, transparent 0 18px, rgba(110, 231, 183, 0.04) 18px 19px);
    border-bottom: 1px solid rgba(110, 231, 183, 0.16);
    font-family: var(--mono);
    font-size: 0.78rem;
  }

  .ws-prompt {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
  }

  .ws-glyph {
    color: var(--emerald-400);
    font-size: 1rem;
  }

  .ws-cmd {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
  }

  .ws-cmd-bin { color: var(--slate-100); font-weight: 600; }
  .ws-cmd-sub { color: var(--violet-300); }
  .ws-cmd-flag { color: var(--amber-300); }

  .ws-caret {
    display: inline-block;
    width: 8px;
    height: 1.05em;
    background: var(--emerald-400);
    margin-left: 0.3rem;
    animation: ws-caret-blink 1.05s steps(1) infinite;
    vertical-align: -3px;
  }

  @keyframes ws-caret-blink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  .ws-stats {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    font-size: 0.7rem;
  }

  .ws-stat {
    display: inline-flex;
    align-items: baseline;
    gap: 0.32rem;
  }

  .ws-stat-key {
    color: rgba(110, 231, 183, 0.6);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 0.58rem;
  }

  .ws-stat-val {
    color: var(--slate-100);
    font-weight: 700;
  }

  .ws-stat-sep {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(187, 247, 208, 0.28);
  }

  /* ─── Project deck (cards) ─── */
  .deck {
    position: relative;
    background:
      linear-gradient(180deg, rgba(22, 30, 52, 0.85), rgba(13, 22, 42, 0.5));
    padding: 1.1rem 1.1rem 1.25rem;
    border-bottom: 1px solid rgba(110, 231, 183, 0.1);
    overflow: hidden;
  }

  /* hide the radio inputs but keep them functional */
  .tab-radio {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .deck-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.85rem;
  }

  .deck-card {
    --card-bg: rgba(28, 38, 70, 0.65);
    position: relative;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 0.85rem 0.95rem 0.75rem;
    border: 1px solid rgba(187, 247, 208, 0.12);
    border-radius: 10px;
    background: var(--card-bg);
    color: var(--slate-300);
    font-family: var(--mono);
    cursor: pointer;
    user-select: none;
    overflow: hidden;
    transition:
      transform 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 240ms ease,
      box-shadow 280ms ease,
      background-color 240ms ease;
  }

  .deck-card:hover {
    transform: translateY(-3px);
    border-color: var(--lang-hue);
    box-shadow: 0 14px 36px rgba(4, 12, 32, 0.4);
  }

  .deck-card:focus-visible {
    outline: 2px solid var(--emerald-400);
    outline-offset: 2px;
  }

  /* top accent strip (language hue) */
  .card-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--lang-hue);
    opacity: 0.55;
    transition: opacity 240ms ease, height 240ms ease, box-shadow 320ms ease;
  }

  .deck-card:hover .card-accent {
    opacity: 1;
    box-shadow: 0 0 12px var(--lang-hue);
  }

  /* holographic shine sweep — diagonal gradient that crosses on hover */
  .card-shine {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.08) 45%,
      rgba(255, 255, 255, 0.18) 50%,
      rgba(255, 255, 255, 0.08) 55%,
      transparent 70%
    );
    transform: translateX(-110%);
    transition: transform 720ms cubic-bezier(0.2, 0.8, 0.2, 1);
    mix-blend-mode: screen;
  }

  .deck-card:hover .card-shine {
    transform: translateX(110%);
  }

  /* card rows */
  .card-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .card-row-mid {
    justify-content: space-between;
    gap: 0.65rem;
  }

  .card-row-bot {
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }

  /* language label */
  .card-lang {
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
    font-size: 0.66rem;
    color: rgba(110, 231, 183, 0.65);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .card-glyph {
    color: var(--lang-hue);
    font-size: 0.85rem;
  }

  .card-lang-name {
    color: var(--lang-hue);
    font-weight: 700;
  }

  /* status pill */
  .card-status {
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
    padding: 0.1rem 0.45rem;
    border: 1px solid rgba(187, 247, 208, 0.18);
    border-radius: 999px;
    background: rgba(13, 22, 42, 0.5);
    font-size: 0.58rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(187, 247, 208, 0.7);
  }

  .card-status.is-active {
    border-color: rgba(110, 231, 183, 0.5);
    color: var(--emerald-400);
    background: rgba(110, 231, 183, 0.08);
  }

  .card-status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(148, 163, 184, 0.65);
  }

  .card-status.is-active .card-status-dot {
    background: var(--emerald-400);
    box-shadow: 0 0 0 0 rgba(110, 231, 183, 0.55);
    animation: ws-status-pulse 2.4s ease-out infinite;
  }

  @keyframes ws-status-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(110, 231, 183, 0.55); }
    70%  { box-shadow: 0 0 0 6px rgba(110, 231, 183, 0); }
    100% { box-shadow: 0 0 0 0 rgba(110, 231, 183, 0); }
  }

  /* project name (the editorial focus point) */
  .card-name {
    margin: 0;
    color: var(--slate-100);
    font-family: var(--display);
    font-size: 1.1rem;
    font-style: italic;
    font-weight: 400;
    font-variation-settings: 'opsz' 144, 'WONK' 1;
    letter-spacing: -0.012em;
    line-height: 1.2;
  }

  /* version pill */
  .card-version {
    display: inline-flex;
    align-items: baseline;
    gap: 0.18rem;
    padding: 0.1rem 0.5rem;
    border: 1px solid rgba(110, 231, 183, 0.22);
    border-radius: 4px;
    background: rgba(110, 231, 183, 0.06);
    color: var(--emerald-300);
    font-size: 0.66rem;
    letter-spacing: 0.04em;
  }

  .version-glyph {
    color: rgba(110, 231, 183, 0.6);
    font-style: italic;
    font-size: 0.62rem;
  }

  /* mini activity waveform */
  .card-bars {
    display: inline-flex;
    align-items: flex-end;
    gap: 2px;
    height: 16px;
    flex: 1;
    justify-content: flex-end;
