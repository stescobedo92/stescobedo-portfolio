---
import Section from './Section.astro';
import Icon from './Icon.astro';
import { projects, profile } from '../../data/portfolio';
import { getPinnedReposMetadata } from '../../lib/github';

const rawBase = import.meta.env.BASE_URL || '/';
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, '')}`;

const pad2 = (n: number) => String(n).padStart(2, '0');
const padN = (n: number, w: number) => String(n).padStart(w, ' ');
const formatCount = (value: number | null | undefined) =>
  typeof value === 'number' ? value.toLocaleString('en-US') : '—';

// ─────────────────────────  LANGUAGE METADATA  ─────────────────────────
type LangKey = 'rust' | 'cpp' | 'go' | 'csharp' | 'typescript' | 'javascript' | 'python' | 'generic';

type LangMeta = {
  key: LangKey;
  label: string;
  ext: string;
  glyph: string;          // emoji-ish file icon
  hue: string;            // accent color (CSS)
  hueSoft: string;        // tinted background
  comment: string;        // // or # etc.
  docComment: string;     // /// or //! or # etc.
};

const LANGS: Record<LangKey, LangMeta> = {
  rust:       { key: 'rust',       label: 'Rust',       ext: 'rs',   glyph: '◆', hue: '247 154 65',   hueSoft: '247 154 65',   comment: '//', docComment: '//!' },
  cpp:        { key: 'cpp',        label: 'C++',        ext: 'cpp',  glyph: '▣', hue: '116 199 236',  hueSoft: '116 199 236',  comment: '//', docComment: '///' },
  go:         { key: 'go',         label: 'Go',         ext: 'go',   glyph: '◎', hue: '125 211 252',  hueSoft: '125 211 252',  comment: '//', docComment: '//' },
  csharp:     { key: 'csharp',     label: 'C#',         ext: 'cs',   glyph: '◈', hue: '167 139 250',  hueSoft: '167 139 250',  comment: '//', docComment: '///' },
  typescript: { key: 'typescript', label: 'TypeScript', ext: 'ts',   glyph: '◇', hue: '96 165 250',   hueSoft: '96 165 250',   comment: '//', docComment: '/**' },
  javascript: { key: 'javascript', label: 'JavaScript', ext: 'js',   glyph: '◇', hue: '250 204 21',   hueSoft: '250 204 21',   comment: '//', docComment: '/**' },
  python:     { key: 'python',     label: 'Python',     ext: 'py',   glyph: '○', hue: '252 211 77',   hueSoft: '252 211 77',   comment: '#',  docComment: '"""' },
  generic:    { key: 'generic',    label: 'Code',       ext: 'src',  glyph: '◌', hue: '110 231 183',  hueSoft: '110 231 183',  comment: '//', docComment: '//' },
};

const detectLang = (tech: string[]): LangMeta => {
  const norm = tech.map((t) => t.toLowerCase());
  if (norm.some((t) => t === 'rust')) return LANGS.rust;
  if (norm.some((t) => t === 'c++' || t === 'cpp')) return LANGS.cpp;
  if (norm.some((t) => t === 'go' || t === 'golang')) return LANGS.go;
  if (norm.some((t) => t === '.net' || t.includes('c#'))) return LANGS.csharp;
  if (norm.some((t) => t === 'typescript' || t === 'ts')) return LANGS.typescript;
  if (norm.some((t) => t === 'javascript' || t === 'js')) return LANGS.javascript;
  if (norm.some((t) => t === 'python')) return LANGS.python;
  return LANGS.generic;
};

// File icon path-style slug for the breadcrumb: dotnet-version-manager → dotnet_version_manager
const fileSlug = (name: string) =>
  name
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '_')
    .replace(/^_|_$/g, '');

const pinnedRepos = await getPinnedReposMetadata(profile.githubUsername, profile.pinnedRepos);
const projectByRepo = new Map(projects.flatMap((project) => (project.githubRepo ? [[project.githubRepo, project]] : [])));
const pinnedProjects = pinnedRepos.map((repo) => {
  const local = projectByRepo.get(repo.fullName);
  return {
    name: repo.name,
    description: repo.description,
    highlights: local?.highlights ?? repo.metadata.languages.slice(0, 3).map((language) => `${language} codebase`),
    tech: repo.metadata.languages.length > 0 ? repo.metadata.languages : local?.tech ?? ['Code'],
    github: repo.htmlUrl,
    githubRepo: repo.fullName,
    demo: repo.homepage ?? local?.demo,
    image: local?.image ?? '',
    cover: local?.cover,
    featured: true,
    active: local?.active ?? false,
    metadata: repo.metadata,
  };
});
const featured = pinnedProjects;
const otherProjects = pinnedProjects.slice(featured.length);

type ProjectLike = typeof pinnedProjects[number];
const metadataFor = (project: ProjectLike) => project.metadata;

const releaseLabel = (release: string | null | undefined) => release ?? 'no release';
const repoLanguagesFor = (project: ProjectLike, metadata: ReturnType<typeof metadataFor>) =>
  metadata.languages.length > 0 ? metadata.languages : project.tech;

// Build a "code preview" as an array of lines, each being an array of tokens.
type Token = { t: 'kw' | 'ty' | 'str' | 'cmt' | 'fn' | 'attr' | 'punct' | 'ident' | 'num' | 'space' | 'hash'; v: string };
type Line = Token[];

const renderRust = (project: ProjectLike): Line[] => {
  const slug = fileSlug(project.name);
  const struct = project.name.split(/[\s\-_]+/).map((w) => w[0]?.toUpperCase() + w.slice(1).toLowerCase()).join('');
  const isActive = project.active === true;
  const lines: Line[] = [];

  lines.push([{ t: 'cmt', v: `//! ${project.name}` }]);
  lines.push([{ t: 'cmt', v: `//! ${'='.repeat(Math.min(project.name.length + 4, 48))}` }]);
  lines.push([{ t: 'cmt', v: '//!' }]);
  lines.push([{ t: 'cmt', v: `//! ${project.description}` }]);
  lines.push([]);
  lines.push([{ t: 'kw', v: 'use' }, { t: 'space', v: ' ' }, { t: 'ident', v: 'std' }, { t: 'punct', v: '::' }, { t: 'ident', v: 'process' }, { t: 'punct', v: '::Command' }, { t: 'punct', v: ';' }]);
  lines.push([{ t: 'kw', v: 'use' }, { t: 'space', v: ' ' }, { t: 'ident', v: 'clap' }, { t: 'punct', v: '::' }, { t: 'ident', v: 'Parser' }, { t: 'punct', v: ';' }]);
  lines.push([]);
  lines.push([{ t: 'attr', v: '#[derive(Debug, Project)]' }]);
  lines.push([{ t: 'kw', v: 'pub struct' }, { t: 'space', v: ' ' }, { t: 'ty', v: struct }, { t: 'space', v: ' ' }, { t: 'punct', v: '{' }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'cmt', v: `/// status: ${isActive ? 'active' : 'shipped'}` }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'kw', v: 'pub status' }, { t: 'punct', v: ':' }, { t: 'space', v: ' ' }, { t: 'ty', v: 'Status' }, { t: 'punct', v: ',' }]);
  lines.push([]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'cmt', v: '/// distinguishing capabilities' }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'kw', v: 'pub highlights' }, { t: 'punct', v: ':' }, { t: 'space', v: ' ' }, { t: 'ty', v: `[&'static str; ${project.highlights.length}]` }, { t: 'punct', v: ',' }]);
  lines.push([{ t: 'punct', v: '}' }]);
  lines.push([]);
  lines.push([{ t: 'kw', v: 'impl' }, { t: 'space', v: ' ' }, { t: 'ty', v: struct }, { t: 'space', v: ' ' }, { t: 'punct', v: '{' }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'kw', v: 'pub fn' }, { t: 'space', v: ' ' }, { t: 'fn', v: 'launch' }, { t: 'punct', v: '() -> ' }, { t: 'ty', v: '!' }, { t: 'space', v: ' ' }, { t: 'punct', v: '{' }]);
  lines.push([{ t: 'space', v: '        ' }, { t: 'cmt', v: `// → github.com/${(project.githubRepo ?? slug).replace(/^.*?\//, 'stescobedo92/')}` }]);
  lines.push([{ t: 'space', v: '        ' }, { t: 'ident', v: 'cli' }, { t: 'punct', v: '::' }, { t: 'fn', v: 'run' }, { t: 'punct', v: '(' }, { t: 'str', v: `"${project.tech.join(' + ')}"` }, { t: 'punct', v: ');' }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'punct', v: '}' }]);
  lines.push([{ t: 'punct', v: '}' }]);
  return lines;
};

const renderCpp = (project: ProjectLike): Line[] => {
  const struct = project.name.split(/[\s\-_]+/).map((w) => w[0]?.toUpperCase() + w.slice(1).toLowerCase()).join('');
  const lines: Line[] = [];
  lines.push([{ t: 'cmt', v: `// ${project.name} — ${project.tech.join(' / ')}` }]);
  lines.push([{ t: 'cmt', v: '//' }]);
  lines.push([{ t: 'cmt', v: `// ${project.description}` }]);
  lines.push([]);
  lines.push([{ t: 'attr', v: '#include' }, { t: 'space', v: ' ' }, { t: 'str', v: '<iostream>' }]);
  lines.push([{ t: 'attr', v: '#include' }, { t: 'space', v: ' ' }, { t: 'str', v: '"platform/desktop.hpp"' }]);
  lines.push([]);
  lines.push([{ t: 'kw', v: 'namespace' }, { t: 'space', v: ' ' }, { t: 'ident', v: 'stescobedo' }, { t: 'space', v: ' ' }, { t: 'punct', v: '{' }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'kw', v: 'class' }, { t: 'space', v: ' ' }, { t: 'ty', v: struct }, { t: 'space', v: ' ' }, { t: 'punct', v: '{' }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'kw', v: 'public:' }]);
  lines.push([{ t: 'space', v: '        ' }, { t: 'kw', v: 'static void' }, { t: 'space', v: ' ' }, { t: 'fn', v: 'apply' }, { t: 'punct', v: '();' }]);
  project.highlights.forEach((h) => {
    lines.push([{ t: 'space', v: '        ' }, { t: 'cmt', v: `// + ${h}` }]);
  });
  lines.push([{ t: 'space', v: '    ' }, { t: 'punct', v: '};' }]);
  lines.push([{ t: 'punct', v: '}' }]);
  return lines;
};

const renderGo = (project: ProjectLike): Line[] => {
  const lines: Line[] = [];
  const pkg = fileSlug(project.name);
  lines.push([{ t: 'cmt', v: `// Package ${pkg}` }]);
  lines.push([{ t: 'cmt', v: `// ${project.description}` }]);
  lines.push([]);
  lines.push([{ t: 'kw', v: 'package' }, { t: 'space', v: ' ' }, { t: 'ident', v: pkg }]);
  lines.push([]);
  lines.push([{ t: 'kw', v: 'import' }, { t: 'space', v: ' ' }, { t: 'punct', v: '(' }]);
  project.tech.forEach((t) => {
    lines.push([{ t: 'space', v: '    ' }, { t: 'str', v: `"${t.toLowerCase()}.io/${pkg}"` }]);
  });
  lines.push([{ t: 'punct', v: ')' }]);
  lines.push([]);
  lines.push([{ t: 'kw', v: 'type' }, { t: 'space', v: ' ' }, { t: 'ty', v: 'Project' }, { t: 'space', v: ' ' }, { t: 'kw', v: 'struct' }, { t: 'space', v: ' ' }, { t: 'punct', v: '{' }]);
  project.highlights.forEach((h, i) => {
    const fld = h.split(/\s+/).slice(0, 2).map((w) => w[0]?.toUpperCase() + w.slice(1).toLowerCase()).join('');
    lines.push([{ t: 'space', v: '    ' }, { t: 'ident', v: fld || `Field${i}` }, { t: 'space', v: ' ' }, { t: 'ty', v: 'string' }, { t: 'space', v: '   ' }, { t: 'cmt', v: `// ${h}` }]);
  });
  lines.push([{ t: 'punct', v: '}' }]);
  return lines;
};

const renderGeneric = (project: ProjectLike, lang: LangMeta): Line[] => {
  const symbol = fileSlug(project.name);
  const lines: Line[] = [];
  lines.push([{ t: 'cmt', v: `${lang.comment} ${project.name} — ${project.tech.join(' / ')}` }]);
  lines.push([{ t: 'cmt', v: `${lang.comment} ${project.description}` }]);
  lines.push([]);
  lines.push([{ t: 'kw', v: 'const' }, { t: 'space', v: ' ' }, { t: 'ident', v: symbol }, { t: 'space', v: ' ' }, { t: 'punct', v: '=' }, { t: 'space', v: ' ' }, { t: 'punct', v: '{' }]);
  lines.push([{ t: 'space', v: '  ' }, { t: 'ident', v: 'repo' }, { t: 'punct', v: ':' }, { t: 'space', v: ' ' }, { t: 'str', v: `"${project.githubRepo ?? project.name}"` }, { t: 'punct', v: ',' }]);
  lines.push([{ t: 'space', v: '  ' }, { t: 'ident', v: 'languages' }, { t: 'punct', v: ':' }, { t: 'space', v: ' ' }, { t: 'str', v: `[${project.tech.slice(0, 4).map((tech) => `"${tech}"`).join(', ')}]` }, { t: 'punct', v: ',' }]);
  lines.push([{ t: 'space', v: '  ' }, { t: 'fn', v: 'open' }, { t: 'punct', v: '()' }, { t: 'space', v: ' ' }, { t: 'punct', v: '{' }]);
  lines.push([{ t: 'space', v: '    ' }, { t: 'kw', v: 'return' }, { t: 'space', v: ' ' }, { t: 'ident', v: 'source' }, { t: 'punct', v: '(' }, { t: 'str', v: `"${project.github}"` }, { t: 'punct', v: ');' }]);
  lines.push([{ t: 'space', v: '  ' }, { t: 'punct', v: '}' }]);
  lines.push([{ t: 'punct', v: '};' }]);
  return lines;
};

const renderForLang = (project: ProjectLike, lang: LangMeta): Line[] => {
  if (lang.key === 'rust') return renderRust(project);
  if (lang.key === 'cpp') return renderCpp(project);
  if (lang.key === 'go') return renderGo(project);
  return renderGeneric(project, lang);
};

// Pre-compute previews for all featured projects so we can render them once
const featuredViews = featured.map((project, index) => {
  const metadata = metadataFor(project);
  const languages = repoLanguagesFor(project, metadata);
  const lang = detectLang(languages);
  const lines = renderForLang(project, lang);
  return {
    project,
    lang,
    lines,
    metadata,
    languages,
    tabId: `tab-${index}`,
    panelId: `panel-${index}`,
    isActive: index === 0,
    fileName: `${fileSlug(project.name)}.${lang.ext}`,
  };
});

// For other projects, cargo-style sections backed by GitHub metadata
const otherViews = otherProjects.map((project, index) => {
  const metadata = metadataFor(project);
  const languages = repoLanguagesFor(project, metadata);
  const lang = detectLang(languages);
  return { project, lang, metadata, languages, num: index + 1, isRemote: false };
});
const manifestViews = otherViews;
---

<Section title="Featured Work" titleKey="sections.projects" id="projects">
  <!-- ────────  IDE WORKSPACE (featured)  ──────── -->
  <div class="ide" role="region" aria-label="Featured projects, displayed as an IDE workspace">
    <!-- Window chrome -->
    <div class="ide-chrome" aria-hidden="true">
      <span class="dot dot-r"></span>
      <span class="dot dot-y"></span>
      <span class="dot dot-g"></span>
      <span class="chrome-title">workspace · selected-work</span>
      <span class="chrome-spacer"></span>
      <span class="chrome-meta">{featured.length} files open</span>
    </div>

    <!-- Tab bar -->
    <div class="ide-tabs" role="tablist" aria-label="Project files">
      {featuredViews.map((view, index) => (
        <input
          type="radio"
          name="ide-tab"
          id={view.tabId}
          class="tab-radio"
          checked={view.isActive}
          aria-controls={view.panelId}
        />
      ))}
      <div class="tab-strip">
        {featuredViews.map((view, index) => (
          <label
            for={view.tabId}
            class="tab"
            data-tab-index={index}
            role="tab"
            tabindex="0"
            style={`--lang-hue: rgb(${view.lang.hue});`}
          >
            <span class="tab-glyph" aria-hidden="true">{view.lang.glyph}</span>
            <a class="tab-name tab-link" href={view.project.github} target="_blank" rel="noopener noreferrer" aria-label={`${view.project.name} repository`}>
              {view.fileName}
            </a>
            <span class="tab-dot" aria-hidden="true"></span>
            <span class="tab-close" aria-hidden="true">×</span>
          </label>
        ))}
        <span class="tab-fade-right" aria-hidden="true"></span>
      </div>
    </div>

    <!-- Editor body — only the active panel is shown via :checked -->
    <div class="ide-body">
      {featuredViews.map((view, index) => (
        <section
          id={view.panelId}
          class="panel"
          role="tabpanel"
          aria-labelledby={view.tabId}
          data-panel-index={index}
          style={`--lang-hue: rgb(${view.lang.hue}); --lang-hue-soft: rgba(${view.lang.hueSoft} / 0.12);`}
        >
          <!-- Breadcrumb -->
          <nav class="breadcrumb" aria-label="File path">
            <span class="bc-glyph" aria-hidden="true">⌘</span>
            <span class="bc-seg">~</span>
            <span class="bc-sep" aria-hidden="true">›</span>
            <span class="bc-seg">workspace</span>
            <span class="bc-sep" aria-hidden="true">›</span>
            <span class="bc-seg">selected-work</span>
            <span class="bc-sep" aria-hidden="true">›</span>
            <span class="bc-seg active">
              <span class="bc-icon">{view.lang.glyph}</span>
              <a class="bc-file-link" href={view.project.github} target="_blank" rel="noopener noreferrer">
                {view.fileName}
              </a>
            </span>
            <span class="bc-spacer"></span>
            <span class="bc-action" aria-hidden="true">⌃ ⌘ → next</span>
          </nav>

          <!-- Editor split: code | sidebar -->
          <div class="editor-split">
            <!-- Code preview -->
            <div class="code-pane">
              <pre class="code-block" aria-label={`${view.project.name} source preview`}>
                {view.lines.map((tokens, lineIdx) => (
                  <div class="code-line">
                    <span class="ln" aria-hidden="true">{padN(lineIdx + 1, 2)}</span>
                    <span class="lc">
                      {tokens.map((token) => (
                        <span class={`tk tk-${token.t}`}>{token.v}</span>
                      ))}
                    </span>
                  </div>
                ))}
                <div class="code-line code-line-cursor">
                  <span class="ln" aria-hidden="true">{padN(view.lines.length + 1, 2)}</span>
                  <span class="lc"><span class="caret" aria-hidden="true"></span></span>
                </div>
              </pre>
            </div>

            <!-- Sidebar -->
            <aside class="meta-pane" aria-label={`${view.project.name} metadata`}>
              <div class="meta-section">
                <h3 class="meta-title">
                  <a href={view.project.github} target="_blank" rel="noopener noreferrer">{view.project.name}</a>
                </h3>
                <p class="meta-lede">{view.project.description}</p>
              </div>

              <div class="meta-section">
                <span class="meta-eyebrow" data-i18n="projects.stats">stats</span>
                <div class="meta-stats">
                  <div class="stat-cell">
                    <span class="stat-num" data-repo-stars={view.project.githubRepo}>{formatCount(view.metadata.stars)}</span>
                    <span class="stat-key" data-i18n="projects.stars">stars</span>
                  </div>
                  <div class="stat-cell">
                    <span class="stat-num" data-repo-commits={view.project.githubRepo}>{formatCount(view.metadata.commits)}</span>
                    <span class="stat-key" data-i18n="projects.commits">commits</span>
                  </div>
                  <div class="stat-cell">
                    <span class="stat-num branch-name" data-repo-branch={view.project.githubRepo}>{view.metadata.defaultBranch ?? '—'}</span>
                    <span class="stat-key" data-i18n="projects.branch">branch</span>
                  </div>
                </div>
              </div>

              <div class="meta-section">
                <span class="meta-eyebrow" data-i18n="projects.stack">stack</span>
                <ul class="meta-tech">
                  {view.project.tech.map((tech) => (
                    <li class="tech-pill">{tech}</li>
                  ))}
                </ul>
              </div>

              <div class="meta-section">
                <span class="meta-eyebrow" data-i18n="projects.highlights">highlights</span>
                <ul class="meta-highlights">
                  {view.project.highlights.map((h, i) => (
                    <li>
                      <span class="hl-num">{pad2(i + 1)}</span>
                      <span class="hl-text">{h}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="meta-actions">
                <a class="action primary" href={view.project.github} target="_blank" rel="noopener noreferrer">
                  <Icon name="github" class="h-4 w-4" />
                  <span data-i18n="projects.source">Source</span>
                  <span class="action-shortcut" aria-hidden="true">↗</span>
                </a>
                {view.project.demo && (
                  <a class="action ghost" href={view.project.demo} target="_blank" rel="noopener noreferrer">
                    <Icon name="external" class="h-4 w-4" />
                    <span>Live</span>
                  </a>
                )}
              </div>
            </aside>
          </div>

          <!-- Status bar -->
          <div class="statusbar" aria-hidden="true">
            <span class="sb-cell sb-branch">
              <span class="sb-glyph">⎇</span>
              <span data-repo-branch={view.project.githubRepo}>{view.metadata.defaultBranch ?? '—'}</span>
            </span>
            <span class="sb-cell">{view.lang.label}</span>
            <span class="sb-cell">UTF-8</span>
            <span class="sb-cell">LF</span>
            <span class="sb-cell">spaces: 4</span>
            <span class="sb-spacer"></span>
            <span class={`sb-cell release-cell ${view.metadata.release ? '' : 'is-empty'}`} data-repo-release={view.project.githubRepo}>
              {releaseLabel(view.metadata.release)}
            </span>
            <span class={`sb-cell sb-status ${view.project.active ? 'is-active' : ''}`}>
              <span class="sb-dot"></span>
              <span>{view.project.active ? 'active' : 'shipped'}</span>
            </span>
            <span class="sb-cell sb-link">Ln {view.lines.length}, Col 1</span>
          </div>
        </section>
      ))}
    </div>
  </div>

  {manifestViews.length > 0 && (
    <div class="workspace" data-github-user={profile.githubUsername}>
      <header class="workspace-head">
        <span class="ws-glyph" aria-hidden="true">⌗</span>
        <div class="ws-title">
          <h3>workspace.toml</h3>
          <p data-i18n="projects.moreCrates">more crates from the same author</p>
        </div>
        <span class="ws-rule" aria-hidden="true"></span>
        <a class="ws-link" href={withBase('blog')} data-i18n="projects.viewArchive">view archive →</a>
      </header>

      <ul class="manifest-grid" id="project-grid">
        {manifestViews.map((view) => (
          <li
            class={`manifest ${view.isRemote ? 'is-remote' : ''}`}
            hidden={view.isRemote}
            data-github-repo={view.project.githubRepo}
            data-repo-name={view.project.githubRepo?.split('/')[1] ?? view.project.name}
            style={`--lang-hue: rgb(${view.lang.hue}); --lang-hue-soft: rgba(${view.lang.hueSoft} / 0.18);`}
          >
            <article class="manifest-card">
              <span class="manifest-rail" aria-hidden="true"></span>

              <header class="manifest-head">
                <span class="manifest-num">{pad2(view.num)}</span>
                <span class="manifest-glyph" aria-hidden="true">{view.lang.glyph}</span>
                <span class="manifest-lang">{view.lang.label}</span>
                <span class="manifest-spacer"></span>
                <span class={`manifest-version ${view.metadata.release ? '' : 'is-empty'}`} data-repo-release={view.project.githubRepo}>
                  {releaseLabel(view.metadata.release)}
                </span>
              </header>

              <div class="manifest-section">
                <span class="ms-key">[package]</span>
                <ul class="ms-rows">
                  <li>
                    <span class="ms-prop">name</span>
                    <span class="ms-eq">=</span>
                    <a class="ms-val ms-link" href={view.project.github} target="_blank" rel="noopener noreferrer">
                      "{view.project.name}"
                    </a>
                  </li>
                  <li>
                    <span class="ms-prop">authors</span>
                    <span class="ms-eq">=</span>
                    <span class="ms-val ms-arr">["stescobedo92"]</span>
                  </li>
                  <li>
                    <span class="ms-prop">license</span>
                    <span class="ms-eq">=</span>
                    <span class="ms-val">"MIT"</span>
                  </li>
                </ul>
              </div>

              <div class="manifest-section manifest-desc">
                <span class="ms-key">[description]</span>
                <p class="repo-description">{view.project.description}</p>
              </div>

              <div class="manifest-section">
                <span class="ms-key">[dependencies]</span>
                <ul class="repo-languages" aria-label={`${view.project.name} technologies`}>
                  {view.languages.slice(0, 6).map((tech) => (
                    <li><span class="dep-plus" aria-hidden="true">+</span> {tech}</li>
                  ))}
                </ul>
              </div>

              <footer class="manifest-foot">
                <span class="foot-stats">
                  <span class="foot-stat">★ <span data-repo-stars={view.project.githubRepo}>{formatCount(view.metadata.stars)}</span></span>
                  <span class="foot-stat">⎇ <span data-repo-commits={view.project.githubRepo}>{formatCount(view.metadata.commits)}</span></span>
                </span>
                <span class="foot-spacer"></span>
                <div class="foot-links card-links">
                  <a class="repo-title" href={view.project.github} target="_blank" rel="noopener noreferrer" aria-label={`${view.project.name} on GitHub`}>
                    <Icon name="github" class="h-4 w-4" />
                    <span class="foot-label" data-i18n="projects.sourceLower">source</span>
                  </a>
                  {view.project.demo && (
                    <a href={view.project.demo} target="_blank" rel="noopener noreferrer" aria-label={`${view.project.name} demo`}>
                      <Icon name="external" class="h-4 w-4" />
                      <span class="foot-label">live</span>
                    </a>
                  )}
                  {'active' in view.project && view.project.active && <span class="active-dot">● active</span>}
                </div>
              </footer>

              <span class="card-num" hidden></span>
            </article>
          </li>
        ))}
      </ul>

      <div class="workspace-footer">
        <button id="toggle-projects" class="show-more" type="button" aria-expanded="false">
          <span class="dash" aria-hidden="true"></span>
          <span data-i18n="projects.cargoSearch">cargo search --remote</span>
          <span class="dash" aria-hidden="true"></span>
        </button>
      </div>
    </div>
  )}
</Section>

<script>
  const PAGE_SIZE = 3;

  const initializeProjects = () => {
    // ── Tab keyboard nav ──
    const tabs = Array.from(document.querySelectorAll<HTMLLabelElement>('.ide-tabs .tab'));
    tabs.forEach((tab) => {
      if ((tab as any).dataset.bound === 'true') return;
      (tab as any).dataset.bound = 'true';
      tab.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;
        event.preventDefault();
        const idx = tabs.indexOf(tab);
        const next = (idx + (event.key === 'ArrowRight' ? 1 : -1) + tabs.length) % tabs.length;
        const radio = document.getElementById(tabs[next].getAttribute('for') ?? '') as HTMLInputElement | null;
        if (radio) {
          radio.checked = true;
          tabs[next].focus();
        }
      });
    });

    // Global keyboard shortcut: ⌘/Ctrl + → / ←
    if (!(document as any).__projectsTabHotkeysBound) {
      (document as any).__projectsTabHotkeysBound = true;
      document.addEventListener('keydown', (event) => {
        if (!event.metaKey && !event.ctrlKey) return;
        if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;
        const radios = Array.from(document.querySelectorAll<HTMLInputElement>('.ide-tabs .tab-radio'));
        if (radios.length === 0) return;
        const activeIdx = radios.findIndex((r) => r.checked);
        if (activeIdx === -1) return;
        const target = (event.target as HTMLElement | null);
        if (target && target.closest('.ide')) {
          event.preventDefault();
          const next = (activeIdx + (event.key === 'ArrowRight' ? 1 : -1) + radios.length) % radios.length;
          radios[next].checked = true;
        }
      });
    }

    // ── Show more (cargo search --remote) ──
    const section = document.querySelector<HTMLElement>('.workspace');
    const button = document.getElementById('toggle-projects') as HTMLButtonElement | null;
    const grid = document.getElementById('project-grid');
    if (!section || !button || !grid || button.dataset.ready === 'true') return;
    button.dataset.ready = 'true';

    const hiddenCards = () => Array.from(grid.querySelectorAll<HTMLElement>('.manifest[hidden]'));
    if (hiddenCards().length === 0) {
      button.hidden = true;
      return;
    }

    button.addEventListener('click', () => {
      button.disabled = true;
      const label = button.querySelector('span:not(.dash)');
      const previousLabel = label?.textContent ?? 'cargo search --remote';
      if (label) label.textContent = 'opening…';

      const next = hiddenCards().slice(0, PAGE_SIZE);
      next.forEach((card) => {
        card.hidden = false;
        card.classList.add('revealed');
      });

      button.setAttribute('aria-expanded', 'true');
      if (label) label.textContent = previousLabel;
      button.disabled = false;

      if (hiddenCards().length === 0) {
        button.hidden = true;
      }
    });
  };

  document.addEventListener('astro:page-load', initializeProjects);
  initializeProjects();
</script>

