  /* the "↳ jump" arrow points down to the editor when this card is active */
  .card-jump {
    color: rgba(187, 247, 208, 0.4);
    font-family: var(--mono);
    font-size: 0.95rem;
    transition: color 240ms ease, transform 320ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .deck-card:hover .card-jump {
    color: var(--emerald-400);
    transform: translateY(2px);
  }

  /* ── Active state — driven by the :checked radio sibling ── */
  .tab-radio:nth-of-type(1):checked ~ .deck-row > .deck-card[data-tab-index="0"],
  .tab-radio:nth-of-type(2):checked ~ .deck-row > .deck-card[data-tab-index="1"],
  .tab-radio:nth-of-type(3):checked ~ .deck-row > .deck-card[data-tab-index="2"],
  .tab-radio:nth-of-type(4):checked ~ .deck-row > .deck-card[data-tab-index="3"],
  .tab-radio:nth-of-type(5):checked ~ .deck-row > .deck-card[data-tab-index="4"] {
