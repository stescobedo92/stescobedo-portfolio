---
import Section from './Section.astro';
import Icon from './Icon.astro';
import { profile } from '../../data/portfolio';

// Stats line + status pill content
const tzOffset = 'GMT-5';
const yearsBuilding = '8+';

// Passion items already on profile.passionItems — used in marquee
const passionsLoop = [...profile.passionItems, ...profile.passionItems];

// Map socials to their icon names
const iconByNetwork = {
  GitHub: 'github',
  LinkedIn: 'linkedin',
  StackOverflow: 'stackoverflow',
  X: 'x',
} as const;
---

<Section title="About me" id="about">
  <div class="about-frame">
    <span class="frame-corner tl" aria-hidden="true">+</span>
    <span class="frame-corner tr" aria-hidden="true">+</span>
    <span class="frame-corner bl" aria-hidden="true">+</span>
    <span class="frame-corner br" aria-hidden="true">+</span>

    <p class="about-eyebrow">
      <span class="dash" aria-hidden="true"></span>
      Profile · Fig. 01
      <span class="dash" aria-hidden="true"></span>
    </p>

    <div class="about-grid">
      <!-- LEFT: editorial bio -->
      <div class="copy">
        <h3 class="signature" aria-hidden="true">Sergio<span class="period">.</span></h3>

        <div class="status-row">
          <span class="status-pill">
            <span class="status-dot" aria-hidden="true"></span>
            <span>Available · {tzOffset}</span>
          </span>
          <span class="status-meta">Open for backend &middot; cloud &middot; tooling</span>
        </div>

        <p class="bio" data-github-bio>{profile.summary}</p>

        <ul class="meta-strip" aria-label="Career stats">
          <li>
            <span class="meta-num">{yearsBuilding}</span>
            <span class="meta-lbl">Years building</span>
          </li>
          <li>
            <span class="meta-num">∞</span>
            <span class="meta-lbl">Curiosity</span>
          </li>
          <li>
            <span class="meta-num" data-repo-count>—</span>
            <span class="meta-lbl">Repos shipped</span>
          </li>
        </ul>

        <div class="passion-block">
          <p class="passion-label">
            <span class="dash" aria-hidden="true"></span>
            Currently into
          </p>
          <div class="passion-marquee" aria-hidden="true">
            <ul class="passion-track">
              {passionsLoop.map((item) => (
                <li>{item}<span class="passion-sep">·</span></li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      <!-- RIGHT: editorial portrait -->
      <div class="portrait-wrap">
        <figure class="portrait-frame">
          <span class="portrait-corner tl" aria-hidden="true"></span>
          <span class="portrait-corner tr" aria-hidden="true"></span>
          <span class="portrait-corner bl" aria-hidden="true"></span>
          <span class="portrait-corner br" aria-hidden="true"></span>

          <div class="portrait-topbar">
            <span class="portrait-tag">SUBJECT · 01</span>
            <ul class="portrait-socials" aria-label="Social channels">
              {profile.socials.map((s) => (
                <li>
                  <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.network}>
                    <Icon name={iconByNetwork[s.network] ?? 'github'} class="h-3 w-3" />
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <img
            src={profile.image}
            alt={profile.name}
            width="420"
            height="420"
            loading="eager"
            data-github-avatar
          />

          <figcaption class="portrait-caption">
            <span class="cap-line">
              <span class="cap-key">Name</span>
              <span class="cap-val">{profile.name}</span>
            </span>
            <span class="cap-line">
              <span class="cap-key">Role</span>
              <span class="cap-val">{profile.label}</span>
            </span>
            <span class="cap-line">
              <span class="cap-key">From</span>
              <span class="cap-val">{profile.location}</span>
            </span>
          </figcaption>
        </figure>
      </div>
    </div>
  </div>
</Section>

<script define:vars={{ username: profile.githubUsername }}>
  const hydrateGitHubProfile = async () => {
    const avatar = document.querySelector('[data-github-avatar]');
    const bio = document.querySelector('[data-github-bio]');
    if (!avatar && !bio) return;

    try {
      const response = await fetch(`https://api.github.com/users/${username}`, {
        cache: 'no-store',
        headers: { Accept: 'application/vnd.github+json' },
      });
      if (!response.ok) return;
      const data = await response.json();
      if (avatar && data.avatar_url) {
        avatar.src = `${data.avatar_url}${data.avatar_url.includes('?') ? '&' : '?'}s=420`;
      }
      if (bio && data.bio) {
        bio.textContent = data.bio;
      }
      const repoCountEl = document.querySelector('[data-repo-count]');
      if (repoCountEl && typeof data.public_repos === 'number') {
        repoCountEl.textContent = String(data.public_repos);
      }
    } catch {
      // Keep the local fallback if GitHub rate limits or network fails.
    }
  };

  document.addEventListener('astro:page-load', hydrateGitHubProfile);
  hydrateGitHubProfile();
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,300..900,0..100,0..1&display=swap');

  /* ABOUT FRAME */
  .about-frame {
    position: relative;
    padding: clamp(1.5rem, 4vw, 3rem) clamp(1.25rem, 3vw, 2.25rem);
    border: 1px solid rgba(187, 247, 208, 0.16);
    background:
      radial-gradient(ellipse at top right, rgba(110, 231, 183, 0.06), transparent 60%),
      rgb(28 38 70);
  }

  .frame-corner {
    position: absolute;
    color: rgb(110 231 183);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 1rem;
    line-height: 1;
    user-select: none;
    pointer-events: none;
  }
  .frame-corner.tl { top: -7px; left: -7px; }
  .frame-corner.tr { top: -7px; right: -7px; }
  .frame-corner.bl { bottom: -7px; left: -7px; }
  .frame-corner.br { bottom: -7px; right: -7px; }

  /* EYEBROW */
  .about-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 2rem;
    color: rgb(110 231 183);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.74rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .about-eyebrow .dash {
    width: 28px;
    height: 1px;
    background: currentColor;
    opacity: 0.6;
  }

  /* GRID */
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 1fr);
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: start;
  }

  /* SIGNATURE TITLE */
  .signature {
    margin: 0 0 1.25rem;
    color: rgb(248 250 252);
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-style: italic;
    font-weight: 400;
    font-variation-settings: 'opsz' 144, 'WONK' 1, 'SOFT' 50;
    letter-spacing: -0.04em;
    line-height: 0.9;
  }

  .signature .period {
    color: rgb(110 231 183);
    font-style: italic;
  }

  /* STATUS ROW */
  .status-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.7rem 1rem;
    margin-bottom: 1.6rem;
  }

  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.32rem 0.85rem;
    border: 1px solid rgba(110, 231, 183, 0.4);
    border-radius: 999px;
    background: rgba(110, 231, 183, 0.08);
    color: rgb(167 243 208);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgb(110 231 183);
    box-shadow: 0 0 0 0 rgba(110, 231, 183, 0.55);
    animation: dotpulse 2.4s ease-out infinite;
  }

  @keyframes dotpulse {
    0% { box-shadow: 0 0 0 0 rgba(110, 231, 183, 0.55); }
    70% { box-shadow: 0 0 0 8px rgba(110, 231, 183, 0); }
    100% { box-shadow: 0 0 0 0 rgba(110, 231, 183, 0); }
  }

  .status-meta {
    color: rgb(148 163 184);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* BIO with drop cap */
  .bio {
    margin: 0 0 1.8rem;
    color: rgb(203 213 225);
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    font-weight: 350;
    line-height: 1.75;
  }

  .bio::first-letter {
    float: left;
    color: rgb(110 231 183);
    font-family: 'Fraunces', Georgia, serif;
    font-size: 3.4rem;
    font-weight: 400;
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'WONK' 1;
    line-height: 0.85;
    padding: 0.35rem 0.55rem 0 0;
  }

  /* META STRIP */
  .meta-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin: 0 0 2rem;
    padding: 0;
    list-style: none;
    border-top: 1px solid rgba(187, 247, 208, 0.16);
    border-bottom: 1px solid rgba(187, 247, 208, 0.16);
  }

  .meta-strip li {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
    padding: 1rem 1.1rem;
    border-right: 1px solid rgba(187, 247, 208, 0.16);
  }

  .meta-strip li:last-child {
    border-right: 0;
  }

  .meta-num {
    color: rgb(248 250 252);
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.3rem, 2.2vw, 1.7rem);
    font-weight: 400;
    font-variation-settings: 'opsz' 144, 'WONK' 1;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .meta-lbl {
    color: rgb(148 163 184);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  /* PASSION MARQUEE */
  .passion-block {
    margin-top: 0.5rem;
  }

  .passion-label {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0 0 0.7rem;
    color: rgb(110 231 183);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .passion-label .dash {
    width: 24px;
    height: 1px;
    background: currentColor;
    opacity: 0.6;
  }

  .passion-marquee {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 6%, black 94%, transparent 100%);
            mask-image: linear-gradient(90deg, transparent 0%, black 6%, black 94%, transparent 100%);
  }

  .passion-track {
    display: flex;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
    width: max-content;
    color: rgb(187 247 208);
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.05rem;
    font-style: italic;
    font-weight: 400;
    font-variation-settings: 'opsz' 144;
    animation: passion-scroll 28s linear infinite;
  }

  .passion-track li {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    white-space: nowrap;
  }

  .passion-sep {
    color: rgb(110 231 183);
    margin-left: 1.5rem;
    font-style: normal;
  }

  @keyframes passion-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* PORTRAIT FRAME */
  .portrait-wrap {
    display: flex;
    justify-content: center;
  }

  .portrait-frame {
    position: relative;
    width: min(100%, 340px);
    margin: 0;
    padding: 1rem;
    border: 1px solid rgba(187, 247, 208, 0.18);
    background: rgba(22, 30, 52, 0.6);
    transition: transform 280ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .portrait-frame:hover {
    transform: translateY(-4px);
  }

  .portrait-corner {
    position: absolute;
    width: 14px;
    height: 14px;
    border: 2px solid rgb(110 231 183);
  }
  .portrait-corner.tl { top: -2px; left: -2px; border-right: 0; border-bottom: 0; }
  .portrait-corner.tr { top: -2px; right: -2px; border-left: 0; border-bottom: 0; }
  .portrait-corner.bl { bottom: -2px; left: -2px; border-right: 0; border-top: 0; }
  .portrait-corner.br { bottom: -2px; right: -2px; border-left: 0; border-top: 0; }

  .portrait-topbar {
    position: absolute;
    top: -10px;
    left: 1rem;
    right: 1rem;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }

  .portrait-tag {
    padding: 0.18rem 0.55rem;
    background: rgb(28 38 70);
    color: rgb(110 231 183);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .portrait-socials {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin: 0;
    padding: 0.18rem 0.4rem;
    background: rgb(28 38 70);
    list-style: none;
  }

  .portrait-socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    color: rgb(187 247 208);
    transition: color 180ms ease, transform 180ms ease;
  }

  .portrait-socials a:hover,
  .portrait-socials a:focus-visible {
    color: rgb(110 231 183);
    transform: translateY(-1px);
    outline: none;
  }

  .portrait-frame img {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    filter: saturate(0.7) contrast(1.05);
    transition: filter 320ms ease;
  }

  .portrait-frame:hover img {
    filter: saturate(1) contrast(1);
  }

  .portrait-caption {
    display: grid;
    gap: 0.45rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed rgba(187, 247, 208, 0.22);
  }

  .cap-line {
    display: grid;
    grid-template-columns: 50px 1fr;
    gap: 0.65rem;
    color: rgb(187 247 208);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.74rem;
  }

  .cap-key {
    color: rgba(110, 231, 183, 0.7);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: 0.66rem;
  }

  .cap-val {
    color: rgb(248 250 252);
    font-family: 'Fraunces', Georgia, serif;
    font-size: 0.92rem;
    font-weight: 400;
    font-variation-settings: 'opsz' 144;
    letter-spacing: -0.005em;
  }

  /* LIGHT MODE */
  :global(html:not(.dark)) .about-frame {
    background: rgb(248 250 252);
    border-color: rgba(15, 23, 42, 0.08);
  }

  :global(html:not(.dark)) .signature,
  :global(html:not(.dark)) .meta-num,
  :global(html:not(.dark)) .cap-val {
    color: rgb(22 30 52);
  }

  :global(html:not(.dark)) .bio {
    color: rgb(48 62 98);
  }

  :global(html:not(.dark)) .portrait-frame {
    background: rgb(255 255 255);
  }

  /* RESPONSIVE */
  @media (max-width: 880px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .portrait-wrap {
      justify-content: flex-start;
    }
  }

  @media (max-width: 560px) {
    .meta-strip {
      grid-template-columns: 1fr;
    }
    .meta-strip li {
      border-right: 0;
      border-bottom: 1px solid rgba(187, 247, 208, 0.12);
    }
    .meta-strip li:last-child {
      border-bottom: 0;
    }
    .signature {
      font-size: clamp(2.4rem, 14vw, 3.6rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .status-dot,
    .passion-track {
      animation: none;
    }
  }
</style>
