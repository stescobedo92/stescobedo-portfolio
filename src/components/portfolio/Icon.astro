---
interface Props {
  name:
    | 'github'
    | 'linkedin'
    | 'stackoverflow'
    | 'external'
    | 'folder'
    | 'send'
    | 'menu'
    | 'x'
    | 'arrow-up'
    | 'arrow-right'
    | 'download';
  class?: string;
}

const { name, class: className = 'h-5 w-5' } = Astro.props;
---

{
  name === 'github' && (
    <svg class={className} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.39.6.11.79-.26.79-.58v-2.23c-3.34.73-4.03-1.42-4.03-1.42-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.49 1 .11-.78.42-1.31.76-1.61-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23.96-.27 1.98-.4 3-.4s2.05.13 3 .4c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.48 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.19.69.8.58A12.01 12.01 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
    </svg>
  )
}

{
  name === 'linkedin' && (
    <svg class={className} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zm1.78 13.02H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.73V1.73C24 .77 23.2 0 22.23 0z" />
    </svg>
  )
}

{
  name === 'stackoverflow' && (
    <svg class={className} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.36 20.13v-5.13h1.71V22H3v-7h1.71v5.13H17.36zM6.42 16.39h8.58v-1.71H6.42v1.71zm.27-3.97 8.36 1.78.36-1.67-8.37-1.78-.35 1.67zm1.16-3.92 7.74 3.61.72-1.55-7.74-3.62-.72 1.56zm2.27-3.78 6.56 5.46 1.09-1.31-6.55-5.46-1.1 1.31zM14.84 0l-1.4 1.04 5.18 6.97 1.39-1.05L14.84 0z" />
    </svg>
  )
}

{
  name !== 'github' && name !== 'linkedin' && name !== 'stackoverflow' && (
    <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      {name === 'external' && <><path d="M15 3h6v6" /><path d="M10 14 21 3" /><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /></>}
      {name === 'folder' && <><path d="M3 7a2 2 0 0 1 2-2h5l2 2h7a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z" /></>}
      {name === 'send' && <><path d="m22 2-7 20-4-9-9-4Z" /><path d="M22 2 11 13" /></>}
      {name === 'menu' && <><path d="M4 6h16" /><path d="M4 12h16" /><path d="M4 18h16" /></>}
      {name === 'x' && <><path d="M18 6 6 18" /><path d="m6 6 12 12" /></>}
      {name === 'arrow-up' && <><path d="m18 15-6-6-6 6" /></>}
      {name === 'arrow-right' && <><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></>}
      {name === 'download' && <><path d="M12 3v12" /><path d="m7 10 5 5 5-5" /><path d="M5 21h14" /></>}
    </svg>
  )
}
