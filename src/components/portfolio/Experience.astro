<script>
  const initializeExperience = () => {
    const filters = document.querySelectorAll<HTMLButtonElement>('.git-filters .chip');
    const commits = document.querySelectorAll<HTMLLIElement>('.git-log .commit');
    if (!filters.length || !commits.length) return;

    filters.forEach((chip) => {
      if ((chip as any).dataset.bound === 'true') return;
      (chip as any).dataset.bound = 'true';

      chip.addEventListener('click', () => {
        const filter = chip.dataset.filter || 'all';
        filters.forEach((c) => c.classList.toggle('is-active', c === chip));

        commits.forEach((commit) => {
          const tag = commit.dataset.tag || '';
          const isCurrent = commit.dataset.current === 'true';
          let visible = true;
          if (filter === 'current') visible = isCurrent;
          else if (filter !== 'all') visible = tag === filter;
          commit.classList.toggle('is-hidden', !visible);
        });
      });
    });
  };

  document.addEventListener('astro:page-load', initializeExperience);
  initializeExperience();
</script>
