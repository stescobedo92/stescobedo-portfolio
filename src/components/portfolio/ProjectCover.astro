---
// Programmatic project covers — modern, themed per project
// Each variant is a hand-crafted SVG/HTML composition with a distinct visual identity

interface Props {
  variant: 'terminal-dotnet' | 'cipher-key' | 'password-stream' | 'pixel-desktop' | 'qr-grid' | 'code-pointer' | 'default';
  name: string;
  tech: string[];
}

const { variant, name, tech } = Astro.props;
const primaryTech = (tech[0] || '').toLowerCase();

// Tech-aware accent
const accentByTech: Record<string, string> = {
  rust: '#fb923c',         // amber
  '.net': '#a855f7',       // violet
  'c++': '#60a5fa',        // sky
  go: '#22d3ee',           // cyan
  python: '#facc15',       // yellow
  cli: '#6ee7b7',          // emerald
  cryptography: '#f472b6', // pink
  security: '#f87171',     // red
};
const accent = accentByTech[primaryTech] ?? '#6ee7b7';

// Pre-compute QR cells in frontmatter to avoid JSX parser confusion with < / >
const qrCells: boolean[] = [];
if (variant === 'qr-grid') {
  for (let i = 0; i < 169; i++) {
    const r = Math.floor(i / 13);
    const c = i % 13;
    const inTopLeft = r <= 3 && c <= 3;
    const inTopRight = r <= 3 && c >= 9;
    const inBottomLeft = r >= 9 && c <= 3;
    const isCorner = inTopLeft || inTopRight || inBottomLeft;
    const onFinder =
      isCorner &&
      ((inTopLeft && (r === 0 || r === 3 || c === 0 || c === 3)) ||
        (inTopLeft && r >= 1 && r <= 2 && c >= 1 && c <= 2) ||
        (inTopRight && (r === 0 || r === 3 || c === 9 || c === 12)) ||
        (inTopRight && r >= 1 && r <= 2 && c >= 10 && c <= 11) ||
        (inBottomLeft && (r === 9 || r === 12 || c === 0 || c === 3)) ||
        (inBottomLeft && r >= 10 && r <= 11 && c >= 1 && c <= 2));
    const seed = ((i * 1103515245 + 12345) >> 8) & 1;
    qrCells.push(isCorner ? onFinder : seed === 1);
  }
}

// Pre-compute pixel grid for desktop variant
const pixelMap = [12, 13, 14, 22, 25, 32, 33, 34, 35, 36, 42, 46, 52, 56, 62, 63, 64, 65, 66, 76];
const pixelCells = Array.from({ length: 96 }, (_, i) => pixelMap.includes(i));

// Pre-compute cipher grid
const cipherActive = [3, 7, 12, 18, 24, 31, 37, 41, 48, 53];
const cipherCells = Array.from({ length: 60 }, (_, i) => cipherActive.includes(i));
---

{variant === 'terminal-dotnet' && (
  <div class="cover terminal-cover" data-accent={accent}>
    <div class="terminal-bar">
      <span class="t-dot" style="background: #fb7185"></span>
      <span class="t-dot" style="background: #fbbf24"></span>
      <span class="t-dot" style="background: #34d399"></span>
      <span class="terminal-title">~/dotnet-version-manager</span>
    </div>
    <div class="terminal-body">
      <span class="t-line"><span class="t-prompt">$</span> dvm list</span>
      <span class="t-line t-out">  6.0.418   <span class="t-dim">/usr/local/share/dotnet</span></span>
      <span class="t-line t-out">  7.0.405   <span class="t-dim">/usr/local/share/dotnet</span></span>
      <span class="t-line t-out">  8.0.100 <span class="t-active">●</span> <span class="t-dim">(active)</span></span>
      <span class="t-line"><span class="t-prompt">$</span> dvm use 7.0<span class="t-cursor"></span></span>
    </div>
  </div>
)}

{variant === 'cipher-key' && (
  <div class="cover cipher-cover">
    <div class="cipher-grid" aria-hidden="true">
      {cipherCells.map((on) => (
        <span class={`c-cell ${on ? 'c-on' : ''}`}>{on ? '1' : '0'}</span>
      ))}
    </div>
    <div class="cipher-center">
      <svg viewBox="0 0 60 60" width="80" height="80" aria-hidden="true">
        <circle cx="22" cy="30" r="11" fill="none" stroke="#6ee7b7" stroke-width="2.5"/>
        <line x1="33" y1="30" x2="55" y2="30" stroke="#6ee7b7" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="48" y1="30" x2="48" y2="36" stroke="#6ee7b7" stroke-width="2.5" stroke-linecap="round"/>
        <line x1="55" y1="30" x2="55" y2="38" stroke="#6ee7b7" stroke-width="2.5" stroke-linecap="round"/>
        <circle cx="22" cy="30" r="3" fill="#6ee7b7"/>
      </svg>
      <span class="cipher-label">KAPS // ENCRYPT</span>
    </div>
  </div>
)}

{variant === 'password-stream' && (
  <div class="cover password-cover">
    <div class="pw-stream" aria-hidden="true">
      <span class="pw-line">$ apppass generate --length 32 --symbols</span>
      <span class="pw-line pw-out">→ <span class="pw-result">k7@Q.fH9!nM*pZ&amp;3vL+cR%xN8tY^wB</span></span>
      <span class="pw-line pw-meta">[entropy: 188 bits · ✓ strong]</span>
    </div>
    <div class="pw-mask">
      {Array.from({ length: 14 }).map((_, i) => (
        <span class="pw-dot" style={`animation-delay: ${i * 80}ms`}>●</span>
      ))}
    </div>
  </div>
)}

{variant === 'pixel-desktop' && (
  <div class="cover pixel-cover">
    <div class="pixel-window">
      <div class="pixel-bar">
        <span class="pixel-handle"></span>
      </div>
      <div class="pixel-art" aria-hidden="true">
        {pixelCells.map((on) => (
          <span class={`px ${on ? 'px-on' : ''}`}></span>
        ))}
      </div>
      <span class="pixel-label">DESKTOP // ROTATE</span>
    </div>
  </div>
)}

{variant === 'qr-grid' && (
  <div class="cover qr-cover">
    <div class="qr-grid-wrap">
      <div class="qr-grid" aria-hidden="true">
        {qrCells.map((on) => (
          <span class={`qr-cell ${on ? 'qr-on' : ''}`}></span>
        ))}
      </div>
      <span class="qr-label">QR // GENERATE</span>
    </div>
  </div>
)}

{variant === 'code-pointer' && (
  <div class="cover code-cover">
    <div class="code-mock">
      <span class="code-line"><span class="c-keyword">template</span><span class="c-punct">&lt;</span><span class="c-keyword">class</span> <span class="c-type">T</span><span class="c-punct">&gt;</span></span>
      <span class="code-line"><span class="c-keyword">class</span> <span class="c-type">unique_ptr</span> <span class="c-punct">{'{'}</span></span>
      <span class="code-line code-indent">  <span class="c-type">T</span><span class="c-punct">*</span> ptr<span class="c-punct">;</span></span>
      <span class="code-line code-indent">  <span class="c-comment">// owns, never shares</span></span>
      <span class="code-line"><span class="c-punct">{'};'}</span></span>
    </div>
    <div class="code-flair" aria-hidden="true">
      <span class="flair-arrow">→</span>
    </div>
  </div>
)}

{variant === 'default' && (
  <div class="cover default-cover">
    <span class="default-glyph" aria-hidden="true">{name.slice(0, 1)}</span>
    <span class="default-name">{name}</span>
  </div>
)}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,300..900,0..100,0..1&display=swap');

  .cover {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.78rem;
    line-height: 1.5;
    background: rgb(22 30 52);
    color: rgb(187 247 208);
  }

  /* TERMINAL VARIANT */
  .terminal-cover {
    background: linear-gradient(160deg, rgb(18 24 42), rgb(28 38 70));
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 0.85rem;
    background: rgba(0, 0, 0, 0.35);
    border-bottom: 1px solid rgba(187, 247, 208, 0.12);
  }

  .t-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }

  .terminal-title {
    margin-left: 0.85rem;
    color: rgb(187 247 208);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    opacity: 0.7;
  }

  .terminal-body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem 1.1rem;
    color: rgb(248 250 252);
    font-size: 0.82rem;
  }

  .t-prompt {
    color: rgb(110 231 183);
    margin-right: 0.4rem;
  }

  .t-out {
    color: rgb(203 213 225);
  }

  .t-dim {
    color: rgb(148 163 184);
    font-size: 0.74rem;
  }

  .t-active {
    color: rgb(110 231 183);
  }

  .t-cursor {
    display: inline-block;
    width: 0.5rem;
    height: 0.95rem;
    margin-left: 2px;
    background: rgb(110 231 183);
    vertical-align: text-bottom;
    animation: blink 1s steps(2) infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  /* CIPHER VARIANT */
  .cipher-cover {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgb(22 30 56), rgb(34 46 78));
  }

  .cipher-grid {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    grid-template-rows: repeat(6, 1fr);
    padding: 0.5rem;
    color: rgba(187, 247, 208, 0.18);
    font-size: 0.75rem;
    text-align: center;
  }

  .c-on {
    color: rgba(110, 231, 183, 0.85);
  }

  .cipher-center {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.5rem;
    background: rgba(22, 30, 52, 0.7);
    border: 1px solid rgba(110, 231, 183, 0.4);
    border-radius: 6px;
    backdrop-filter: blur(8px);
  }

  .cipher-label {
    color: rgb(110 231 183);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  /* PASSWORD VARIANT */
  .password-cover {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1.2rem;
    background: linear-gradient(155deg, rgb(18 24 42), rgb(38 50 88));
  }

  .pw-stream {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: rgb(203 213 225);
    font-size: 0.78rem;
  }

  .pw-out {
    color: rgb(248 250 252);
  }

  .pw-result {
    color: rgb(110 231 183);
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .pw-meta {
    color: rgb(148 163 184);
    font-size: 0.7rem;
  }

  .pw-mask {
    display: flex;
    gap: 0.3rem;
    margin-top: 0.85rem;
  }

  .pw-dot {
    color: rgb(110 231 183);
    font-size: 0.7rem;
    animation: pwfade 1.4s ease-in-out infinite;
  }

  @keyframes pwfade {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  /* PIXEL VARIANT */
  .pixel-cover {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(120deg, rgb(22 30 52), rgb(34 46 78));
  }

  .pixel-window {
    width: 78%;
    border: 1px solid rgba(187, 247, 208, 0.18);
    border-radius: 4px;
    background: rgba(22, 30, 52, 0.6);
  }

  .pixel-bar {
    height: 16px;
    background: rgba(187, 247, 208, 0.06);
    border-bottom: 1px solid rgba(187, 247, 208, 0.1);
    display: flex;
    align-items: center;
    padding: 0 6px;
  }

  .pixel-handle {
    width: 32px;
    height: 4px;
    background: rgba(187, 247, 208, 0.3);
    border-radius: 2px;
  }

  .pixel-art {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1px;
    padding: 8px;
  }

  .px {
    aspect-ratio: 1;
    background: rgba(187, 247, 208, 0.06);
  }

  .px-on {
    background: rgb(110 231 183);
    box-shadow: 0 0 6px rgba(110, 231, 183, 0.5);
  }

  .pixel-label {
    display: block;
    padding: 0.4rem 0.8rem;
    border-top: 1px solid rgba(187, 247, 208, 0.1);
    color: rgb(110 231 183);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-align: center;
    text-transform: uppercase;
  }

  /* QR VARIANT */
  .qr-cover {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(140deg, rgb(22 30 56), rgb(34 46 78));
  }

  .qr-grid-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem;
    background: rgba(248, 250, 252, 0.96);
    border-radius: 6px;
  }

  .qr-grid {
    display: grid;
    grid-template-columns: repeat(13, 8px);
    grid-template-rows: repeat(13, 8px);
    gap: 0;
  }

  .qr-cell {
    background: transparent;
  }

  .qr-on {
    background: rgb(22 30 52);
  }

  .qr-label {
    color: rgb(22 30 52);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  /* CODE VARIANT */
  .code-cover {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1.5rem 1.7rem;
    background: linear-gradient(155deg, rgb(18 24 42), rgb(20 45 95));
  }

  .code-mock {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    color: rgb(203 213 225);
    font-size: 0.85rem;
  }

  .code-indent {
    padding-left: 0.5rem;
  }

  .c-keyword {
    color: rgb(167 243 208);
  }

  .c-type {
    color: rgb(110 231 183);
    font-weight: 600;
  }

  .c-punct {
    color: rgb(148 163 184);
  }

  .c-comment {
    color: rgb(100 116 139);
    font-style: italic;
  }

  .code-flair {
    position: absolute;
    bottom: 0.8rem;
    right: 1rem;
    color: rgba(110, 231, 183, 0.4);
    font-family: 'Fraunces', Georgia, serif;
    font-size: 3.5rem;
    font-style: italic;
    line-height: 1;
  }

  /* DEFAULT VARIANT */
  .default-cover {
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      linear-gradient(135deg, rgba(110, 231, 183, 0.15), transparent 60%),
      rgb(28 38 70);
  }

  .default-glyph {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 6rem;
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'WONK' 1;
    color: rgba(110, 231, 183, 0.25);
  }

  .default-name {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    color: rgb(187 247 208);
    font-size: 0.74rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
</style>
