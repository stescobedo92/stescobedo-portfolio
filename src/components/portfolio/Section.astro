---
interface Props {
  title?: string;
  titleKey?: string;
  id?: string;
  class?: string;
}

const { title, titleKey, id, class: className = '' } = Astro.props;
---

<section id={id} class={`portfolio-section ${className}`}>
  {title && <h2 class="numbered-heading" data-i18n={titleKey}>{title}</h2>}
  <slot />
</section>

<style>
  .portfolio-section {
    max-width: 1100px;
    margin: 0 auto 7rem;
    scroll-margin-top: 7rem;
  }

  .numbered-heading {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    margin: 0 0 2.5rem;
    color: rgb(248 250 252);
    font-size: clamp(1.6rem, 4vw, 2rem);
    font-weight: 700;
    line-height: 1.15;
    white-space: nowrap;
  }

  :global(html:not(.dark)) .numbered-heading {
    color: rgb(22 30 52);
  }

  .numbered-heading::before {
    counter-increment: section;
    content: '0' counter(section) '.';
    color: rgb(52 211 153);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: clamp(1rem, 2vw, 1.15rem);
    font-weight: 500;
  }

  .numbered-heading::after {
    content: '';
    height: 1px;
    flex: 1;
    max-width: 320px;
    background: rgb(48 62 98);
  }

  :global(html:not(.dark)) .numbered-heading::after {
    background: rgb(203 213 225);
  }

  @media (max-width: 640px) {
    .portfolio-section {
      margin-bottom: 5rem;
    }

    .numbered-heading {
      white-space: normal;
    }
  }
</style>
