---
import Section from './Section.astro';
import Icon from './Icon.astro';

interface Post {
  slug: string;
  data: {
    title: string;
    description: string;
    pubDate: Date;
    category: string;
    readingTime: number;
  };
}

const { posts = [] } = Astro.props as { posts: Post[] };

const rawBase = import.meta.env.BASE_URL || '/';
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, '')}`;

const pad2 = (n: number) => String(n).padStart(2, '0');
const monthShort = (d: Date) => d.toLocaleDateString('en-US', { month: 'short' });
const dayPad = (d: Date) => String(d.getDate()).padStart(2, '0');
const yearOf = (d: Date) => d.getFullYear();

// Filename from slug
const filenameOf = (slug: string) => `${slug}.mdx`;
---

{posts.length > 0 && (
  <Section title="Posts" titleKey="sections.posts" id="posts">
    <p class="posts-eyebrow">
      <span class="dash" aria-hidden="true"></span>
      cd ~/blog · ls --recent
      <span class="dash" aria-hidden="true"></span>
    </p>

    <div class="terminal">
      <div class="term-bar">
        <span class="term-dot" style="background: #fb7185"></span>
        <span class="term-dot" style="background: #fbbf24"></span>
        <span class="term-dot" style="background: #34d399"></span>
        <span class="term-title">stescobedo@journal: ~/blog</span>
        <a class="term-tab" href={withBase('blog')} aria-label="View all entries">
          ls -la --all
          <Icon name="arrow-right" class="h-3 w-3" />
        </a>
      </div>

      <div class="term-body">
        <p class="prompt">
          <span class="user">stescobedo</span><span class="host">@journal</span>
          <span class="path">~/blog</span>
          <span class="dollar">$</span>
          <span class="cmd">ls</span>
          <span class="flag">--recent</span>
        </p>

        <p class="totals">total {posts.length}</p>

        <ol class="entries">
          {posts.map((post, idx) => (
            <li class="entry" style={`--delay: ${idx * 70}ms`}>
              <a href={withBase(`blog/${post.slug}`)} class="entry-link">
                <span class="perm">-rw-r--r--</span>
                <span class="num">{pad2(idx + 1)}</span>
                <span class="owner">stescobedo</span>
                <span class="size">{post.data.readingTime}m</span>
                <span class="date">
                  <span class="d-mon">{monthShort(post.data.pubDate)}</span>
                  <span class="d-day">{dayPad(post.data.pubDate)}</span>
                  <span class="d-year">{yearOf(post.data.pubDate)}</span>
                </span>
                <span class="filename">
                  <span class="file-tag">[{post.data.category}]</span>
                  {filenameOf(post.slug)}
                </span>
                <span class="entry-title-line">
                  <span class="comment-mark">→</span>
                  <span class="entry-title">{post.data.title}</span>
                </span>
              </a>
            </li>
          ))}
        </ol>

        <p class="prompt prompt-active">
          <span class="user">stescobedo</span><span class="host">@journal</span>
          <span class="path">~/blog</span>
          <span class="dollar">$</span>
          <span class="cursor" aria-hidden="true"></span>
        </p>
      </div>
    </div>

    <div class="posts-foot">
      <a class="posts-archive" href={withBase('blog')}>
        <span data-i18n="posts.archive">cat all-entries</span>
        <Icon name="arrow-right" class="h-3 w-3" />
      </a>
    </div>
  </Section>
)}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,300..900,0..100,0..1&display=swap');

  .posts-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin: -1rem 0 2rem;
    color: rgb(110 231 183);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .posts-eyebrow .dash {
    width: 36px;
    height: 1px;
    background: currentColor;
    opacity: 0.6;
  }

  /* TERMINAL */
  .terminal {
    border: 1px solid rgba(187, 247, 208, 0.16);
    border-radius: 12px;
    background:
      linear-gradient(160deg, rgba(34, 46, 78, 0.4), rgba(22, 30, 52, 0.7));
    overflow: hidden;
    backdrop-filter: blur(8px);
    box-shadow: 0 24px 60px rgba(4, 12, 32, 0.32);
  }

  .term-bar {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.7rem 1rem;
    background: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid rgba(187, 247, 208, 0.1);
  }

  .term-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }

  .term-title {
    flex: 1;
    margin-left: 0.85rem;
    color: rgba(187, 247, 208, 0.65);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
  }

  .term-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.7rem;
    border: 1px solid rgba(110, 231, 183, 0.3);
    border-radius: 6px;
    background: rgba(110, 231, 183, 0.06);
    color: rgb(187 247 208);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: color 220ms ease, border-color 220ms ease, transform 220ms ease;
  }

  .term-tab:hover {
    color: rgb(110 231 183);
    border-color: rgb(110 231 183);
    transform: translateX(3px);
  }

  .term-body {
    padding: 1.4rem 1.5rem 1.6rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.86rem;
    line-height: 1.7;
  }

  .prompt {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    margin: 0 0 0.6rem;
    color: rgb(187 247 208);
  }

  .user {
    color: rgb(110 231 183);
  }

  .host {
    color: rgba(187, 247, 208, 0.7);
  }

  .path {
    color: rgb(167 243 208);
  }

  .dollar {
    color: rgb(110 231 183);
    font-weight: 700;
  }

  .cmd {
    color: rgb(248 250 252);
  }

  .flag {
    color: rgba(187, 247, 208, 0.7);
    font-style: italic;
  }

  .totals {
    margin: 0 0 0.85rem;
    color: rgba(187, 247, 208, 0.45);
    font-style: italic;
  }

  /* ENTRIES */
  .entries {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin-bottom: 1rem;
  }

  .entry {
    animation: rise 540ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
    animation-delay: var(--delay);
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .entry-link {
    display: grid;
    grid-template-columns: max-content max-content max-content max-content max-content 1fr;
    grid-template-rows: auto auto;
    grid-template-areas:
      'perm num owner size date filename'
      '. . . . . title';
    gap: 0.05rem 0.85rem;
    padding: 0.45rem 0.65rem;
    border-radius: 6px;
    color: inherit;
    text-decoration: none;
    transition: background-color 200ms ease;
  }

  .entry-link:hover,
  .entry-link:focus-visible {
    background: rgba(110, 231, 183, 0.08);
    outline: none;
  }

  .perm {
    grid-area: perm;
    color: rgba(187, 247, 208, 0.55);
  }

  .entry .num {
    grid-area: num;
    color: rgba(110, 231, 183, 0.55);
  }

  .owner {
    grid-area: owner;
    color: rgba(187, 247, 208, 0.6);
  }

  .size {
    grid-area: size;
    color: rgb(167 243 208);
    font-weight: 600;
  }

  .date {
    grid-area: date;
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
    color: rgba(187, 247, 208, 0.7);
  }

  .d-day {
    color: rgb(248 250 252);
  }

  .d-year {
    color: rgba(187, 247, 208, 0.4);
    font-size: 0.78em;
  }

  .filename {
    grid-area: filename;
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    color: rgb(110 231 183);
    font-weight: 600;
    transition: color 240ms ease;
  }

  .entry-link:hover .filename {
    color: rgb(167 243 208);
  }

  .file-tag {
    color: rgba(110, 231, 183, 0.6);
    font-weight: 400;
    font-style: italic;
    font-size: 0.85em;
  }

  /* Title (subtitle line under filename) */
  .entry-title-line {
    grid-area: title;
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    padding-left: 0.2rem;
    margin-top: -0.1rem;
  }

  .comment-mark {
    color: rgba(110, 231, 183, 0.5);
  }

  .entry-title {
    color: rgb(187 247 208);
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1rem;
    font-style: italic;
    font-weight: 400;
    font-variation-settings: 'opsz' 144;
    letter-spacing: -0.005em;
    transition: color 240ms ease;
  }

  .entry-link:hover .entry-title {
    color: rgb(248 250 252);
  }

  /* ACTIVE PROMPT (bottom) */
  .prompt-active {
    margin-bottom: 0;
    margin-top: 0.85rem;
  }

  .cursor {
    display: inline-block;
    width: 0.55rem;
    height: 1rem;
    background: rgb(110 231 183);
    vertical-align: middle;
    animation: blink 1.1s steps(2) infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  /* FOOT */
  .posts-foot {
    display: flex;
    justify-content: flex-end;
    margin-top: 1.25rem;
  }

  .posts-archive {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgb(110 231 183);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 220ms ease, transform 220ms ease;
  }

  .posts-archive:hover {
    color: rgb(167 243 208);
    transform: translateX(4px);
  }

  /* ═══════════════════════  LIGHT MODE  ═══════════════════════ */
  :global(html:not(.dark)) .posts-eyebrow,
  :global(html:not(.dark)) .posts-eyebrow .dash {
    color: rgb(5 150 105);
  }

  :global(html:not(.dark)) .terminal {
    background: rgb(255 255 255);
    border-color: rgb(226 232 240);
    box-shadow: 0 12px 36px rgba(15, 23, 42, 0.06);
  }

  :global(html:not(.dark)) .term-bar {
    background: rgb(248 250 252);
    border-bottom-color: rgb(226 232 240);
  }

  :global(html:not(.dark)) .term-title {
    color: rgb(71 85 105);
  }

  :global(html:not(.dark)) .term-tab {
    color: rgb(15 118 110);
    border-color: rgb(167 243 208);
  }

  :global(html:not(.dark)) .term-tab:hover {
    color: rgb(5 150 105);
    border-color: rgb(5 150 105);
    background: rgba(16, 185, 129, 0.06);
  }

  :global(html:not(.dark)) .term-body {
    color: rgb(15 23 42);
  }

  /* prompt tokens */
  :global(html:not(.dark)) .prompt .user { color: rgb(5 150 105); }
  :global(html:not(.dark)) .prompt .host { color: rgb(15 118 110); }
  :global(html:not(.dark)) .prompt .path { color: rgb(180 83 9); }
  :global(html:not(.dark)) .prompt .dollar { color: rgb(5 150 105); }
  :global(html:not(.dark)) .prompt .cmd { color: rgb(124 58 237); }
  :global(html:not(.dark)) .prompt .flag { color: rgb(180 83 9); }
  :global(html:not(.dark)) .totals { color: rgb(100 116 139); }

  /* ls -la columns */
  :global(html:not(.dark)) .perm { color: rgb(100 116 139); }
  :global(html:not(.dark)) .entry .num { color: rgb(15 118 110); }
  :global(html:not(.dark)) .owner { color: rgb(15 118 110); }
  :global(html:not(.dark)) .size { color: rgb(180 83 9); }
  :global(html:not(.dark)) .date,
  :global(html:not(.dark)) .d-mon,
  :global(html:not(.dark)) .d-day,
  :global(html:not(.dark)) .d-year { color: rgb(71 85 105); }
  :global(html:not(.dark)) .filename { color: rgb(15 23 42); }
  :global(html:not(.dark)) .file-tag { color: rgb(5 150 105); }
  :global(html:not(.dark)) .comment-mark { color: rgb(5 150 105); }
  :global(html:not(.dark)) .entry-title { color: rgb(15 23 42); }
  :global(html:not(.dark)) .entry-link:hover .entry-title { color: rgb(5 150 105); }
  :global(html:not(.dark)) .cursor { background: rgb(5 150 105); }

  /* footer link */
  :global(html:not(.dark)) .posts-archive {
    color: rgb(5 150 105);
  }
  :global(html:not(.dark)) .posts-archive:hover {
    color: rgb(15 118 110);
  }

  /* RESPONSIVE */
  @media (max-width: 800px) {
    .term-body {
      font-size: 0.78rem;
    }
    .entry-link {
      grid-template-columns: max-content max-content max-content max-content;
      grid-template-areas:
        'perm num size date'
        'filename filename filename filename'
        'title title title title';
      gap: 0.1rem 0.65rem;
    }
    .owner {
      display: none;
    }
  }

  @media (max-width: 540px) {
    .perm,
    .entry .num {
      display: none;
    }
    .entry-link {
      grid-template-columns: max-content 1fr;
      grid-template-areas:
        'size date'
        'filename filename'
        'title title';
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .entry,
    .cursor {
      animation: none;
    }
  }
</style>
