---
import TypedText from './TypedText.astro';
import Icon from './Icon.astro';
import { profile, primarySkills } from '../../data/portfolio';

const rawBase = import.meta.env.BASE_URL || '/';
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, '')}`;

const firstName = profile.name.split(' ')[0];
const lastNames = profile.name.split(' ').slice(1).join(' ');

// Map socials to icon names (used for portrait-topbar)
const iconByNetwork = {
  GitHub: 'github',
  LinkedIn: 'linkedin',
  StackOverflow: 'stackoverflow',
  X: 'x',
} as const;

// Stack matrix: 14 columns × 10 rows = 140 cells. JS picks random cells to
// materialize a skill icon from skillicons.dev for ~3 seconds.
const MATRIX_COLS = 14;
const MATRIX_ROWS = 10;
const matrixCells = Array.from({ length: MATRIX_COLS * MATRIX_ROWS }, (_, i) => i);
const skillIcons = primarySkills.map((s) => s.icon);
---

<section class="hero" aria-label="Intro" id="hero">
  <a id="about" class="anchor-alias" aria-hidden="true"></a>
  <!-- Animated grid background + live stack matrix -->
  <div class="hero-bg" aria-hidden="true">
    <div class="grid"></div>
    <div class="aurora aurora-1"></div>
    <div class="aurora aurora-2"></div>
    <div
      class="skill-matrix"
      id="skill-matrix"
      data-cols={MATRIX_COLS}
      data-rows={MATRIX_ROWS}
      data-skills={skillIcons.join(',')}
    >
      {matrixCells.map((i) => (
        <span class="skill-cell" data-cell-index={i}></span>
      ))}
    </div>
    <div class="cursor-glow" id="cursor-glow"></div>
  </div>

  <!-- Status bar -->
  <div class="status-bar">
    <span class="status-cell">
      <span class="status-dot live" aria-hidden="true"></span>
      <span class="status-key">Status</span>
      <span class="status-val">Available for hire</span>
    </span>
    <span class="status-sep" aria-hidden="true"></span>
    <span class="status-cell">
      <span class="status-key">Now</span>
      <span class="status-val">Building backend services</span>
    </span>
    <span class="status-sep" aria-hidden="true"></span>
    <span class="status-cell">
      <span class="status-key">Time</span>
      <span class="status-val" id="hero-time">—</span>
    </span>
  </div>

  <div class="hero-grid">
    <!-- LEFT: code object -->
    <div class="hero-copy">
      <p class="greeting">
        <span class="greet-line"></span>
        <span>const developer = </span>
        <span class="greet-symbol">{`{`}</span>
      </p>

      <h1 class="display-name">
        <span class="name-text">{profile.name}<span class="name-period">.</span></span>
      </h1>

      <h2 class="motto" data-github-bio>
        <TypedText text={profile.motto} speed={35} delay={500} />
      </h2>

      <ul class="props" aria-label="Profile properties">
        <li>
          <span class="prop-key">role:</span>
          <span class="prop-val str">"{profile.label}"</span>
          <span class="prop-comma">,</span>
        </li>
        <li>
          <span class="prop-key">location:</span>
          <span class="prop-val str">"{profile.location}"</span>
          <span class="prop-comma">,</span>
        </li>
        <li>
          <span class="prop-key">experience:</span>
          <span class="prop-val num">8</span>
          <span class="prop-op">+</span>
          <span class="prop-comment">// years</span>
          <span class="prop-comma">,</span>
        </li>
        <li>
          <span class="prop-key">repos:</span>
          <span class="prop-val num" data-repo-count>—</span>
          <span class="prop-comment">// public on github</span>
          <span class="prop-comma">,</span>
        </li>
        <li>
          <span class="prop-key">exploring:</span>
          <span class="prop-val str">"<TypedText texts={profile.passionItems} speed={65} delay={1200} loop />"</span>
          <span class="prop-comma">,</span>
        </li>
      </ul>

      <p class="closing-bracket" aria-hidden="true">{`}`}</p>

      <div class="actions">
        <a class="cta primary" href={`mailto:${profile.email}`}>
          <span class="cta-label">
            <Icon name="send" class="h-4 w-4" />
            Get in touch
          </span>
          <span class="cta-glow" aria-hidden="true"></span>
        </a>
        <a class="cta secondary" href={withBase('Sergio_Triana_Escobedo_CV.pdf')} download>
          <span class="cta-label">
            <Icon name="download" class="h-4 w-4" />
            Resume / CV
          </span>
        </a>
        <a class="cta ghost" href="#projects">
          <span class="cta-label">
            See work
            <Icon name="arrow-right" class="h-4 w-4" />
          </span>
        </a>
      </div>
    </div>

    <!-- RIGHT: portrait card -->
    <aside class="portrait-card" aria-label="Portrait" id="portrait-card">
      <span class="portrait-prop" aria-hidden="true">portrait:</span>

      <figure class="portrait-frame">
        <span class="portrait-corner tl" aria-hidden="true"></span>
        <span class="portrait-corner tr" aria-hidden="true"></span>
        <span class="portrait-corner bl" aria-hidden="true"></span>
        <span class="portrait-corner br" aria-hidden="true"></span>

        <div class="portrait-topbar">
          <span class="portrait-tag">SUBJECT · 01</span>
          <ul class="portrait-socials" aria-label="Social channels">
            {profile.socials.map((s) => (
              <li>
                <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.network}>
                  <Icon name={iconByNetwork[s.network] ?? 'github'} class="h-3 w-3" />
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="portrait-photo">
          <img
            src={profile.image}
            alt={profile.name}
            width="420"
            height="420"
            loading="eager"
            data-github-avatar
          />
          <span class="portrait-scanline" aria-hidden="true"></span>
          <span class="portrait-rec" aria-hidden="true">
            <span class="rec-dot"></span>
            <span class="rec-text">REC</span>
          </span>
          <span class="portrait-grid-overlay" aria-hidden="true"></span>
        </div>

        <figcaption class="portrait-caption">
          <span class="cap-line">
            <span class="cap-key">name:</span>
            <span class="cap-val">"{profile.name}"</span>
          </span>
          <span class="cap-line">
            <span class="cap-key">role:</span>
            <span class="cap-val">"{profile.label}"</span>
          </span>
          <span class="cap-line">
            <span class="cap-key">from:</span>
            <span class="cap-val">"{profile.location}"</span>
          </span>
        </figcaption>
      </figure>
    </aside>
  </div>

  <!-- Bottom marquee strip -->
  <div class="bottom-strip" aria-hidden="true">
    <span class="strip-eyebrow">Currently exploring</span>
    <div class="strip-marquee">
      <ul class="strip-track">
        {[...profile.passionItems, ...profile.passionItems].map((item) => (
          <li>
            <span class="strip-bullet">◇</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Scroll hint -->
  <a class="scroll-hint" href="#about" aria-label="Scroll to About">
    <span class="hint-line" aria-hidden="true"></span>
    <span class="hint-label">scroll</span>
  </a>
</section>

<script>
  const initializeHero = () => {
    const hero = document.getElementById('hero');
    if (!hero || (hero as any).dataset.ready === 'true') return;
    (hero as any).dataset.ready = 'true';

    // Mouse-tracked cursor glow + 3D parallax tilt on the portrait card
    const glow = document.getElementById('cursor-glow');
    const portraitCard = document.getElementById('portrait-card');
    const onMove = (e: MouseEvent) => {
      const rect = hero.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      if (glow) {
        glow.style.transform = `translate(${x - 200}px, ${y - 200}px)`;
        glow.style.opacity = '1';
      }
      if (portraitCard) {
        const nx = (x / rect.width - 0.5) * 2;  // -1..1
        const ny = (y / rect.height - 0.5) * 2; // -1..1
        portraitCard.style.setProperty('--tilt-y', `${nx * 6}deg`);
        portraitCard.style.setProperty('--tilt-x', `${-ny * 5}deg`);
        portraitCard.style.setProperty('--shift-x', `${nx * 4}px`);
        portraitCard.style.setProperty('--shift-y', `${-ny * 4}px`);
      }
    };
    const onLeave = () => {
      if (glow) glow.style.opacity = '0';
      if (portraitCard) {
        portraitCard.style.setProperty('--tilt-x', '0deg');
        portraitCard.style.setProperty('--tilt-y', '0deg');
        portraitCard.style.setProperty('--shift-x', '0px');
        portraitCard.style.setProperty('--shift-y', '0px');
      }
    };
    hero.addEventListener('mousemove', onMove);
    hero.addEventListener('mouseleave', onLeave);

    // ── Stack matrix: random skill icons materialize and dissolve ──
    const matrix = document.getElementById('skill-matrix');
    if (matrix && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const skills = (matrix.dataset.skills || '').split(',').filter(Boolean);
      const cells = Array.from(matrix.querySelectorAll<HTMLElement>('.skill-cell'));
      const html = document.documentElement;
      const isDark = () => html.classList.contains('dark');
      const iconUrl = (name: string, dark: boolean) =>
        `https://skillicons.dev/icons?i=${name}&theme=${dark ? 'dark' : 'light'}`;

      type Active = { skill: string; img: HTMLImageElement };
      const active = new Map<HTMLElement, Active>();
      const MAX_ACTIVE = 5;
      const HOLD_MIN = 2200;
      const HOLD_MAX = 4200;
      const FADE_OUT = 700;

      // Pre-warm the cache by hitting each icon URL once for the current theme
      const preload = (dark: boolean) => {
        skills.forEach((s) => {
          const img = new Image();
          img.src = iconUrl(s, dark);
        });
      };
      preload(isDark());

      const releaseCell = (cell: HTMLElement) => {
        const entry = active.get(cell);
        if (!entry) return;
        cell.classList.remove('is-active');
        window.setTimeout(() => {
          entry.img.remove();
          active.delete(cell);
        }, FADE_OUT);
      };

      const activateRandom = () => {
        if (active.size >= MAX_ACTIVE) return;
        const free = cells.filter((c) => !active.has(c));
        if (free.length === 0 || skills.length === 0) return;
        const cell = free[Math.floor(Math.random() * free.length)];
        const skill = skills[Math.floor(Math.random() * skills.length)];
        const img = document.createElement('img');
        img.src = iconUrl(skill, isDark());
        img.alt = '';
        img.loading = 'lazy';
        img.decoding = 'async';
        img.dataset.skill = skill;
        cell.appendChild(img);
        // Force reflow then add the active class for the fade-in to play
        void cell.offsetWidth;
        cell.classList.add('is-active');
        active.set(cell, { skill, img });
        const hold = HOLD_MIN + Math.random() * (HOLD_MAX - HOLD_MIN);
        window.setTimeout(() => releaseCell(cell), hold);
      };

      // Cadence: a new icon every 320–620ms
      let timer: number;
      const schedule = () => {
        activateRandom();
        timer = window.setTimeout(schedule, 320 + Math.random() * 300);
      };
      schedule();

      // Re-fetch active icons when the theme toggles
      const themeObserver = new MutationObserver(() => {
        const dark = isDark();
        active.forEach(({ img, skill }) => {
          img.src = iconUrl(skill, dark);
        });
      });
      themeObserver.observe(html, { attributes: true, attributeFilter: ['class'] });
    }

    // Live time clock
    const timeEl = document.getElementById('hero-time');
    if (timeEl) {
      const updateTime = () => {
        const now = new Date();
        const time = now.toLocaleTimeString('en-US', {
          hour: '2-digit',
          minute: '2-digit',
          hour12: false,
          timeZone: 'America/Mexico_City',
        });
        timeEl.textContent = `${time} GMT-5`;
      };
      updateTime();
      window.setInterval(updateTime, 30000);
    }

    // GitHub profile hydration: avatar + bio + public_repos count
    (async () => {
      const avatar = document.querySelector('[data-github-avatar]') as HTMLImageElement | null;
      const repoCountEl = document.querySelector('[data-repo-count]');
      const bioEl = document.querySelector('[data-github-bio]');
      const username = 'stescobedo92';
      try {
        const response = await fetch(`https://api.github.com/users/${username}`, {
          cache: 'no-store',
          headers: { Accept: 'application/vnd.github+json' },
        });
        if (!response.ok) return;
        const data = await response.json();
        if (avatar && data.avatar_url) {
          avatar.src = `${data.avatar_url}${data.avatar_url.includes('?') ? '&' : '?'}s=420`;
        }
        if (repoCountEl && typeof data.public_repos === 'number') {
          repoCountEl.textContent = String(data.public_repos);
        }
        // Bio is optional; only update if GitHub returns one
        if (bioEl && data.bio) {
          // Keep the styled motto markup; only update plain text content if no children other than text
          if (bioEl.children.length === 0) bioEl.textContent = data.bio;
        }
      } catch {
        // Keep static fallback
      }
    })();
  };

  document.addEventListener('astro:page-load', initializeHero);
  initializeHero();
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,300..900,0..100,0..1&display=swap');

  .hero {
    position: relative;
    min-height: calc(100vh - 5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
    margin: 0 0 4rem;
    padding: 5.5rem 0 4rem;
    scroll-margin-top: 6rem;
    overflow: hidden;
  }

  .anchor-alias {
    position: absolute;
    top: -5rem;
    height: 1px;
    width: 1px;
    pointer-events: none;
  }

  /* TWO-COLUMN GRID */
  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(240px, 0.75fr);
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: start;
    width: 100%;
    max-width: 1240px;
    margin: 2rem auto 0;
  }

  /* PROPS LIST — code object body */
  .props {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    margin: 0.85rem 0 0.4rem;
    padding: 0 0 0 1.25rem;
    list-style: none;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .props li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.55rem;
  }

  .prop-key {
    color: rgb(110 231 183);
    flex-shrink: 0;
  }

  .prop-val {
    color: rgb(248 250 252);
  }

  .prop-val.str {
    color: rgb(187 247 208);
  }

  .prop-val.num {
    color: rgb(167 243 208);
    font-weight: 600;
  }

  .prop-op {
    color: rgb(110 231 183);
  }

  .prop-comma {
    color: rgba(187, 247, 208, 0.4);
  }

  .prop-comment {
    color: rgba(187, 247, 208, 0.4);
    font-style: italic;
  }

  /* PORTRAIT CARD */
  .portrait-card {
    position: relative;
    padding-top: 2rem;
    max-width: 280px;
    justify-self: start;
    width: 100%;
  }

  .portrait-prop {
    position: absolute;
    top: 0;
    left: 0;
    color: rgb(110 231 183);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.92rem;
  }

  /* 3D tilt is driven by JS via custom properties — see initializeHero() */
  .portrait-card {
    --tilt-x: 0deg;
    --tilt-y: 0deg;
    --shift-x: 0px;
    --shift-y: 0px;
    perspective: 900px;
    perspective-origin: 50% 30%;
  }

  .portrait-frame {
    position: relative;
    width: 100%;
    margin: 0;
    padding: 1rem;
    border: 1px solid rgba(187, 247, 208, 0.18);
    background: rgba(34, 46, 78, 0.7);
    backdrop-filter: blur(10px);
    transform:
      rotateX(var(--tilt-x))
      rotateY(var(--tilt-y))
      translate3d(var(--shift-x), var(--shift-y), 0);
    transform-style: preserve-3d;
    transition: transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1), border-color 280ms ease, box-shadow 320ms ease;
    box-shadow: 0 18px 48px rgba(4, 12, 32, 0.4);
  }

  .portrait-frame:hover {
    border-color: rgba(110, 231, 183, 0.55);
    box-shadow: 0 32px 80px rgba(4, 12, 32, 0.55);
  }

  .portrait-corner {
    position: absolute;
    width: 14px;
    height: 14px;
    border: 2px solid rgb(110 231 183);
    z-index: 2;
  }
  .portrait-corner.tl { top: -2px; left: -2px; border-right: 0; border-bottom: 0; }
  .portrait-corner.tr { top: -2px; right: -2px; border-left: 0; border-bottom: 0; }
  .portrait-corner.bl { bottom: -2px; left: -2px; border-right: 0; border-top: 0; }
  .portrait-corner.br { bottom: -2px; right: -2px; border-left: 0; border-top: 0; }

  .portrait-topbar {
    position: absolute;
    top: -10px;
    left: 1rem;
    right: 1rem;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }

  .portrait-tag {
    padding: 0.18rem 0.55rem;
    background: rgb(28 38 70);
    color: rgb(110 231 183);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .portrait-socials {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin: 0;
    padding: 0.18rem 0.4rem;
    background: rgb(28 38 70);
    list-style: none;
  }

  .portrait-socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    color: rgb(187 247 208);
    transition: color 180ms ease, transform 180ms ease;
  }

  .portrait-socials a:hover,
  .portrait-socials a:focus-visible {
    color: rgb(110 231 183);
    transform: translateY(-1px);
    outline: none;
  }

  /* PORTRAIT PHOTO + CRT-STYLE OVERLAYS */
  .portrait-photo {
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .portrait-photo img {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    filter: saturate(0.78) contrast(1.05);
    transition: filter 320ms ease, transform 480ms ease;
    will-change: filter;
  }

  .portrait-frame:hover .portrait-photo img {
    filter: saturate(1) contrast(1);
    transform: scale(1.015);
  }

  /* horizontal scan-line that drifts down the photo */
  .portrait-scanline {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background:
      linear-gradient(
        180deg,
        transparent 0%,
        rgba(110, 231, 183, 0.28) 48%,
        rgba(167, 243, 208, 0.6) 50%,
        rgba(110, 231, 183, 0.28) 52%,
        transparent 100%
      );
    background-size: 100% 18%;
    background-repeat: no-repeat;
    background-position: 0% -20%;
    mix-blend-mode: screen;
    animation: scanline-sweep 4.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    opacity: 0.6;
  }

  @keyframes scanline-sweep {
    0%   { background-position: 0% -20%;  opacity: 0; }
    8%   { opacity: 0.65; }
    50%  { background-position: 0% 110%;  opacity: 0.55; }
    52%  { opacity: 0; }
    100% { background-position: 0% 110%;  opacity: 0; }
  }

  /* faint scanline texture (always on) */
  .portrait-photo::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      repeating-linear-gradient(
        180deg,
        rgba(13, 22, 42, 0.0) 0px,
        rgba(13, 22, 42, 0.0) 2px,
        rgba(13, 22, 42, 0.18) 3px,
        rgba(13, 22, 42, 0.0) 4px
      );
    mix-blend-mode: multiply;
    opacity: 0.35;
  }

  /* live REC indicator */
  .portrait-rec {
    position: absolute;
    top: 0.55rem;
    right: 0.55rem;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
    padding: 0.18rem 0.45rem;
    border: 1px solid rgba(252, 165, 165, 0.65);
    border-radius: 999px;
    background: rgba(13, 22, 42, 0.78);
    backdrop-filter: blur(4px);
    color: rgb(252 165 165);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .rec-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgb(248 113 113);
    box-shadow: 0 0 0 0 rgba(248, 113, 113, 0.6);
    animation: rec-pulse 1.6s ease-out infinite;
  }

  @keyframes rec-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(248, 113, 113, 0.7); }
    70%  { box-shadow: 0 0 0 7px rgba(248, 113, 113, 0); }
    100% { box-shadow: 0 0 0 0 rgba(248, 113, 113, 0); }
  }

  /* very faint grid overlay on the photo (cell hint) */
  .portrait-grid-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background-image:
      linear-gradient(rgba(110, 231, 183, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(110, 231, 183, 0.06) 1px, transparent 1px);
    background-size: 24px 24px;
    mix-blend-mode: screen;
    opacity: 0.55;
  }

  .portrait-caption {
    display: grid;
    gap: 0.4rem;
    margin: 1rem 0 0;
    padding-top: 1rem;
    border-top: 1px dashed rgba(187, 247, 208, 0.22);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.78rem;
  }

  .cap-line {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    min-width: 0;
  }

  .cap-key {
    color: rgb(110 231 183);
    width: 3.4rem;
    flex-shrink: 0;
  }

  .cap-val {
    color: rgb(187 247 208);
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
    hyphens: auto;
  }

  /* ANIMATED BACKGROUND */
  .hero-bg {
    position: absolute;
