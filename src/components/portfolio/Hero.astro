---
import TypedText from './TypedText.astro';
import Icon from './Icon.astro';
import { profile } from '../../data/portfolio';
import { getUserProfile } from '../../lib/github';

const rawBase = import.meta.env.BASE_URL || '/';
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, '')}`;

const firstName = profile.name.split(' ')[0];
const lastNames = profile.name.split(' ').slice(1).join(' ');
const githubProfile = await getUserProfile(profile.githubUsername, {
  knownPrivateRepos: profile.githubPrivateRepoCount,
  totalReposFallback: profile.githubTotalRepoCount,
});
const avatarUrl = githubProfile.avatarUrl
  ? `${githubProfile.avatarUrl}${githubProfile.avatarUrl.includes('?') ? '&' : '?'}s=420`
  : profile.image;

// Map socials to icon names (used for portrait-topbar)
const iconByNetwork = {
  GitHub: 'github',
  LinkedIn: 'linkedin',
  StackOverflow: 'stackoverflow',
  X: 'x',
} as const;
---

<section class="hero" aria-label="Intro" id="hero">
  <a id="about" class="anchor-alias" aria-hidden="true"></a>
  <!-- Animated grid background + falling code-rain canvas -->
  <div class="hero-bg" aria-hidden="true">
    <div class="grid"></div>
    <div class="aurora aurora-1"></div>
    <div class="aurora aurora-2"></div>
    <canvas class="code-rain" id="code-rain"></canvas>
    <div class="cursor-glow" id="cursor-glow"></div>
  </div>

  <!-- Status bar -->
  <div class="status-bar">
    <span class="status-cell">
      <span class="status-dot live" aria-hidden="true"></span>
      <span class="status-key" data-i18n="hero.status">Status</span>
      <span class="status-val" data-i18n="hero.available">Available for hire</span>
    </span>
    <span class="status-sep" aria-hidden="true"></span>
    <span class="status-cell">
      <span class="status-key" data-i18n="hero.now">Now</span>
      <span class="status-val" data-i18n="hero.building">Building backend services</span>
    </span>
    <span class="status-sep" aria-hidden="true"></span>
    <span class="status-cell">
      <span class="status-key" data-i18n="hero.time">Time</span>
      <span class="status-val" id="hero-time">—</span>
    </span>
  </div>

  <div class="hero-grid">
    <!-- LEFT: code object -->
    <div class="hero-copy">
      <p class="greeting">
        <span class="greet-line"></span>
        <span>const developer = </span>
        <span class="greet-symbol">{`{`}</span>
      </p>

      <h1 class="display-name">
        <span class="name-text">{profile.name}<span class="name-period">.</span></span>
      </h1>

      <h2 class="motto" data-github-bio>
        <TypedText text={profile.motto} speed={35} delay={500} />
      </h2>

      <ul class="props" aria-label="Profile properties">
        <li>
          <span class="prop-key">role:</span>
          <span class="prop-val str">"{profile.label}"</span>
          <span class="prop-comma">,</span>
        </li>
        <li>
          <span class="prop-key">location:</span>
          <span class="prop-val str">"{profile.location}"</span>
          <span class="prop-comma">,</span>
        </li>
        <li>
          <span class="prop-key">experience:</span>
          <span class="prop-val num">8</span>
          <span class="prop-op">+</span>
          <span class="prop-comment" data-i18n="hero.roleComment">// years</span>
          <span class="prop-comma">,</span>
        </li>
        <li>
          <span class="prop-key">repos:</span>
          <span class="prop-val num" data-repo-count>{githubProfile.totalRepos ?? '—'}</span>
          <span class="prop-comment" data-i18n="hero.reposComment">// public on github</span>
          <span class="prop-comma">,</span>
        </li>
        <li>
          <span class="prop-key">exploring:</span>
          <span class="prop-val str">"<TypedText texts={profile.passionItems} speed={65} delay={1200} loop />"</span>
          <span class="prop-comma">,</span>
        </li>
      </ul>

      <p class="closing-bracket" aria-hidden="true">{`}`}</p>

      <div class="actions">
        <a class="cta primary" href={`mailto:${profile.email}`}>
          <span class="cta-label">
            <Icon name="send" class="h-4 w-4" />
            <span data-i18n="hero.contact">Get in touch</span>
          </span>
          <span class="cta-glow" aria-hidden="true"></span>
        </a>
        <a class="cta secondary" href={withBase('Sergio_Triana_Escobedo_CV.pdf')} download>
          <span class="cta-label">
            <Icon name="download" class="h-4 w-4" />
            <span data-i18n="hero.resume">Resume / CV</span>
          </span>
        </a>
        <a class="cta ghost" href="#projects">
          <span class="cta-label">
            <span data-i18n="hero.seeWork">See work</span>
            <Icon name="arrow-right" class="h-4 w-4" />
          </span>
        </a>
      </div>
    </div>

    <!-- RIGHT: portrait card -->
    <aside class="portrait-card" aria-label="Portrait" id="portrait-card">
      <span class="portrait-prop" aria-hidden="true">portrait:</span>

      <figure class="portrait-frame">
        <span class="portrait-corner tl" aria-hidden="true"></span>
        <span class="portrait-corner tr" aria-hidden="true"></span>
        <span class="portrait-corner bl" aria-hidden="true"></span>
        <span class="portrait-corner br" aria-hidden="true"></span>

        <div class="portrait-topbar">
          <span class="portrait-tag">SUBJECT · 01</span>
          <ul class="portrait-socials" aria-label="Social channels">
            {profile.socials.map((s) => (
              <li>
                <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.network}>
                  <Icon name={iconByNetwork[s.network] ?? 'github'} class="h-3 w-3" />
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="portrait-photo">
          <img
            src={avatarUrl}
            alt={profile.name}
            width="420"
            height="420"
            loading="eager"
            data-github-avatar
          />
          <span class="portrait-scanline" aria-hidden="true"></span>
          <span class="portrait-rec" aria-hidden="true">
            <span class="rec-dot"></span>
            <span class="rec-text">REC</span>
          </span>
          <span class="portrait-grid-overlay" aria-hidden="true"></span>
        </div>

        <figcaption class="portrait-caption">
          <span class="cap-line">
            <span class="cap-key">name:</span>
            <span class="cap-val">"{profile.name}"</span>
          </span>
          <span class="cap-line">
            <span class="cap-key">role:</span>
            <span class="cap-val">"{profile.label}"</span>
          </span>
          <span class="cap-line">
            <span class="cap-key">from:</span>
            <span class="cap-val">"{profile.location}"</span>
          </span>
        </figcaption>
      </figure>
    </aside>
  </div>

  <!-- Bottom marquee strip -->
  <div class="bottom-strip" aria-hidden="true">
    <span class="strip-eyebrow" data-i18n="hero.exploring">Currently exploring</span>
    <div class="strip-marquee">
      <ul class="strip-track">
        {[...profile.passionItems, ...profile.passionItems].map((item) => (
          <li>
            <span class="strip-bullet">◇</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Scroll hint -->
  <a class="scroll-hint" href="#about" aria-label="Scroll to About">
    <span class="hint-line" aria-hidden="true"></span>
    <span class="hint-label" data-i18n="hero.scroll">scroll</span>
  </a>
</section>

<script>
  const initializeHero = () => {
    const hero = document.getElementById('hero');
    if (!hero || (hero as any).dataset.ready === 'true') return;
    (hero as any).dataset.ready = 'true';

    // Mouse-tracked cursor glow + 3D parallax tilt on the portrait card
    const glow = document.getElementById('cursor-glow');
    const portraitCard = document.getElementById('portrait-card');
    const onMove = (e: MouseEvent) => {
      const rect = hero.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      if (glow) {
        glow.style.transform = `translate(${x - 200}px, ${y - 200}px)`;
        glow.style.opacity = '1';
      }
      if (portraitCard) {
        const nx = (x / rect.width - 0.5) * 2;  // -1..1
        const ny = (y / rect.height - 0.5) * 2; // -1..1
        portraitCard.style.setProperty('--tilt-y', `${nx * 6}deg`);
        portraitCard.style.setProperty('--tilt-x', `${-ny * 5}deg`);
        portraitCard.style.setProperty('--shift-x', `${nx * 4}px`);
        portraitCard.style.setProperty('--shift-y', `${-ny * 4}px`);
      }
    };
    const onLeave = () => {
      if (glow) glow.style.opacity = '0';
      if (portraitCard) {
        portraitCard.style.setProperty('--tilt-x', '0deg');
        portraitCard.style.setProperty('--tilt-y', '0deg');
        portraitCard.style.setProperty('--shift-x', '0px');
        portraitCard.style.setProperty('--shift-y', '0px');
      }
    };
    hero.addEventListener('mousemove', onMove);
    hero.addEventListener('mouseleave', onLeave);

    // ── Code rain: matrix-style stream of code tokens ──
    const canvas = document.getElementById('code-rain') as HTMLCanvasElement | null;
    const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (canvas && !reduceMotion) {
      const ctx = canvas.getContext('2d');
      if (ctx) {
        const html = document.documentElement;
        const isDark = () => html.classList.contains('dark');

        // Token pools — what falls in each stream. Mix of code keywords,
        // operators, hex digits and symbols so the rain reads as "code"
        // rather than random characters.
        const TOKENS = [
          'fn', 'pub', 'let', 'mut', 'use', 'mod', 'impl', 'self',
          'async', 'await', 'Ok', 'Err', 'Some', 'None', 'Self',
          'const', '=>', '::', '&&', '||', '==', '!=', '<=', '>=',
          '0xff', '0x0a', '0b01', 'true', 'false', 'null', 'void',
          'try', 'pkg', 'lib', 'main', 'init', 'box', 'arc', 'mut',
        ];
        const SYMBOLS = ['{', '}', '[', ']', '(', ')', ';', ':', '?', '!', '_', '$', '#', '@', '<', '>', '+', '-', '*', '/'];
        const HEX = '0123456789abcdef'.split('');
        const HEAD_GLYPHS = ['▶', '█', '▌', '▎', '◆', '⬢'];

        const pickChar = (preferLong: boolean): string => {
          const r = Math.random();
          if (preferLong) {
            if (r < 0.55) return TOKENS[Math.floor(Math.random() * TOKENS.length)];
            if (r < 0.80) return SYMBOLS[Math.floor(Math.random() * SYMBOLS.length)];
            return HEX[Math.floor(Math.random() * HEX.length)];
          } else {
            if (r < 0.55) return SYMBOLS[Math.floor(Math.random() * SYMBOLS.length)];
            if (r < 0.85) return HEX[Math.floor(Math.random() * HEX.length)];
            return TOKENS[Math.floor(Math.random() * TOKENS.length)];
          }
        };

        type Stream = {
          col: number;       // column index
          y: number;         // head row position (fractional)
          speed: number;     // rows per frame
          length: number;    // trail length in rows
          chars: string[];   // pre-baked chars per trail position
          churn: number;     // probability the trail mutates each frame
          longBias: boolean; // prefers tokens vs symbols
        };

        const FONT_SIZE = 14;
        const LINE_HEIGHT = 18;
        let cols = 0;
        let rows = 0;
        let streams: Stream[] = [];
        let W = 0;
        let H = 0;

        const newStream = (col: number, atTop = false): Stream => ({
          col,
          y: atTop ? -Math.random() * 12 : Math.random() * (rows + 12) - 12,
          // Gentler speeds + tighter range so streams glide instead of dart
          speed: 0.08 + Math.random() * 0.22,
          length: 6 + Math.floor(Math.random() * 18),
          chars: Array.from({ length: 24 }, () => pickChar(Math.random() < 0.45)),
          churn: 0.03 + Math.random() * 0.12,
          longBias: Math.random() < 0.45,
        });

        const resize = () => {
          const dpr = Math.min(window.devicePixelRatio || 1, 2);
          const rect = canvas.getBoundingClientRect();
          W = rect.width;
          H = rect.height;
          canvas.width = Math.max(1, Math.floor(W * dpr));
          canvas.height = Math.max(1, Math.floor(H * dpr));
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          cols = Math.max(4, Math.floor(W / FONT_SIZE));
          rows = Math.max(8, Math.floor(H / LINE_HEIGHT));
          streams = Array.from({ length: cols }, (_, i) => newStream(i, false));
        };

        resize();
        const ro = new ResizeObserver(resize);
        ro.observe(canvas);

        const draw = () => {
          const dark = isDark();

          // 1. Translucent fill = trail-fade. Tinted to match the page bg.
          //    Lower alpha → trails persist longer → silkier continuous flow.
          ctx.fillStyle = dark ? 'rgba(13, 22, 42, 0.07)' : 'rgba(255, 255, 255, 0.10)';
          ctx.fillRect(0, 0, W, H);

          ctx.font = `500 ${FONT_SIZE}px 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace`;
          ctx.textBaseline = 'top';

          const HEAD_RGB = dark ? '220, 252, 231' : '6, 95, 70';
          const TAIL_RGB = dark ? '110, 231, 183' : '16, 185, 129';

          for (const s of streams) {
            // Occasional churn so trail chars mutate as they fall
            if (Math.random() < s.churn) {
              const idx = Math.floor(Math.random() * s.length);
              s.chars[idx] = pickChar(s.longBias);
            }

            for (let i = 0; i < s.length; i++) {
              const rowY = s.y - i;
              if (rowY < -1 || rowY > rows + 1) continue;
              const x = s.col * FONT_SIZE;
              const y = rowY * LINE_HEIGHT;

              if (i === 0) {
                // Head: bright + slightly larger glyph
                const headChar = Math.random() < 0.18
                  ? HEAD_GLYPHS[Math.floor(Math.random() * HEAD_GLYPHS.length)]
                  : s.chars[0];
                ctx.fillStyle = `rgba(${HEAD_RGB}, 0.95)`;
                ctx.shadowColor = `rgba(${TAIL_RGB}, 0.6)`;
                ctx.shadowBlur = 6;
                ctx.fillText(headChar, x, y);
                ctx.shadowBlur = 0;
              } else {
                // Trail: progressively dimmer, slightly transparent
                const t = 1 - i / s.length;
                const alpha = Math.max(0, t * 0.65);
                ctx.fillStyle = `rgba(${TAIL_RGB}, ${alpha})`;
                ctx.fillText(s.chars[i] ?? '·', x, y);
              }
            }

            s.y += s.speed;

            // Reset stream once the trail clears the bottom
            if (s.y - s.length > rows + 4) {
              if (Math.random() < 0.4) {
                streams[s.col] = newStream(s.col, true);
              }
            }
          }
        };

        // Throttle to ~20 fps via rAF + timestamp guard for a calmer feel
        const TARGET_FPS = 20;
        const FRAME_INTERVAL = 1000 / TARGET_FPS;
        let lastFrame = 0;
        let rafId = 0;
        let running = false;

        const loop = (now: number) => {
          if (!running) return;
          if (now - lastFrame >= FRAME_INTERVAL) {
            draw();
            lastFrame = now;
          }
          rafId = requestAnimationFrame(loop);
        };

        const start = () => {
          if (running) return;
          running = true;
          rafId = requestAnimationFrame(loop);
        };
        const stop = () => {
          running = false;
          cancelAnimationFrame(rafId);
        };

        // Pause when the hero scrolls out of view to spare battery
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) start();
              else stop();
            }
          },
          { threshold: 0 },
        );
        io.observe(hero);

        // Re-paint immediately on theme toggle so the fade tint follows the page bg
        const themeObserver = new MutationObserver(() => {
          // One transparent fill in the new theme erases the lingering opposite tint
          ctx.fillStyle = isDark() ? 'rgba(13, 22, 42, 0.6)' : 'rgba(255, 255, 255, 0.6)';
          ctx.fillRect(0, 0, W, H);
        });
        themeObserver.observe(html, { attributes: true, attributeFilter: ['class'] });
      }
    }

    // Live time clock
    const timeEl = document.getElementById('hero-time');
    if (timeEl) {
      const updateTime = () => {
        const now = new Date();
        const time = now.toLocaleTimeString('en-US', {
          hour: '2-digit',
          minute: '2-digit',
          hour12: false,
          timeZone: 'America/Mexico_City',
        });
        timeEl.textContent = `${time} GMT-5`;
      };
      updateTime();
      window.setInterval(updateTime, 30000);
    }

  };

  document.addEventListener('astro:page-load', initializeHero);
  initializeHero();
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,300..900,0..100,0..1&display=swap');

  .hero {
    position: relative;
    min-height: calc(100vh - 5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
    margin: 0 0 4rem;
    padding: 5.5rem 0 4rem;
    scroll-margin-top: 6rem;
    overflow: hidden;
  }

  .anchor-alias {
    position: absolute;
    top: -5rem;
    height: 1px;
    width: 1px;
    pointer-events: none;
  }

  /* TWO-COLUMN GRID */
  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(240px, 0.75fr);
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: start;
    width: 100%;
    max-width: 1240px;
    margin: 2rem auto 0;
  }

  /* PROPS LIST — code object body */
  .props {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
    margin: 0.85rem 0 0.4rem;
    padding: 0 0 0 1.25rem;
    list-style: none;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .props li {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.55rem;
  }

  .prop-key {
    color: rgb(110 231 183);
    flex-shrink: 0;
  }

  .prop-val {
    color: rgb(248 250 252);
  }

  .prop-val.str {
    color: rgb(187 247 208);
  }

  .prop-val.num {
    color: rgb(167 243 208);
    font-weight: 600;
  }

  .prop-op {
    color: rgb(110 231 183);
    margin-left: -0.42rem;
  }

  .prop-comma {
    color: rgba(187, 247, 208, 0.4);
  }

  .prop-comment {
    color: rgba(187, 247, 208, 0.4);
    font-style: italic;
  }

  /* PORTRAIT CARD */
  .portrait-card {
    position: relative;
    padding-top: 2rem;
    max-width: 280px;
    justify-self: start;
    width: 100%;
  }

  .portrait-prop {
    position: absolute;
    top: 0;
    left: 0;
    color: rgb(110 231 183);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.92rem;
  }

  /* 3D tilt is driven by JS via custom properties — see initializeHero() */
  .portrait-card {
    --tilt-x: 0deg;
    --tilt-y: 0deg;
    --shift-x: 0px;
    --shift-y: 0px;
    perspective: 900px;
    perspective-origin: 50% 30%;
  }

  .portrait-frame {
    position: relative;
    width: 100%;
    margin: 0;
    padding: 1rem;
    border: 1px solid rgba(187, 247, 208, 0.18);
    background: rgba(34, 46, 78, 0.7);
    backdrop-filter: blur(10px);
    transform:
      rotateX(var(--tilt-x))
      rotateY(var(--tilt-y))
      translate3d(var(--shift-x), var(--shift-y), 0);
    transform-style: preserve-3d;
    transition: transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1), border-color 280ms ease, box-shadow 320ms ease;
    box-shadow: 0 18px 48px rgba(4, 12, 32, 0.4);
  }

  .portrait-frame:hover {
    border-color: rgba(110, 231, 183, 0.55);
    box-shadow: 0 32px 80px rgba(4, 12, 32, 0.55);
  }

  .portrait-corner {
    position: absolute;
    width: 14px;
    height: 14px;
    border: 2px solid rgb(110 231 183);
    z-index: 2;
  }
  .portrait-corner.tl { top: -2px; left: -2px; border-right: 0; border-bottom: 0; }
  .portrait-corner.tr { top: -2px; right: -2px; border-left: 0; border-bottom: 0; }
  .portrait-corner.bl { bottom: -2px; left: -2px; border-right: 0; border-top: 0; }
  .portrait-corner.br { bottom: -2px; right: -2px; border-left: 0; border-top: 0; }

  .portrait-topbar {
    position: absolute;
    top: -10px;
    left: 1rem;
    right: 1rem;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }

  .portrait-tag {
    padding: 0.18rem 0.55rem;
    background: rgb(28 38 70);
    color: rgb(110 231 183);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .portrait-socials {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin: 0;
    padding: 0.18rem 0.4rem;
    background: rgb(28 38 70);
    list-style: none;
  }

  .portrait-socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    color: rgb(187 247 208);
    transition: color 180ms ease, transform 180ms ease;
  }

  .portrait-socials a:hover,
  .portrait-socials a:focus-visible {
    color: rgb(110 231 183);
    transform: translateY(-1px);
    outline: none;
  }

  /* PORTRAIT PHOTO + CRT-STYLE OVERLAYS */
  .portrait-photo {
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .portrait-photo img {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    filter: saturate(0.78) contrast(1.05);
    transition: filter 320ms ease, transform 480ms ease;
    will-change: filter;
  }

  .portrait-frame:hover .portrait-photo img {
    filter: saturate(1) contrast(1);
    transform: scale(1.015);
  }

  /* horizontal scan-line that drifts down the photo */
  .portrait-scanline {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background:
      linear-gradient(
        180deg,
        transparent 0%,
        rgba(110, 231, 183, 0.28) 48%,
        rgba(167, 243, 208, 0.6) 50%,
        rgba(110, 231, 183, 0.28) 52%,
        transparent 100%
      );
    background-size: 100% 18%;
    background-repeat: no-repeat;
    background-position: 0% -20%;
    mix-blend-mode: screen;
    animation: scanline-sweep 4.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    opacity: 0.6;
  }

  @keyframes scanline-sweep {
    0%   { background-position: 0% -20%;  opacity: 0; }
    8%   { opacity: 0.65; }
    50%  { background-position: 0% 110%;  opacity: 0.55; }
    52%  { opacity: 0; }
    100% { background-position: 0% 110%;  opacity: 0; }
  }

  /* faint scanline texture (always on) */
  .portrait-photo::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      repeating-linear-gradient(
        180deg,
        rgba(13, 22, 42, 0.0) 0px,
        rgba(13, 22, 42, 0.0) 2px,
        rgba(13, 22, 42, 0.18) 3px,
        rgba(13, 22, 42, 0.0) 4px
      );
    mix-blend-mode: multiply;
    opacity: 0.35;
  }

  /* live REC indicator */
  .portrait-rec {
    position: absolute;
    top: 0.55rem;
    right: 0.55rem;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
    padding: 0.18rem 0.45rem;
    border: 1px solid rgba(252, 165, 165, 0.65);
    border-radius: 999px;
    background: rgba(13, 22, 42, 0.78);
    backdrop-filter: blur(4px);
    color: rgb(252 165 165);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .rec-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgb(248 113 113);
    box-shadow: 0 0 0 0 rgba(248, 113, 113, 0.6);
    animation: rec-pulse 1.6s ease-out infinite;
  }

  @keyframes rec-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(248, 113, 113, 0.7); }
    70%  { box-shadow: 0 0 0 7px rgba(248, 113, 113, 0); }
    100% { box-shadow: 0 0 0 0 rgba(248, 113, 113, 0); }
  }

  /* very faint grid overlay on the photo (cell hint) */
  .portrait-grid-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background-image:
      linear-gradient(rgba(110, 231, 183, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(110, 231, 183, 0.06) 1px, transparent 1px);
    background-size: 24px 24px;
    mix-blend-mode: screen;
    opacity: 0.55;
  }

  .portrait-caption {
    display: grid;
    gap: 0.4rem;
    margin: 1rem 0 0;
    padding-top: 1rem;
    border-top: 1px dashed rgba(187, 247, 208, 0.22);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.78rem;
  }

  .cap-line {
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    min-width: 0;
  }

  .cap-key {
    color: rgb(110 231 183);
    width: 3.4rem;
    flex-shrink: 0;
  }

  .cap-val {
    color: rgb(187 247 208);
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
    hyphens: auto;
  }

  /* ANIMATED BACKGROUND */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .grid {
    position: absolute;
    inset: -2px;
    background-image:
      linear-gradient(rgba(187, 247, 208, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(187, 247, 208, 0.06) 1px, transparent 1px);
    background-size: 56px 56px;
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
            mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
    animation: grid-pan 60s linear infinite;
  }

  @keyframes grid-pan {
    from { transform: translate(0, 0); }
    to { transform: translate(56px, 56px); }
  }

  .aurora {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.5;
  }

  .aurora-1 {
    top: 5%;
    left: -10%;
    width: 380px;
    height: 380px;
    background: radial-gradient(circle, rgba(110, 231, 183, 0.4), transparent 70%);
    animation: aurora-drift1 18s ease-in-out infinite alternate;
  }

  .aurora-2 {
    bottom: 5%;
    right: -8%;
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, rgba(52, 211, 153, 0.32), transparent 70%);
    animation: aurora-drift2 22s ease-in-out infinite alternate;
  }

  @keyframes aurora-drift1 {
    from { transform: translate(0, 0) scale(1); }
    to { transform: translate(120px, 80px) scale(1.18); }
  }
  @keyframes aurora-drift2 {
    from { transform: translate(0, 0) scale(1); }
    to { transform: translate(-100px, -60px) scale(1.12); }
  }

  .cursor-glow {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(110, 231, 183, 0.18), transparent 65%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 320ms ease, transform 80ms linear;
    will-change: transform, opacity;
  }

  /* ─────────  CODE RAIN (Matrix-style canvas)  ─────────
     Lives in the right band of the hero, around the portrait. A radial
     mask carves out the card itself so the rain never falls onto the
     photo or caption. JS draws code tokens at ~24 fps in canvas. */
  .code-rain {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: clamp(320px, 48%, 640px);
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.62;
    -webkit-mask-image:
      /* carve out the portrait card area */
      radial-gradient(
        ellipse 50% 36% at 28% 30%,
        transparent 0%,
        transparent 78%,
        black 100%
      ),
      /* fade the edges so streams don't terminate sharply */
      linear-gradient(
        to right,
        transparent 0%,
        black 12%,
        black 88%,
        transparent 100%
      );
            mask-image:
      radial-gradient(
        ellipse 50% 36% at 28% 30%,
        transparent 0%,
        transparent 78%,
        black 100%
      ),
      linear-gradient(
        to right,
        transparent 0%,
        black 12%,
        black 88%,
        transparent 100%
      );
    -webkit-mask-composite: source-in;
            mask-composite: intersect;
    /* Vertical fade so heads emerge softly at the top and dissolve at the bottom */
    -webkit-mask-image:
      radial-gradient(
        ellipse 50% 36% at 28% 30%,
        transparent 0%,
        transparent 78%,
        black 100%
      ),
      linear-gradient(
        180deg,
        transparent 0%,
        black 8%,
        black 90%,
        transparent 100%
      );
            mask-image:
      radial-gradient(
        ellipse 50% 36% at 28% 30%,
        transparent 0%,
        transparent 78%,
        black 100%
      ),
      linear-gradient(
        180deg,
        transparent 0%,
        black 8%,
        black 90%,
        transparent 100%
      );
  }

  /* COPY */
  .hero-copy {
    position: relative;
    z-index: 1;
    max-width: 1080px;
  }

  /* STATUS BAR */
  .status-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.85rem;
    width: max-content;
    max-width: 100%;
    margin: 0 auto 2.5rem;
    padding: 0.55rem 1rem;
    border: 1px solid rgba(187, 247, 208, 0.18);
    border-radius: 999px;
    background: rgba(22, 30, 52, 0.55);
    backdrop-filter: blur(14px);
    color: rgb(187 247 208);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.74rem;
  }

  .status-cell {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgb(110 231 183);
  }

  .status-dot.live {
    box-shadow: 0 0 0 0 rgba(110, 231, 183, 0.6);
    animation: dot-pulse 2.4s ease-out infinite;
  }

  @keyframes dot-pulse {
    0% { box-shadow: 0 0 0 0 rgba(110, 231, 183, 0.6); }
    70% { box-shadow: 0 0 0 8px rgba(110, 231, 183, 0); }
    100% { box-shadow: 0 0 0 0 rgba(110, 231, 183, 0); }
  }

  .status-key {
    color: rgba(187, 247, 208, 0.55);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.66rem;
  }

  .status-val {
    color: rgb(248 250 252);
  }

  .status-sep {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(187, 247, 208, 0.3);
  }

  /* GREETING (code-line style) */
  .greeting {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0 0 0.4rem;
    color: rgb(110 231 183);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.92rem;
    letter-spacing: 0.02em;
  }

  .greeting > span:nth-child(2) {
    color: rgb(187 247 208);
  }

  .greet-line {
    display: inline-block;
    width: 26px;
    height: 1px;
    background: currentColor;
    opacity: 0.6;
  }

  .greet-symbol {
    color: rgb(110 231 183);
    font-weight: 700;
  }

  /* DISPLAY NAME — single line with gradient first-letter */
  .display-name {
    position: relative;
    margin: 0.4rem 0 0;
    padding: 1.2em 0 0.4em;
    overflow: visible;
  }

  .name-text {
    color: rgb(187 247 208);
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-style: italic;
    font-weight: 400;
    font-variation-settings: 'opsz' 144, 'WONK' 1;
    letter-spacing: -0.025em;
    line-height: 1.6;
    display: inline-block;
    word-break: break-word;
    overflow: visible;
  }

  .name-text::first-letter {
    color: transparent;
    font-size: 2.1em;
    font-style: italic;
    font-weight: 400;
    font-variation-settings: 'opsz' 144, 'WONK' 1, 'SOFT' 80;
    letter-spacing: -0.06em;
    background: linear-gradient(135deg, rgb(110 231 183) 0%, rgb(52 211 153) 50%, rgb(16 185 129) 100%);
    -webkit-background-clip: text;
            background-clip: text;
    padding-right: 0.06em;
  }

  .name-period {
    color: rgb(110 231 183);
  }

  /* MOTTO */
  .motto {
    min-height: 1.6em;
    margin: 0.7rem 0 0.4rem;
    color: rgb(248 250 252);
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(1.05rem, 1.8vw, 1.4rem);
    font-style: italic;
    font-weight: 350;
    font-variation-settings: 'opsz' 144;
    letter-spacing: -0.012em;
    line-height: 1.3;
    max-width: 640px;
  }

  /* SUMMARY (code prompt style) */
  .summary {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    max-width: 760px;
    margin: 0;
    color: rgb(187 247 208);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .summary-tag {
    color: rgb(110 231 183);
    font-weight: 700;
  }

  .summary-amp {
    color: rgba(187, 247, 208, 0.4);
    margin: 0 0.2rem;
  }

  .passion {
    color: rgb(110 231 183);
  }

  .closing-bracket {
    margin: 0.4rem 0 0;
    color: rgb(110 231 183);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 1rem;
    font-weight: 700;
  }

  /* CTA BUTTONS */
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.5rem;
  }

  .cta {
    position: relative;
    display: inline-flex;
    overflow: hidden;
    border-radius: 999px;
    text-decoration: none;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 220ms ease;
  }

  .cta-label {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.95rem 1.5rem;
  }

  /* Primary - solid emerald gradient */
  .cta.primary {
    background: linear-gradient(135deg, rgb(110 231 183), rgb(52 211 153));
    color: rgb(13 26 58);
    box-shadow: 0 8px 28px rgba(52, 211, 153, 0.32);
  }

  .cta.primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(52, 211, 153, 0.45);
  }

  .cta-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 50%, rgba(255, 255, 255, 0.4), transparent 50%);
    opacity: 0;
    transition: opacity 320ms ease;
  }

  .cta.primary:hover .cta-glow {
    opacity: 1;
  }

  /* Secondary - outlined */
  .cta.secondary {
    background: transparent;
    border: 1px solid rgba(110, 231, 183, 0.5);
    color: rgb(187 247 208);
  }

  .cta.secondary:hover {
    border-color: rgb(110 231 183);
    background: rgba(110, 231, 183, 0.08);
    transform: translateY(-3px);
  }

  /* Ghost - minimal */
  .cta.ghost {
    background: transparent;
    color: rgb(187 247 208);
  }

  .cta.ghost:hover {
    color: rgb(110 231 183);
    transform: translateY(-3px);
  }

  /* BOTTOM STRIP - marquee */
  .bottom-strip {
    width: 100%;
    max-width: 1240px;
    margin: 4rem auto 0;
    padding-top: 1.75rem;
    border-top: 1px solid rgba(187, 247, 208, 0.12);
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 1.5rem;
    align-items: center;
  }

  .strip-eyebrow {
    color: rgba(110, 231, 183, 0.7);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .strip-marquee {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 6%, black 94%, transparent 100%);
            mask-image: linear-gradient(90deg, transparent 0%, black 6%, black 94%, transparent 100%);
  }

  .strip-track {
    display: flex;
    gap: 2rem;
    margin: 0;
    padding: 0;
    list-style: none;
    width: max-content;
    color: rgb(187 247 208);
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.05rem;
    font-style: italic;
    font-variation-settings: 'opsz' 144;
    animation: strip-scroll 32s linear infinite;
  }

  .strip-track li {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    white-space: nowrap;
  }

  .strip-bullet {
    color: rgb(110 231 183);
    font-style: normal;
  }

  @keyframes strip-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* SCROLL HINT */
  .scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(187, 247, 208, 0.6);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color 220ms ease;
  }

  .scroll-hint:hover {
    color: rgb(110 231 183);
  }

  .hint-line {
    display: inline-block;
    width: 28px;
    height: 1px;
    background: currentColor;
    animation: hint-pulse 2.6s ease-in-out infinite;
  }

  @keyframes hint-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 1; }
  }

  /* ═══════════════════════  LIGHT MODE  ═══════════════════════ */
  /* greeting / code-line tokens */
  :global(html:not(.dark)) .greeting {
    color: rgb(5 150 105);
  }
  :global(html:not(.dark)) .greeting > span:nth-child(2) {
    color: rgb(15 118 110);
  }
  :global(html:not(.dark)) .greet-symbol {
    color: rgb(5 150 105);
  }

  /* display name + motto */
  :global(html:not(.dark)) .name-row,
  :global(html:not(.dark)) .name-text {
    color: rgb(15 23 42);
  }
  :global(html:not(.dark)) .name-period {
    color: rgb(5 150 105);
  }
  :global(html:not(.dark)) .motto {
    color: rgb(15 23 42);
  }
  :global(html:not(.dark)) .summary {
    color: rgb(51 65 85);
  }

  /* props (code-object body) */
  :global(html:not(.dark)) .prop-key {
    color: rgb(5 150 105);
  }
  :global(html:not(.dark)) .prop-val {
    color: rgb(15 23 42);
  }
  :global(html:not(.dark)) .prop-val.str {
    color: rgb(15 118 110);
  }
  :global(html:not(.dark)) .prop-val.num {
    color: rgb(180 83 9);
  }
  :global(html:not(.dark)) .prop-op {
    color: rgb(5 150 105);
  }
  :global(html:not(.dark)) .prop-comma {
    color: rgb(148 163 184);
  }
  :global(html:not(.dark)) .prop-comment {
    color: rgb(100 116 139);
  }
  :global(html:not(.dark)) .closing-bracket {
    color: rgb(5 150 105);
  }

  /* status bar */
  :global(html:not(.dark)) .status-bar {
    background: rgba(255, 255, 255, 0.85);
    border-color: rgb(226 232 240);
    color: rgb(51 65 85);
  }
  :global(html:not(.dark)) .status-val {
    color: rgb(15 23 42);
  }
  :global(html:not(.dark)) .status-key {
    color: rgb(100 116 139);
  }
  :global(html:not(.dark)) .status-dot,
  :global(html:not(.dark)) .status-dot.live {
    background: rgb(16 185 129);
  }
  :global(html:not(.dark)) .status-sep {
    background: rgb(203 213 225);
  }

  /* CTAs in light mode */
  :global(html:not(.dark)) .cta.primary {
    background: linear-gradient(135deg, rgb(16 185 129), rgb(5 150 105));
    color: rgb(255 255 255);
    box-shadow: 0 8px 24px rgba(16, 185, 129, 0.25);
  }
  :global(html:not(.dark)) .cta.primary:hover {
    box-shadow: 0 14px 36px rgba(16, 185, 129, 0.35);
  }
  :global(html:not(.dark)) .cta.secondary {
    border-color: rgb(5 150 105);
    color: rgb(15 118 110);
  }
  :global(html:not(.dark)) .cta.secondary:hover {
    background: rgba(16, 185, 129, 0.08);
    border-color: rgb(5 150 105);
  }
  :global(html:not(.dark)) .cta.ghost {
    color: rgb(15 23 42);
  }
  :global(html:not(.dark)) .cta.ghost:hover {
    color: rgb(5 150 105);
  }

  /* portrait card */
  :global(html:not(.dark)) .portrait-prop {
    color: rgb(5 150 105);
  }
  :global(html:not(.dark)) .portrait-frame {
    background: rgb(255 255 255);
    border-color: rgb(226 232 240);
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
  }
  :global(html:not(.dark)) .portrait-frame:hover {
    border-color: rgb(16 185 129);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
  }
  :global(html:not(.dark)) .portrait-corner {
    border-color: rgb(5 150 105);
  }
  :global(html:not(.dark)) .portrait-tag {
    background: rgb(248 250 252);
    color: rgb(5 150 105);
    border: 1px solid rgb(226 232 240);
  }
  :global(html:not(.dark)) .portrait-socials {
    background: rgb(248 250 252);
    border: 1px solid rgb(226 232 240);
  }
  :global(html:not(.dark)) .portrait-socials a {
    color: rgb(15 118 110);
  }
  :global(html:not(.dark)) .portrait-socials a:hover,
  :global(html:not(.dark)) .portrait-socials a:focus-visible {
    color: rgb(5 150 105);
  }
  :global(html:not(.dark)) .portrait-caption {
    border-top-color: rgb(226 232 240);
  }
  :global(html:not(.dark)) .cap-key {
    color: rgb(5 150 105);
  }
  :global(html:not(.dark)) .cap-val {
    color: rgb(15 23 42);
  }

  /* bottom marquee strip */
  :global(html:not(.dark)) .bottom-strip {
    border-top-color: rgb(226 232 240);
  }
  :global(html:not(.dark)) .strip-eyebrow {
    color: rgb(5 150 105);
  }
  :global(html:not(.dark)) .strip-track {
    color: rgb(15 23 42);
  }
  :global(html:not(.dark)) .strip-bullet {
    color: rgb(5 150 105);
  }

  /* scroll hint + animated bg accents */
  :global(html:not(.dark)) .scroll-hint {
    color: rgb(71 85 105);
  }
  :global(html:not(.dark)) .scroll-hint:hover {
    color: rgb(5 150 105);
  }
  :global(html:not(.dark)) .grid {
    background-image:
      linear-gradient(rgba(15, 23, 42, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(15, 23, 42, 0.05) 1px, transparent 1px);
  }
  :global(html:not(.dark)) .aurora-1 {
    background: radial-gradient(circle, rgba(16, 185, 129, 0.18), transparent 70%);
  }
  :global(html:not(.dark)) .aurora-2 {
    background: radial-gradient(circle, rgba(5, 150, 105, 0.14), transparent 70%);
  }
  :global(html:not(.dark)) .cursor-glow {
    background: radial-gradient(circle, rgba(16, 185, 129, 0.16), transparent 65%);
  }

  /* code rain in light mode — slightly higher opacity so the muted
     emerald characters still register against white */
  :global(html:not(.dark)) .code-rain {
    opacity: 0.72;
  }

  /* portrait overlays in light mode (less aggressive blending) */
  :global(html:not(.dark)) .portrait-photo::before {
    opacity: 0.18;
  }
  :global(html:not(.dark)) .portrait-grid-overlay {
    background-image:
      linear-gradient(rgba(15, 23, 42, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(15, 23, 42, 0.06) 1px, transparent 1px);
