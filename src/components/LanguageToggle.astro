  const getInitialLanguage = (): Lang => {
    return 'en';
  };

  const applyLanguage = (lang: Lang) => {
    const dict = translations[lang];
    document.documentElement.lang = lang;
    document.documentElement.dataset.lang = lang;
    localStorage.setItem('language', lang);

    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((element) => {
      const key = element.dataset.i18n;
      if (key && dict[key]) element.textContent = dict[key];
    });

    document.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[data-i18n-placeholder]').forEach((element) => {
      const key = element.dataset.i18nPlaceholder;
      if (key && dict[key]) element.placeholder = dict[key];
    });

    document.querySelectorAll<HTMLElement>('.manifest-version.is-empty, .release-cell.is-empty').forEach((element) => {
      element.textContent = dict['projects.noRelease'];
    });

    document.querySelectorAll<HTMLElement>('[data-lang-option]').forEach((element) => {
      element.classList.toggle('is-active', element.dataset.langOption === lang);
    });
  };

  const initializeLanguageToggles = () => {
    const lang = getInitialLanguage();
    applyLanguage(lang);
    document.querySelectorAll<HTMLButtonElement>('[data-language-toggle]').forEach((button) => {
      if (button.dataset.ready === 'true') return;
      button.dataset.ready = 'true';
      button.addEventListener('click', () => {
        applyLanguage(document.documentElement.dataset.lang === 'es' ? 'en' : 'es');
      });
    });
  };

  document.addEventListener('astro:page-load', initializeLanguageToggles);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeLanguageToggles, { once: true });
  } else {
    initializeLanguageToggles();
  }
</script>

<style>
  .language-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    height: 2.35rem;
    padding: 0 0.75rem;
    border: 1px solid rgba(110, 231, 183, 0.34);
    border-radius: 999px;
    background: rgba(22, 30, 52, 0.36);
    color: rgba(187, 247, 208, 0.72);
    cursor: pointer;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    transition: border-color 180ms ease, background-color 180ms ease, color 180ms ease;
  }

  .language-toggle:hover,
  .language-toggle:focus-visible {
    border-color: rgb(110 231 183);
    background: rgba(110, 231, 183, 0.1);
    color: rgb(187 247 208);
    outline: none;
  }

  .lang-option {
    opacity: 0.55;
  }

  .lang-option.is-active {
    color: rgb(110 231 183);
    opacity: 1;
  }

  .lang-sep {
    color: rgba(187, 247, 208, 0.34);
  }

  :global(html:not(.dark)) .language-toggle {
    background: rgba(255, 255, 255, 0.68);
    border-color: rgba(5, 150, 105, 0.24);
    color: rgb(71 85 105);
  }

  :global(html:not(.dark)) .language-toggle:hover,
  :global(html:not(.dark)) .language-toggle:focus-visible {
    background: rgb(236 253 245);
    border-color: rgb(5 150 105);
    color: rgb(15 23 42);
  }

  :global(html:not(.dark)) .lang-option.is-active {
    color: rgb(5 150 105);
  }
</style>
