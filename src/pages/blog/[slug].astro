---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/portfolio/Icon.astro';
import { format, formatDistanceToNow } from 'date-fns';
import { es } from 'date-fns/locale';
import { profile } from '../../data/portfolio';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, posts },
  }));
}

const { post, posts } = Astro.props;
const { Content, headings } = await post.render();

const rawBase = import.meta.env.BASE_URL || '/';
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const withBase = (path: string) => `${base}${path.replace(/^\//, '')}`;

const author = (post.data as any).author || {};
const authorName = author.name || 'Sergio Triana';
const githubUsername = profile.githubUsername;
let avatar: string = author.avatar || `https://github.com/${githubUsername}.png?size=128`;
if (typeof avatar === 'string' && avatar.includes('github.com') && avatar.includes('/blob/')) {
  avatar = avatar.replace('github.com', 'raw.githubusercontent.com').replace('/blob/', '/');
}
if (typeof avatar === 'string' && avatar.startsWith('/') && !avatar.startsWith('//')) {
  avatar = withBase(avatar);
}

// Adjacent navigation (sorted by date desc)
const sortedPosts = posts
  .filter((p: any) => !p.data.draft)
  .sort((a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentIndex = sortedPosts.findIndex((p: any) => p.slug === post.slug);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

const formattedDate = format(post.data.pubDate, "d 'de' MMMM, yyyy", { locale: es });
const isoDate = format(post.data.pubDate, 'yyyy-MM-dd');
const tags = (post.data as any).tags as string[] | undefined;

// Word count from body for header stats
const body = (post as any).body ?? '';
const wordCount = typeof body === 'string' ? body.trim().split(/\s+/).filter(Boolean).length : 0;
const charCount = typeof body === 'string' ? body.length : 0;
const lineCount = typeof body === 'string' ? body.split('\n').length : 0;

// Deterministic short SHA for the file
const shortSha = (input: string) => {
  let h = 0x811c9dc5;
  for (let i = 0; i < input.length; i++) {
    h ^= input.charCodeAt(i);
    h = Math.imul(h, 0x01000193) >>> 0;
  }
  return h.toString(16).padStart(8, '0').slice(0, 7);
};

const sha = shortSha(post.slug);
const filePath = `docs/${post.data.category.toLowerCase().replace(/\s+/g, '-')}/${post.slug}.md`;

// Filter TOC to top-2 levels (h2/h3)
const toc = (headings ?? []).filter((h: any) => h.depth >= 2 && h.depth <= 3);
---

<Layout title={`${post.data.title} | docs/`}>
  <!-- Reading progress bar (sticky top) -->
  <div id="reading-progress" class="reading-progress" aria-hidden="true"></div>

  <article class="md-file">
    <!-- ════════  FILE HEADER (chrome)  ════════ -->
    <header class="file-header">
      <!-- Breadcrumb path -->
      <nav class="path-bar" aria-label="File path">
        <a href={withBase('blog')} class="back-link" aria-label="Back to docs">
          <span class="back-glyph" aria-hidden="true">←</span>
          <span class="back-label">docs</span>
        </a>
        <span class="path-sep" aria-hidden="true">/</span>
        <span class="path-seg">{post.data.category.toLowerCase().replace(/\s+/g, '-')}</span>
        <span class="path-sep" aria-hidden="true">/</span>
        <span class="path-seg active">
          <span class="path-icon" aria-hidden="true">M↓</span>
          {post.slug}.md
        </span>

        <span class="path-spacer"></span>

        <span class="path-pos">
          {String(currentIndex + 1).padStart(2, '0')} / {String(sortedPosts.length).padStart(2, '0')}
        </span>
      </nav>

      <!-- Tab strip — only this file is "open" -->
      <div class="tab-strip" aria-hidden="true">
        <div class="tab is-active">
          <span class="tab-glyph">M↓</span>
          <span class="tab-name">{post.slug}.md</span>
          <span class="tab-dot"></span>
          <span class="tab-close">×</span>
        </div>
        <div class="tab-fade"></div>
      </div>

      <!-- File substats — like an editor's status info -->
      <div class="file-substats">
        <span class="sub-cell">
          <span class="sub-key">commit</span>
          <span class="sub-val mono">{sha}</span>
        </span>
        <span class="sub-cell">
          <span class="sub-key">date</span>
          <span class="sub-val mono">{isoDate}</span>
        </span>
        <span class="sub-cell">
          <span class="sub-key">lines</span>
          <span class="sub-val mono">{lineCount}</span>
        </span>
        <span class="sub-cell">
          <span class="sub-key">words</span>
          <span class="sub-val mono">{wordCount.toLocaleString()}</span>
        </span>
        <span class="sub-cell">
          <span class="sub-key">read</span>
          <span class="sub-val mono">{post.data.readingTime} min</span>
        </span>
        <span class="sub-spacer"></span>
        <a class="sub-action" href={`https://github.com/${githubUsername}`} target="_blank" rel="noopener noreferrer">Raw</a>
        <span class="sub-pipe" aria-hidden="true">|</span>
        <span class="sub-action">Blame</span>
        <span class="sub-pipe" aria-hidden="true">|</span>
        <span class="sub-action">History</span>
      </div>
    </header>

    <!-- ════════  FRONTMATTER PREVIEW  ════════ -->
    <details class="frontmatter" open>
      <summary>
        <span class="fm-arrow" aria-hidden="true">▾</span>
        <span class="fm-token">---</span>
        <span class="fm-label">frontmatter</span>
        <span class="fm-hint" aria-hidden="true">(YAML · click to collapse)</span>
      </summary>
      <pre class="fm-yaml"><code><span class="yaml-line"><span class="yaml-key">title</span><span class="yaml-colon">:</span> <span class="yaml-str">"{post.data.title}"</span></span>
<span class="yaml-line"><span class="yaml-key">description</span><span class="yaml-colon">:</span> <span class="yaml-str">"{post.data.description}"</span></span>
<span class="yaml-line"><span class="yaml-key">pubDate</span><span class="yaml-colon">:</span> <span class="yaml-num">{isoDate}</span></span>
<span class="yaml-line"><span class="yaml-key">category</span><span class="yaml-colon">:</span> <span class="yaml-str">"{post.data.category}"</span></span>
<span class="yaml-line"><span class="yaml-key">readingTime</span><span class="yaml-colon">:</span> <span class="yaml-num">{post.data.readingTime}</span></span>
<span class="yaml-line"><span class="yaml-key">author</span><span class="yaml-colon">:</span></span>
<span class="yaml-line">  <span class="yaml-key">name</span><span class="yaml-colon">:</span> <span class="yaml-str">"{authorName}"</span></span>
{tags && tags.length > 0 && (
  <Fragment>
    <span class="yaml-line"><span class="yaml-key">tags</span><span class="yaml-colon">:</span> <span class="yaml-arr">[{tags.map((t, i) => <Fragment><span class="yaml-str">"{t}"</span>{i < tags.length - 1 ? ', ' : ''}</Fragment>)}]</span></span>
  </Fragment>
)}
<span class="yaml-line"><span class="yaml-token">---</span></span></code></pre>
    </details>

    <!-- ════════  BODY + SIDEBAR LAYOUT  ════════ -->
    <div class="reading-grid">
      <!-- ── Article column ── -->
      <div class="reading-main">
        <!-- Article hero -->
        <header class="article-header">
          <div class="kicker">
            <span class="kicker-cat">#{post.data.category.toLowerCase()}</span>
            <span class="kicker-sep" aria-hidden="true">·</span>
            <time datetime={post.data.pubDate.toISOString()}>{isoDate}</time>
            <span class="kicker-sep" aria-hidden="true">·</span>
            <span>{post.data.readingTime} min read</span>
          </div>

          <h1 class="article-title">
            <span class="md-h1-prefix" aria-hidden="true"># </span>
            {post.data.title}
          </h1>

          <p class="dek">
            <span class="md-quote-prefix" aria-hidden="true">&gt; </span>
            {post.data.description}
          </p>

          <div class="byline">
            <img class="avatar" src={avatar} alt={authorName} loading="lazy" decoding="async" />
            <div class="byline-info">
              <span class="byline-name">{authorName}</span>
              <span class="byline-role">@{githubUsername} · {formattedDate}</span>
            </div>
          </div>
        </header>

        <!-- Article body -->
        <div class="article-body">
          <Content />
        </div>

        <!-- Article footer / share / tags -->
        <footer class="article-footer">
          <div class="footer-line" aria-hidden="true">
            <span class="footer-token">/* eof */</span>
          </div>

          <div class="footer-content">
            <p class="footer-eyebrow">// thanks for reading</p>
            <p class="footer-text">
              If this resonated, I'd love to hear what you took away — or where I got it wrong.
            </p>

            <div class="share-row">
              <span class="share-label">Share:</span>
              <a
                class="share-btn"
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Share on X"
              >
                <Icon name="external" class="h-4 w-4" />
                <span>X / Twitter</span>
              </a>
              <a
                class="share-btn"
                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://stescobedo92.github.io/stescobedo-portfolio/blog/${post.slug}`)}`}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Share on LinkedIn"
              >
                <Icon name="linkedin" class="h-4 w-4" />
                <span>LinkedIn</span>
              </a>
              <button id="copy-link" class="share-btn" type="button" aria-label="Copy link">
                <span class="copy-glyph" aria-hidden="true">⎘</span>
                <span class="copy-label">Copy link</span>
              </button>
            </div>

            {tags && tags.length > 0 && (
              <ul class="tags" aria-label="Tags">
                {tags.map((tag) => <li>#{tag}</li>)}
              </ul>
            )}
          </div>
        </footer>

        <!-- Adjacent files -->
        {(prevPost || nextPost) && (
          <nav class="adjacent" aria-label="Adjacent files">
            <p class="adj-title">
              <span class="adj-glyph" aria-hidden="true">⌗</span>
              also in this directory
            </p>
            <div class="adj-grid">
              {prevPost ? (
                <a class="adj-card prev" href={withBase(`blog/${prevPost.slug}`)}>
                  <span class="adj-label">
                    <span class="adj-arrow flip" aria-hidden="true">→</span>
                    older file
                  </span>
                  <span class="adj-fname">{prevPost.slug}.md</span>
                  <span class="adj-name">{prevPost.data.title}</span>
                  <span class="adj-meta">#{prevPost.data.category.toLowerCase()} · {prevPost.data.readingTime} min</span>
                </a>
              ) : <span class="adj-card placeholder" aria-hidden="true"></span>}

              {nextPost ? (
                <a class="adj-card next" href={withBase(`blog/${nextPost.slug}`)}>
                  <span class="adj-label">
                    newer file
                    <span class="adj-arrow" aria-hidden="true">→</span>
                  </span>
                  <span class="adj-fname">{nextPost.slug}.md</span>
                  <span class="adj-name">{nextPost.data.title}</span>
                  <span class="adj-meta">#{nextPost.data.category.toLowerCase()} · {nextPost.data.readingTime} min</span>
                </a>
              ) : <span class="adj-card placeholder" aria-hidden="true"></span>}
            </div>
          </nav>
        )}

        <div class="back-cta-wrap">
          <a href={withBase('blog')} class="back-cta">
            <span class="dash" aria-hidden="true"></span>
            <span class="back-cta-glyph" aria-hidden="true">↩</span>
            <span>cd ../docs</span>
            <span class="dash" aria-hidden="true"></span>
          </a>
        </div>
      </div>

      <!-- ── Sidebar (TOC + meta, sticky on desktop) ── -->
      <aside class="reading-side" aria-label="Outline">
        <div class="side-card toc-card">
          <header class="side-head">
            <span class="side-glyph" aria-hidden="true">⌧</span>
            <h2>outline</h2>
            <span class="side-rule"></span>
          </header>

          {toc.length > 0 ? (
            <ol class="toc">
              {toc.map((heading: any) => (
                <li class={`toc-item depth-${heading.depth}`}>
                  <a href={`#${heading.slug}`} data-heading-id={heading.slug}>
                    <span class="toc-marker" aria-hidden="true"></span>
                    <span class="toc-text">{heading.text}</span>
                  </a>
                </li>
              ))}
            </ol>
          ) : (
            <p class="toc-empty">// no headings in this file</p>
          )}
        </div>

        <div class="side-card meta-card">
          <header class="side-head">
            <span class="side-glyph" aria-hidden="true">ⓘ</span>
            <h2>file info</h2>
            <span class="side-rule"></span>
          </header>

          <dl class="meta-list">
            <div class="meta-row">
              <dt>path</dt>
              <dd class="mono">{filePath}</dd>
            </div>
            <div class="meta-row">
              <dt>commit</dt>
              <dd class="mono accent">{sha}</dd>
            </div>
            <div class="meta-row">
              <dt>modified</dt>
              <dd>{formatDistanceToNow(post.data.pubDate, { addSuffix: true })}</dd>
            </div>
            <div class="meta-row">
              <dt>characters</dt>
              <dd class="mono">{charCount.toLocaleString()}</dd>
            </div>
            <div class="meta-row">
              <dt>headings</dt>
              <dd class="mono">{toc.length}</dd>
            </div>
          </dl>

          <a href={`https://github.com/${githubUsername}`} target="_blank" rel="noopener noreferrer" class="meta-action">
            <span aria-hidden="true">⤴</span>
            <span>edit on github</span>
          </a>
        </div>
      </aside>
    </div>
  </article>
</Layout>

<script>
  const initializeArticle = () => {
    const bar = document.getElementById('reading-progress');
    if (bar && bar.dataset.ready !== 'true') {
      bar.dataset.ready = 'true';
      const update = () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        bar.style.transform = `scaleX(${Math.min(100, Math.max(0, progress)) / 100})`;
      };
      window.addEventListener('scroll', update, { passive: true });
      update();
    }

    // ── TOC scroll-spy ──
    const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc a[data-heading-id]'));
    if (tocLinks.length > 0 && 'IntersectionObserver' in window) {
      const linkBySlug = new Map<string, HTMLAnchorElement>();
      tocLinks.forEach((link) => {
        const id = link.dataset.headingId;
        if (id) linkBySlug.set(id, link);
      });

      const setActive = (slug: string) => {
        tocLinks.forEach((l) => l.classList.toggle('is-active', l.dataset.headingId === slug));
      };

      const headings = Array.from(document.querySelectorAll<HTMLElement>('.article-body h2, .article-body h3'));
      const observer = new IntersectionObserver((entries) => {
        const inView = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => (a.target as HTMLElement).offsetTop - (b.target as HTMLElement).offsetTop)[0];
        if (inView) {
          const id = (inView.target as HTMLElement).id;
          if (id && linkBySlug.has(id)) setActive(id);
        }
      }, { rootMargin: '-15% 0px -65% 0px', threshold: [0, 0.5, 1] });

      headings.forEach((h) => observer.observe(h));
    }

    // ── Smooth scroll for TOC links (keyboard friendly) ──
    tocLinks.forEach((link) => {
      link.addEventListener('click', (event) => {
        const id = link.dataset.headingId;
        if (!id) return;
        const target = document.getElementById(id);
        if (!target) return;
        event.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.replaceState(null, '', `#${id}`);
      });
    });

    // ── Copy link button ──
    const copyBtn = document.getElementById('copy-link') as HTMLButtonElement | null;
    if (copyBtn && copyBtn.dataset.bound !== 'true') {
      copyBtn.dataset.bound = 'true';
      copyBtn.addEventListener('click', async () => {
        const label = copyBtn.querySelector<HTMLElement>('.copy-label');
        const original = label?.textContent ?? 'Copy link';
        try {
          await navigator.clipboard.writeText(window.location.href);
          if (label) label.textContent = 'copied ✓';
          copyBtn.classList.add('is-copied');
        } catch {
          if (label) label.textContent = 'press ⌘C';
        }
        setTimeout(() => {
          if (label) label.textContent = original;
          copyBtn.classList.remove('is-copied');
        }, 2000);
      });
    }
  };

  document.addEventListener('astro:page-load', initializeArticle);
  initializeArticle();
</script>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,300..900,0..100,0..1&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&display=swap');

  :root {
    --reader-mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    --reader-display: 'Fraunces', Georgia, serif;
    --reader-emerald-100: rgb(187 247 208);
    --reader-emerald-300: rgb(167 243 208);
    --reader-emerald-400: rgb(110 231 183);
    --reader-emerald-500: rgb(52 211 153);
    --reader-navy-950: rgb(13 22 42);
    --reader-navy-900: rgb(22 30 52);
    --reader-navy-800: rgb(28 38 70);
    --reader-navy-700: rgb(34 46 78);
    --reader-slate-100: rgb(248 250 252);
    --reader-slate-300: rgb(203 213 225);
    --reader-slate-500: rgb(100 116 139);
    --reader-amber-300: rgb(252 211 77);
    --reader-rose-300: rgb(252 165 165);
    --reader-violet-300: rgb(196 181 253);
    --reader-sky-300: rgb(125 211 252);
  }

  /* ─────────  READING PROGRESS BAR  ───────── */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    transform-origin: left center;
    transform: scaleX(0);
    background: linear-gradient(
      90deg,
      var(--reader-emerald-400) 0%,
      var(--reader-emerald-300) 50%,
      var(--reader-amber-300) 100%
    );
    z-index: 60;
    will-change: transform;
    box-shadow: 0 0 14px rgba(110, 231, 183, 0.45);
  }

  /* ─────────  MD FILE WRAPPER  ───────── */
  .md-file {
    max-width: 1200px;
    margin: 0 auto;
    padding: 6rem 1.5rem 4rem;
  }

  /* ═══════════════════════  FILE HEADER  ═══════════════════════ */
  .file-header {
    margin-bottom: 1.75rem;
    border: 1px solid rgba(187, 247, 208, 0.14);
    border-radius: 10px;
    background: linear-gradient(180deg, rgba(34, 46, 78, 0.6), rgba(22, 30, 52, 0.4));
    overflow: hidden;
  }

  /* path bar */
  .path-bar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.32rem 0.45rem;
    padding: 0.65rem 0.95rem;
    background: rgba(13, 22, 42, 0.65);
    border-bottom: 1px solid rgba(110, 231, 183, 0.08);
    font-family: var(--reader-mono);
    font-size: 0.74rem;
    color: rgba(187, 247, 208, 0.6);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    color: var(--reader-emerald-400);
    text-decoration: none;
    transition: background-color 200ms ease, color 200ms ease, transform 200ms ease;
  }

  .back-link:hover {
    background: rgba(110, 231, 183, 0.08);
    transform: translateX(-2px);
  }

  .back-glyph { font-size: 0.85rem; font-weight: 700; }

  .path-sep { color: rgba(187, 247, 208, 0.3); }

  .path-seg {
    color: rgba(187, 247, 208, 0.7);
  }

  .path-seg.active {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--reader-slate-100);
    font-weight: 600;
  }

  .path-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 3px;
    background: linear-gradient(135deg, var(--reader-sky-300), var(--reader-emerald-400));
    color: var(--reader-navy-950);
    font-size: 0.5rem;
    font-weight: 800;
    letter-spacing: -0.06em;
  }

  .path-spacer { flex: 1; }

  .path-pos {
    padding: 0.1rem 0.45rem;
    border-radius: 3px;
    background: rgba(110, 231, 183, 0.08);
    color: var(--reader-emerald-400);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    font-weight: 700;
  }

  /* tab strip */
  .tab-strip {
    position: relative;
    display: flex;
    background: rgba(22, 30, 52, 0.85);
    border-bottom: 1px solid rgba(110, 231, 183, 0.1);
  }

  .tab {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.95rem 0.55rem 0.85rem;
    color: rgba(187, 247, 208, 0.55);
    font-family: var(--reader-mono);
    font-size: 0.74rem;
    border-right: 1px solid rgba(187, 247, 208, 0.06);
    user-select: none;
  }

  .tab.is-active {
    position: relative;
    color: var(--reader-slate-100);
    background: rgba(34, 46, 78, 0.7);
  }

  .tab.is-active::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--reader-emerald-400);
    box-shadow: 0 0 12px var(--reader-emerald-400);
  }

  .tab-glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border-radius: 3px;
    background: linear-gradient(135deg, var(--reader-sky-300), var(--reader-emerald-400));
    color: var(--reader-navy-950);
    font-size: 0.46rem;
    font-weight: 800;
    letter-spacing: -0.06em;
  }

  .tab-name { font-weight: 500; }

  .tab-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--reader-emerald-400);
    box-shadow: 0 0 6px var(--reader-emerald-400);
    margin-left: 0.2rem;
  }

  .tab-close {
    color: rgba(187, 247, 208, 0.4);
    font-size: 0.95rem;
    line-height: 1;
    margin-left: 0.15rem;
  }

  .tab-fade {
    flex: 1;
    background: linear-gradient(90deg, rgba(22, 30, 52, 0.85) 0%, rgba(22, 30, 52, 0.3) 100%);
  }

  /* file substats */
  .file-substats {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    padding: 0.55rem 0.95rem;
    background: rgba(13, 22, 42, 0.5);
    font-family: var(--reader-mono);
    font-size: 0.7rem;
  }

  .file-substats .sub-cell {
    display: inline-flex;
    align-items: baseline;
    gap: 0.32rem;
  }

  .file-substats .sub-key {
    color: rgba(110, 231, 183, 0.55);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.6rem;
  }

  .file-substats .sub-val { color: var(--reader-slate-100); }
  .file-substats .sub-val.mono { color: var(--reader-amber-300); }

  .file-substats .sub-spacer { flex: 1; }

  .sub-action {
    color: rgba(187, 247, 208, 0.65);
    text-decoration: none;
    cursor: default;
    transition: color 200ms ease;
  }

  a.sub-action { cursor: pointer; }
  a.sub-action:hover { color: var(--reader-emerald-400); }

  .sub-pipe { color: rgba(187, 247, 208, 0.2); }

  /* ═══════════════════════  FRONTMATTER  ═══════════════════════ */
  .frontmatter {
    margin-bottom: 2rem;
    border: 1px solid rgba(187, 247, 208, 0.12);
    border-radius: 8px;
    background: rgba(13, 22, 42, 0.55);
    overflow: hidden;
  }

  .frontmatter summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding: 0.6rem 0.95rem;
    font-family: var(--reader-mono);
    font-size: 0.74rem;
    color: rgba(187, 247, 208, 0.7);
    transition: color 200ms ease;
    width: 100%;
    box-sizing: border-box;
  }

  .frontmatter summary::-webkit-details-marker { display: none; }
  .frontmatter summary:hover { color: var(--reader-emerald-400); }

  .fm-arrow {
    color: var(--reader-emerald-400);
    transition: transform 240ms cubic-bezier(0.2, 0.8, 0.2, 1);
    display: inline-block;
  }

  .frontmatter:not([open]) .fm-arrow {
    transform: rotate(-90deg);
  }

  .fm-token {
    color: var(--reader-amber-300);
    font-weight: 700;
  }

  .fm-label {
    color: var(--reader-slate-100);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .fm-hint {
    color: rgba(187, 247, 208, 0.4);
    font-style: italic;
    font-size: 0.66rem;
  }

  .fm-yaml {
    margin: 0;
    padding: 0.85rem 0.95rem 1.1rem;
    background: rgba(22, 30, 52, 0.4);
    border-top: 1px dashed rgba(110, 231, 183, 0.12);
    font-family: var(--reader-mono);
    font-size: 0.74rem;
    line-height: 1.7;
    overflow-x: auto;
  }

  .yaml-line { display: block; }
  .yaml-key { color: var(--reader-sky-300); }
  .yaml-colon { color: rgba(187, 247, 208, 0.5); margin-right: 0.2rem; }
  .yaml-str { color: var(--reader-emerald-300); }
  .yaml-num { color: var(--reader-amber-300); }
  .yaml-arr { color: var(--reader-violet-300); }
  .yaml-token { color: var(--reader-amber-300); font-weight: 700; }

  /* ═══════════════════════  READING GRID  ═══════════════════════ */
  .reading-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 280px);
    gap: 3rem;
    align-items: start;
  }

  .reading-main { min-width: 0; }

  /* ═══════════════════════  ARTICLE HEADER  ═══════════════════════ */
  .article-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px dashed rgba(187, 247, 208, 0.16);
  }

  .kicker {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 1.4rem;
    color: rgba(148, 163, 184, 0.85);
    font-family: var(--reader-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
  }

  .kicker-cat {
    color: var(--reader-emerald-400);
    font-weight: 600;
  }

  .kicker-sep { color: rgba(187, 247, 208, 0.3); }

  .article-title {
    margin: 0 0 1.5rem;
    color: var(--reader-slate-100);
    font-family: var(--reader-display);
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    font-weight: 400;
    font-variation-settings: 'opsz' 144, 'WONK' 1;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }

  .md-h1-prefix {
    color: var(--reader-emerald-400);
    font-family: var(--reader-mono);
    font-size: 0.55em;
    font-weight: 700;
    letter-spacing: 0;
    vertical-align: 0.35em;
    margin-right: 0.18em;
  }

  .dek {
    margin: 0 0 2rem;
    color: var(--reader-slate-300);
    font-family: var(--reader-display);
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    font-style: italic;
    font-weight: 350;
    line-height: 1.55;
    max-width: 60ch;
  }

  .md-quote-prefix {
    color: rgba(110, 231, 183, 0.7);
    font-family: var(--reader-mono);
    font-size: 0.85em;
    font-style: normal;
    font-weight: 700;
  }

  .byline {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.65rem 0.85rem;
    border: 1px solid rgba(110, 231, 183, 0.18);
    border-radius: 999px;
    background: rgba(28, 38, 70, 0.45);
    width: fit-content;
  }

  .avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--reader-emerald-400);
  }

  .byline-info { display: flex; flex-direction: column; gap: 0.1rem; }
  .byline-name {
    color: var(--reader-slate-100);
    font-family: var(--reader-display);
    font-size: 0.95rem;
    font-weight: 500;
  }
  .byline-role {
    color: rgba(187, 247, 208, 0.6);
    font-family: var(--reader-mono);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
  }

  /* ═══════════════════════  ARTICLE BODY  ═══════════════════════ */
  .article-body {
    color: var(--reader-slate-300);
    font-family: var(--reader-display);
    font-size: 1.18rem;
    font-weight: 350;
    line-height: 1.78;
    letter-spacing: -0.005em;
  }

  .article-body > p:first-of-type::first-letter {
    float: left;
    color: var(--reader-emerald-400);
    font-family: var(--reader-display);
    font-size: 4.5rem;
    font-weight: 400;
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'WONK' 1;
    line-height: 0.85;
    padding: 0.4rem 0.75rem 0 0;
  }

  .article-body p { margin: 0 0 1.55rem; }

  .article-body h1,
  .article-body h2,
  .article-body h3,
  .article-body h4 {
    color: var(--reader-slate-100);
    font-family: var(--reader-display);
    font-weight: 400;
    font-variation-settings: 'opsz' 144;
    letter-spacing: -0.015em;
    line-height: 1.2;
    scroll-margin-top: 6rem;
    position: relative;
  }

  .article-body h2 {
    margin: 3.5rem 0 1.2rem;
    font-size: clamp(1.6rem, 2.8vw, 2.1rem);
    padding-bottom: 0.55rem;
    border-bottom: 1px solid rgba(187, 247, 208, 0.16);
    font-style: italic;
  }

  .article-body h2::before {
    content: '## ';
    color: var(--reader-emerald-400);
    font-family: var(--reader-mono);
    font-style: normal;
    font-size: 0.55em;
    font-weight: 700;
    vertical-align: 0.45em;
    margin-right: 0.2em;
  }

  .article-body h3 {
    margin: 2.5rem 0 0.8rem;
    font-size: clamp(1.25rem, 2vw, 1.55rem);
  }

  .article-body h3::before {
    content: '### ';
    color: var(--reader-emerald-400);
    font-family: var(--reader-mono);
    font-style: normal;
    font-size: 0.6em;
    font-weight: 700;
    vertical-align: 0.4em;
    margin-right: 0.2em;
  }

  .article-body h4 { margin: 1.5rem 0 0.6rem; font-size: 1.1rem; }

  .article-body a {
    color: var(--reader-emerald-400);
    text-decoration: none;
    background-image: linear-gradient(transparent 92%, rgba(110, 231, 183, 0.5) 0);
    background-size: 100% 100%;
    background-repeat: no-repeat;
    transition: background-image 220ms ease, color 200ms ease;
  }

  .article-body a:hover {
    color: var(--reader-emerald-300);
    background-image: linear-gradient(transparent 88%, rgba(110, 231, 183, 0.7) 0);
  }

  .article-body code {
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    background: rgba(110, 231, 183, 0.1);
    border: 1px solid rgba(110, 231, 183, 0.18);
    color: var(--reader-emerald-300);
    font-family: var(--reader-mono);
    font-size: 0.86em;
  }

  .article-body pre {
    position: relative;
    margin: 1.75rem 0;
    padding: 1.25rem 1.4rem;
    border: 1px solid rgba(187, 247, 208, 0.16);
    border-radius: 6px;
    background: rgba(13, 22, 42, 0.85);
    overflow-x: auto;
    font-family: var(--reader-mono);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .article-body pre::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--reader-emerald-400), transparent);
    border-radius: 6px 6px 0 0;
  }

  .article-body pre code {
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--reader-slate-300);
    font-size: 1em;
  }

  .article-body ul,
  .article-body ol { margin: 0 0 1.55rem; padding-left: 1.5rem; }
  .article-body ul li,
  .article-body ol li { margin: 0.4rem 0; }

  .article-body ul {
    list-style: none;
    padding-left: 0;
  }

  .article-body ul li {
    position: relative;
    padding-left: 1.5rem;
  }

  .article-body ul li::before {
    content: '+';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--reader-emerald-400);
    font-family: var(--reader-mono);
    font-weight: 700;
    font-size: 1em;
  }

  .article-body blockquote {
    margin: 2rem 0;
    padding: 1rem 0 1rem 1.5rem;
    border-left: 3px solid var(--reader-emerald-400);
    background: linear-gradient(90deg, rgba(110, 231, 183, 0.06), transparent 60%);
    color: var(--reader-emerald-100);
    font-family: var(--reader-display);
    font-size: 1.18rem;
    font-style: italic;
    font-weight: 350;
  }

  .article-body blockquote p:last-child { margin-bottom: 0; }

  .article-body hr {
    margin: 3rem auto;
    width: 6rem;
    height: 0;
    border: 0;
    border-top: 1px dashed rgba(110, 231, 183, 0.5);
  }

  .article-body img {
    display: block;
    width: 100%;
    margin: 2rem 0;
    border: 1px solid rgba(187, 247, 208, 0.16);
    border-radius: 4px;
  }

  .article-body table {
    width: 100%;
    margin: 2rem 0;
    border-collapse: collapse;
    border: 1px solid rgba(187, 247, 208, 0.16);
    font-family: var(--reader-mono);
    font-size: 0.86rem;
  }

  .article-body table th,
  .article-body table td {
    padding: 0.7rem 0.95rem;
    border-bottom: 1px solid rgba(187, 247, 208, 0.12);
    text-align: left;
  }

  .article-body table th {
    background: rgba(34, 46, 78, 0.65);
    color: var(--reader-slate-100);
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  /* ═══════════════════════  ARTICLE FOOTER  ═══════════════════════ */
  .article-footer {
    margin: 4rem 0 2rem;
    padding: 0;
    border: 1px solid rgba(110, 231, 183, 0.18);
    border-radius: 10px;
    background: linear-gradient(180deg, rgba(34, 46, 78, 0.55), rgba(22, 30, 52, 0.4));
    overflow: hidden;
  }

  .footer-line {
    padding: 0.5rem 0.95rem;
    background: rgba(13, 22, 42, 0.6);
    border-bottom: 1px dashed rgba(110, 231, 183, 0.14);
    font-family: var(--reader-mono);
    font-size: 0.7rem;
  }

  .footer-token {
    color: var(--reader-slate-500);
    font-style: italic;
  }

  .footer-content {
    padding: 1.4rem 1.5rem 1.5rem;
  }

  .footer-eyebrow {
    margin: 0 0 0.5rem;
    color: rgba(110, 231, 183, 0.65);
    font-family: var(--reader-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    font-style: italic;
  }

  .footer-text {
    margin: 0 0 1.25rem;
    color: var(--reader-emerald-100);
    font-family: var(--reader-display);
    font-size: 1.05rem;
    font-style: italic;
    font-weight: 350;
    line-height: 1.6;
  }

  .share-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px dashed rgba(187, 247, 208, 0.14);
  }

  .share-label {
    color: rgba(110, 231, 183, 0.65);
    font-family: var(--reader-mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-right: 0.25rem;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.42rem 0.75rem;
    border: 1px solid rgba(187, 247, 208, 0.2);
    border-radius: 6px;
    background: rgba(13, 22, 42, 0.55);
    color: var(--reader-emerald-100);
    cursor: pointer;
    font-family: var(--reader-mono);
    font-size: 0.7rem;
    text-decoration: none;
    transition: color 180ms ease, border-color 180ms ease, background-color 200ms ease, transform 180ms ease;
  }

  .share-btn:hover,
  .share-btn:focus-visible {
    color: var(--reader-emerald-400);
    border-color: var(--reader-emerald-400);
    background: rgba(110, 231, 183, 0.06);
    transform: translateY(-1px);
    outline: none;
  }

  .share-btn.is-copied {
    color: var(--reader-amber-300);
    border-color: var(--reader-amber-300);
  }

  .copy-glyph { font-size: 0.85rem; }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .tags li {
    padding: 0.16rem 0.55rem;
    border-radius: 999px;
    background: rgba(28, 38, 70, 0.55);
    border: 1px solid rgba(187, 247, 208, 0.14);
    color: rgba(187, 247, 208, 0.7);
    font-family: var(--reader-mono);
    font-size: 0.66rem;
  }

  /* ═══════════════════════  ADJACENT  ═══════════════════════ */
  .adjacent {
    margin: 2.5rem 0;
  }

  .adj-title {
    margin: 0 0 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(110, 231, 183, 0.65);
    font-family: var(--reader-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .adj-glyph { color: var(--reader-emerald-400); font-size: 0.85rem; }

  .adj-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .adj-card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1rem 1.2rem;
    border: 1px solid rgba(187, 247, 208, 0.14);
    border-radius: 8px;
    background: rgba(28, 38, 70, 0.4);
    color: inherit;
    text-decoration: none;
    transition: transform 240ms cubic-bezier(0.2, 0.8, 0.2, 1), border-color 240ms ease, background-color 240ms ease;
    overflow: hidden;
  }

  .adj-card.placeholder {
    visibility: hidden;
  }

  .adj-card:hover {
    transform: translateY(-3px);
    border-color: var(--reader-emerald-400);
    background: rgba(110, 231, 183, 0.06);
  }

  .adj-card.next { text-align: right; }

  .adj-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--reader-emerald-400);
    font-family: var(--reader-mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .adj-card.next .adj-label { justify-content: flex-end; }

  .adj-arrow.flip { transform: rotate(180deg); }
  .adj-arrow { transition: transform 200ms ease; }
  .adj-card:hover .adj-arrow { transform: translateX(2px); }
  .adj-card.prev:hover .adj-arrow { transform: rotate(180deg) translateX(2px); }

  .adj-fname {
    color: rgba(110, 231, 183, 0.7);
    font-family: var(--reader-mono);
    font-size: 0.7rem;
    font-weight: 500;
  }

  .adj-name {
    color: var(--reader-slate-100);
    font-family: var(--reader-display);
    font-size: 1.05rem;
    font-weight: 400;
    line-height: 1.3;
    font-variation-settings: 'opsz' 144;
    letter-spacing: -0.012em;
  }

  .adj-meta {
    color: rgba(187, 247, 208, 0.55);
    font-family: var(--reader-mono);
    font-size: 0.66rem;
    letter-spacing: 0.04em;
  }

  /* back cta */
  .back-cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px dashed rgba(187, 247, 208, 0.14);
  }

  .back-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.7rem 1.3rem;
    border: 1px solid rgba(110, 231, 183, 0.32);
    border-radius: 999px;
    background: rgba(28, 38, 70, 0.5);
    color: var(--reader-emerald-400);
    font-family: var(--reader-mono);
    font-size: 0.78rem;
    text-decoration: none;
    transition: color 180ms ease, background-color 220ms ease, border-color 220ms ease, transform 200ms ease;
  }

  .back-cta:hover,
  .back-cta:focus-visible {
    color: var(--reader-emerald-300);
    background: rgba(110, 231, 183, 0.08);
    border-color: var(--reader-emerald-400);
    transform: translateY(-1px);
    outline: none;
  }

  .back-cta-glyph { font-size: 0.85rem; }

  .back-cta .dash {
    display: inline-block;
    width: 28px;
    height: 1px;
    background: currentColor;
    opacity: 0.5;
  }

  /* ═══════════════════════  SIDEBAR  ═══════════════════════ */
  .reading-side {
    position: sticky;
    top: 6rem;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .side-card {
    border: 1px solid rgba(187, 247, 208, 0.12);
    border-radius: 8px;
    background: rgba(22, 30, 52, 0.55);
    backdrop-filter: blur(8px);
    overflow: hidden;
  }

  .side-head {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 0.85rem;
    background: rgba(13, 22, 42, 0.55);
    border-bottom: 1px dashed rgba(110, 231, 183, 0.12);
  }

  .side-glyph { color: var(--reader-emerald-400); font-size: 0.85rem; }

  .side-head h2 {
    margin: 0;
    color: var(--reader-slate-100);
    font-family: var(--reader-mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .side-rule {
    flex: 1;
    height: 1px;
    background: rgba(110, 231, 183, 0.18);
    margin-left: 0.45rem;
  }

  /* TOC */
  .toc {
    list-style: none;
    margin: 0;
    padding: 0.6rem 0.4rem 0.7rem;
    max-height: 50vh;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(110, 231, 183, 0.2) transparent;
  }

  .toc::-webkit-scrollbar { width: 4px; }
  .toc::-webkit-scrollbar-thumb { background: rgba(110, 231, 183, 0.2); border-radius: 999px; }

  .toc-item a {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.32rem 0.6rem;
    border-radius: 4px;
    color: rgba(187, 247, 208, 0.65);
    font-family: var(--reader-mono);
    font-size: 0.72rem;
    text-decoration: none;
    line-height: 1.35;
    transition: color 180ms ease, background-color 200ms ease;
  }

  .toc-item.depth-3 a {
    padding-left: 1.5rem;
    font-size: 0.68rem;
    color: rgba(187, 247, 208, 0.5);
  }

  .toc-marker {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(187, 247, 208, 0.2);
    transition: background-color 220ms ease, transform 240ms cubic-bezier(0.2, 0.8, 0.2, 1);
    flex-shrink: 0;
  }

  .toc-item a:hover {
    color: var(--reader-emerald-100);
    background: rgba(110, 231, 183, 0.06);
  }

  .toc-item a:hover .toc-marker {
    background: var(--reader-emerald-400);
  }

  .toc-item a.is-active {
    color: var(--reader-emerald-400);
    background: rgba(110, 231, 183, 0.08);
    font-weight: 600;
  }

  .toc-item a.is-active .toc-marker {
    background: var(--reader-emerald-400);
    transform: scale(1.4);
    box-shadow: 0 0 10px var(--reader-emerald-400);
  }

  .toc-empty {
