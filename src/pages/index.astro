---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Hero from '../components/portfolio/Hero.astro';
import Experience from '../components/portfolio/Experience.astro';
import Projects from '../components/portfolio/Projects.astro';
import Education from '../components/portfolio/Education.astro';
import Skills from '../components/portfolio/Skills.astro';
import PostsPreview from '../components/portfolio/PostsPreview.astro';
import Contact from '../components/portfolio/Contact.astro';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<Layout title="Sergio Triana | Software Engineer">
	<Hero />
	<Experience />
	<Projects />
	<Education />
	<Skills />
	<PostsPreview posts={posts} />
	<Contact />
</Layout>
